+#!/bin/sh
+# === install.sh  ======================================================================================================
+#                                               Sen Infrastructure
+#                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+#                                    See the LICENSE.txt file for more information.
+#                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+# ======================================================================================================================
+#
+# Sen quick installer.
+#
+#   curl -sSf https://raw.githubusercontent.com/airbus/sen/main/resources/installer/install.sh | sh
+#   curl -sSf .../install.sh | sh -s -- 0.5.2 --yes
+#   sh install.sh                               # menu, list available
+#   sh install.sh 0.5.2                         # auto-pick or menu
+#   sh install.sh 0.5.2 --compiler gcc-12.4.0   # explicit toolchain
+#
+# The install lays down a build into $SEN_HOME/<build-id>/ and writes two
+# activate scripts there. Source the one that matches your shell:
+#
+#   bash / zsh : . $SEN_HOME/<build-id>/activate
+#   fish       : source $SEN_HOME/<build-id>/activate.fish
+#
+# Multiple builds can coexist; sourcing a build's activate strips any
+# previously-active Sen build from PATH first, so switching is just sourcing
+# the other activate file.
+#
+# Exit codes:
+#   0   success (or already installed)
+#   1   any failure: bad args, missing tooling, network, extract, ...
+#   99  another install.sh is in progress (the install lock)
+#
+# Environment overrides:
+#   SEN_HOME           install root (default: $HOME/.sen)
+#   SEN_BASE_URL       release download base
+#                      (default: https://github.com/airbus/sen)
+#   SEN_API_URL        GitHub releases API base
+#                      (default: https://api.github.com/repos/airbus/sen)
+#   SEN_RAW_URL        where the self-copy refetches install.sh from
+#                      (default: https://raw.githubusercontent.com/airbus/sen/main)
+#   SEN_HOST_ARCH      override `uname -m` (test fixtures, cross-arch debug)
+#   SEN_HOST_OS        override `uname -s`
+#   SEN_ALLOW_ROOT     set to 1 to allow root (containers); same as --allow-root
+#   NO_COLOR           set to disable color output
+#
+# Platform / tool contract:
+#   POSIX sh (dash, busybox ash, bash, zsh) for the script itself. Activate
+#   scripts are POSIX-style for bash/zsh and fish-native for fish. Linux only;
+#   architecture is filtered dynamically against the release's asset list, so
+#   a new arch ships the moment a release artifact for it appears.
+#
+#   Required on PATH (checked upfront by ensure_tools): curl, tar, sha256sum,
+#   awk, sed, grep, find, xargs, sort. Optional: tput (color), flock (install
+#   lock), shasum (sha256sum fallback).
+#
+# Function-local convention: every function declares its working vars with
+# `local`. `local` is not POSIX but dash, bash, ash, and zsh all support it,
+# and the activate script we generate already relies on it. Declaring locals
+# defends against accidental cross-function name collisions in this single
+# flat namespace.
+
+# Strict mode applies to script execution only. The test harness sources
+# this file with SENV_INSTALLER_NORUN=1 to call individual functions, where
+# `set -u` would clash with bats' habit of probing unset vars.
+if [ "${SENV_INSTALLER_NORUN:-0}" != "1" ]; then
+    set -eu
+fi
+
+SENV_INSTALLER_VERSION="0.2.0"
+
+: "${SEN_HOME:=$HOME/.sen}"
+: "${SEN_BASE_URL:=https://github.com/airbus/sen}"
+: "${SEN_API_URL:=https://api.github.com/repos/airbus/sen}"
+: "${SEN_RAW_URL:=https://raw.githubusercontent.com/airbus/sen/main}"
+
+# Parsed-arg globals. Top-level so the test harness can inspect them after
+# calling parse_args directly.
+SENV_VERSION_ARG=""
+SENV_COMPILER=""
+SENV_NON_INTERACTIVE=0
+SENV_ALLOW_ROOT=0
+
+# Resolve-stage scratch globals. Functions below set these instead of using
+# command substitution so callers don't have to round-trip through subshells
+# (where set -e behaviour is harder to reason about).
+SENV_RESOLVED_URL=""
+SENV_RESOLVED_USED_MENU=0
+SENV_ARCHIVE_PATH=""
+
+# Color globals: empty by default so `paint` is safe under `set -u` from any
+# code path (including parse_args, which runs before init_colors). init_colors
+# upgrades these to terminfo escapes when stdout is a TTY.
+_C_BOLD=""    ; _C_DIM=""     ; _C_RED=""
+_C_GREEN=""   ; _C_YELLOW=""  ; _C_CYAN=""
+_C_MAGENTA="" ; _C_RESET=""
+
+#---------------------------------------------------------------------------------------------------------------
+# Color and message helpers
+#---------------------------------------------------------------------------------------------------------------
+
+# Populate _C_* with terminfo escape sequences if stdout is a TTY, tput is
+# on PATH, the terminal supports >= 8 colors, and NO_COLOR is unset.
+init_colors() {
+    local n
+    _C_BOLD=""    ; _C_DIM=""     ; _C_RED=""
+    _C_GREEN=""   ; _C_YELLOW=""  ; _C_CYAN=""
+    _C_MAGENTA="" ; _C_RESET=""
+    [ -n "${NO_COLOR:-}" ] && return 0
+    [ -t 1 ] || return 0
+    command -v tput >/dev/null 2>&1 || return 0
+    n=$(tput colors 2>/dev/null || echo 0)
+    [ "$n" -ge 8 ] 2>/dev/null || return 0
+    _C_BOLD=$(tput bold)
+    _C_DIM=$(tput dim)
+    _C_RED=$(tput setaf 1)
+    _C_GREEN=$(tput setaf 2)
+    _C_YELLOW=$(tput setaf 3)
+    _C_CYAN=$(tput setaf 6)
+    _C_MAGENTA=$(tput setaf 5)
+    _C_RESET=$(tput sgr0)
+}
+
+# Inline colored text (no newline). Last argument is the text; preceding
+# arguments compose styles. Example: paint cyan bold "ready"
+paint() {
+    local prefix=""
+    while [ $# -gt 1 ]; do
+        case "$1" in
+            bold)    prefix="$prefix$_C_BOLD" ;;
+            dim)     prefix="$prefix$_C_DIM" ;;
+            red)     prefix="$prefix$_C_RED" ;;
+            green)   prefix="$prefix$_C_GREEN" ;;
+            yellow)  prefix="$prefix$_C_YELLOW" ;;
+            cyan)    prefix="$prefix$_C_CYAN" ;;
+            magenta) prefix="$prefix$_C_MAGENTA" ;;
+        esac
+        shift
+    done
+    printf '%s%s%s' "$prefix" "$1" "$_C_RESET"
+}
+
+err()  { printf '%s %s\n' "$(paint red bold    "$1")" "$2" >&2; }
+warn() { printf '%s %s\n' "$(paint yellow bold "$1")" "$2" >&2; }
+note() { printf '%s %s\n' "$(paint yellow      "$1")" "$2" >&2; }
+ok()   { printf '%s %s\n' "$(paint green bold  "$1")" "$2"; }
+
+#---------------------------------------------------------------------------------------------------------------
+# Argument parsing
+#---------------------------------------------------------------------------------------------------------------
+
+print_usage() {
+    cat <<EOF
+$(paint bold "Sen quick installer") $(paint dim "v$SENV_INSTALLER_VERSION")
+
+$(paint bold "Usage:") sh install.sh [<version>] [options]
+
+$(paint bold "Options:")
+  --compiler <name>-<ver>     pick a specific toolchain (gcc-12.4.0, clang-16.0.0, msvc-19.X)
+  --compiler=<name>-<ver>     same, equals form
+  -y, --yes                   non-interactive (refuse rather than open the menu)
+  --allow-root                allow running as root (containers)
+  -h, --help                  show this help
+  -V, --version               print installer version
+
+If <version> is omitted, the script prints the available release tags and
+exits. Multiple builds for one version (different compilers / archs) trigger
+an interactive menu unless --compiler resolves to exactly one or --yes is set.
+EOF
+}
+
+parse_args() {
+    SENV_VERSION_ARG=""
+    SENV_COMPILER=""
+    SENV_NON_INTERACTIVE=0
+    SENV_ALLOW_ROOT=0
+    while [ $# -gt 0 ]; do
+        case "$1" in
+            --compiler)     SENV_COMPILER="${2:-}"
+                            [ -n "$SENV_COMPILER" ] || { err "install.sh:" "--compiler needs a value."; return 1; }
+                            shift 2 ;;
+            --compiler=*)   SENV_COMPILER="${1#*=}"
+                            [ -n "$SENV_COMPILER" ] || { err "install.sh:" "--compiler needs a value."; return 1; }
+                            shift ;;
+            -y|--yes)       SENV_NON_INTERACTIVE=1; shift ;;
+            --allow-root)   SENV_ALLOW_ROOT=1; shift ;;
+            -h|--help)      print_usage; exit 0 ;;
+            -V|--version)   printf 'install.sh %s\n' "$SENV_INSTALLER_VERSION"; exit 0 ;;
+            -*)             err "install.sh:" "unknown option: $1"; return 1 ;;
+            *)
+                if [ -z "$SENV_VERSION_ARG" ]; then
+                    SENV_VERSION_ARG="$1"
+                else
+                    err "install.sh:" "unexpected argument: $1"
+                    return 1
+                fi
+                shift ;;
+        esac
+    done
+}
+
+#---------------------------------------------------------------------------------------------------------------
+# Pre-flight checks
+#---------------------------------------------------------------------------------------------------------------
+
+ensure_not_root() {
+    [ "$(id -u 2>/dev/null || echo 0)" = "0" ] || return 0
+    [ -n "${SEN_ALLOW_ROOT:-}" ] && return 0
+    [ "$SENV_ALLOW_ROOT" = "1" ] && return 0
+    err "install.sh:" "refusing to run as root (Sen installs into \$HOME)."
+    printf '%s\n' \
+        '       If you really mean it (e.g. inside a container), re-run with:' \
+        '         sh install.sh --allow-root' \
+        '       or set SEN_ALLOW_ROOT=1.' \
+        >&2
+    return 1
+}
+
+ensure_linux() {
+    case "$(host_os)" in
+        linux) ;;
+        *)
+            err "install.sh:" "Sen quick install supports Linux only (got: $(host_os))."
+            return 1 ;;
+    esac
+}
+
+ensure_curl() {
+    command -v curl >/dev/null 2>&1 && return 0
+    err "install.sh:" "this installer needs curl, which was not found in PATH."
+    printf '%s\n' \
+        '       install it and re-run, for example:' \
+        '         Debian/Ubuntu: sudo apt install curl' \
+        '         Fedora/RHEL:   sudo dnf install curl' \
+        '         Arch:          sudo pacman -S curl' \
+        '         Alpine:        sudo apk add curl' \
+        >&2
+    return 1
+}
+
+# Verify the coreutils we need are on PATH. Failure here is much friendlier
+# than an opaque "tar: command not found" deep in unpack on a minimal image
+# (Alpine without coreutils, busybox-only containers, and so on).
+ensure_tools() {
+    local tool missing=""
+    for tool in tar sha256sum awk sed grep find xargs sort; do
+        command -v "$tool" >/dev/null 2>&1 || missing="$missing $tool"
+    done
+    [ -z "$missing" ] && return 0
+    err "install.sh:" "missing required tools:$missing"
+    printf '%s\n' \
+        '       these are part of standard coreutils on every modern Linux.' \
+        '       on a minimal container, install coreutils + tar; for example:' \
+        '         Alpine:        sudo apk add coreutils tar' \
+        '         Debian/Ubuntu: sudo apt install coreutils tar findutils' \
+        >&2
+    return 1
+}
+
+#---------------------------------------------------------------------------------------------------------------
+# Host detection
+#---------------------------------------------------------------------------------------------------------------
+
+# Detect the host's architecture slot as it appears in Sen release filenames
+# (x86_64 / aarch64 / ...). amd64 / arm64 are aliased to the slots Sen uses;
+# anything else is passed through. Test override: SEN_HOST_ARCH.
+host_arch() {
+    local m
+    if [ -n "${SEN_HOST_ARCH:-}" ]; then
+        printf '%s' "$SEN_HOST_ARCH"
+        return 0
+    fi
+    m=$(uname -m 2>/dev/null || echo unknown)
+    case "$m" in
+        x86_64|amd64)   printf 'x86_64' ;;
+        aarch64|arm64)  printf 'aarch64' ;;
+        *)              printf '%s' "$m" ;;
+    esac
+}
+
+# Detect the host's OS slot as it appears in Sen release filenames. Test
+# override: SEN_HOST_OS.
+host_os() {
+    if [ -n "${SEN_HOST_OS:-}" ]; then
+        printf '%s' "$SEN_HOST_OS"
+        return 0
+    fi
+    case "$(uname -s 2>/dev/null)" in
+        Linux)  printf 'linux' ;;
+        Darwin) printf 'darwin' ;;
+        *)      printf 'unknown' ;;
+    esac
+}
+
+#---------------------------------------------------------------------------------------------------------------
+# GitHub releases: ls-remote + asset filter + toolchain parser
+#---------------------------------------------------------------------------------------------------------------
+
+# Print every release tag from GitHub, one per line.
+ls_remote() {
+    local json
+    if ! json=$(curl -fsSL "$SEN_API_URL/releases" 2>/dev/null); then
+        err "install.sh:" "could not query $SEN_API_URL/releases"
+        return 1
+    fi
+    printf '%s' "$json" \
+        | grep -o '"tag_name"[[:space:]]*:[[:space:]]*"[^"]*"' \
+        | sed -E 's/.*"([^"]+)"$/\1/'
+}
+
+# Reads a GitHub Releases API response (pretty-printed JSON) on stdin and
+# emits one tarball download URL per line, filtered to the host's
+# (arch, os). Empty on no matches.
+extract_assets() {
+    local arch os
+    arch=$(host_arch)
+    os=$(host_os)
+    grep -o '"browser_download_url"[[:space:]]*:[[:space:]]*"[^"]*"' \
+        | sed -E 's/.*"(https:[^"]+)".*/\1/' \
+        | grep -E "sen-.*-${arch}-${os}-.*-release\.tar\.gz$" \
+        || true
+}
+
+# Extract the toolchain (compiler name + version) from a Sen release URL or
+# filename. Prints "<name> <version>" on stdout. Maps the legacy `gnu` slot
+# to "gcc" for 0.5.x compatibility.
+#   sen-0.5.2-x86_64-linux-gnu-12.4.0-release.tar.gz       -> "gcc 12.4.0"
+#   sen-0.6.0-x86_64-linux-gcc-12.4.0-release.tar.gz       -> "gcc 12.4.0"
+#   sen-0.6.0-x86_64-linux-clang-16.0.0-release.tar.gz     -> "clang 16.0.0"
+#   sen-0.6.0-amd64-windows-msvc-19.44.35223.0-release.zip -> "msvc 19.44.35223.0"
+parse_toolchain() {
+    local name stem ver rest tag
+    name="${1##*/}"
+    stem="${name%-release.tar.gz}"
+    stem="${stem%-release.zip}"
+    ver="${stem##*-}"
+    rest="${stem%-*}"
+    tag="${rest##*-}"
+    case "$tag" in
+        gnu) printf '%s %s' gcc "$ver" ;;
+        *)   printf '%s %s' "$tag" "$ver" ;;
+    esac
+}
+
+#---------------------------------------------------------------------------------------------------------------
+# Compiler detection (for the menu's per-line compat hint)
+#---------------------------------------------------------------------------------------------------------------
+
+# Print the detected version of one named compiler on this system, or return
+# non-zero (with no output) if it isn't on PATH or doesn't respond.
+detect_compiler() {
+    local v
+    case "$1" in
+        gcc)
+            command -v gcc >/dev/null 2>&1 || return 1
+            v=$(gcc -dumpfullversion -dumpversion 2>/dev/null) || return 1
+            printf '%s' "$v" ;;
+        clang)
+            command -v clang >/dev/null 2>&1 || return 1
+            v=$(clang -dumpversion 2>/dev/null) || return 1
+            printf '%s' "$v" ;;
+        *)
+            return 1 ;;
+    esac
+}
+
+# One "<name> <version>" line per detected system compiler. Empty output is
+# the "nothing detected" signal; the function still returns 0.
+detect_compilers() {
+    local v
+    v=$(detect_compiler gcc 2>/dev/null)   && printf 'gcc %s\n'   "$v"
+    v=$(detect_compiler clang 2>/dev/null) && printf 'clang %s\n' "$v"
+    return 0
+}
+
+#---------------------------------------------------------------------------------------------------------------
+# Resolve URL: fetch JSON, build candidates, pick one
+#---------------------------------------------------------------------------------------------------------------
+
+# Emit one "<name> <version>\t<url>" line per host-matching Linux build for
+# $version. Empty stdout = no matching builds. Network or API errors return
+# non-zero with a message on stderr.
+build_candidates() {
+    local version="$1"
+    local api_url="$SEN_API_URL/releases/tags/$version"
+    local json urls url toolchain
+    if ! json=$(curl -fsSL "$api_url" 2>/dev/null); then
+        err "install.sh:" "could not query release '$version'"
+        printf '%s\n' "$(paint dim "run 'sh install.sh' (no args) to see available versions.")" >&2
+        return 1
+    fi
+    urls=$(printf '%s' "$json" | extract_assets)
+    [ -z "$urls" ] && return 0
+    while IFS= read -r url; do
+        [ -z "$url" ] && continue
+        toolchain=$(parse_toolchain "$url") || continue
+        printf '%s\t%s\n' "$toolchain" "$url"
+    done <<EOF
+$urls
+EOF
+}
+
+# Pick a URL according to the input policy. Sets SENV_RESOLVED_URL on success
+# and SENV_RESOLVED_USED_MENU=1 iff the user picked from the interactive menu.
+resolve_url() {
+    local version="$1" compiler="$2" non_interactive="$3"
+    local candidates user_name user_ver count
+    SENV_RESOLVED_URL=""
+    SENV_RESOLVED_USED_MENU=0
+
+    candidates=$(build_candidates "$version") || return 1
+    if [ -z "$candidates" ]; then
+        err "install.sh:" "no $(host_arch)-$(host_os) builds in release $version"
+        return 1
+    fi
+
+    # 1) Explicit --compiler. gcc-X.Y / clang-X.Y / msvc-X.Y; bare X.Y is
+    # treated as gcc-X.Y for backward compatibility with the pre-0.6 names.
+    if [ -n "$compiler" ]; then
+        case "$compiler" in
+            gcc-*)   user_name=gcc   ; user_ver="${compiler#gcc-}" ;;
+            clang-*) user_name=clang ; user_ver="${compiler#clang-}" ;;
+            msvc-*)  user_name=msvc  ; user_ver="${compiler#msvc-}" ;;
+            *)       user_name=gcc   ; user_ver="$compiler" ;;
+        esac
+        SENV_RESOLVED_URL=$(printf '%s\n' "$candidates" \
+            | awk -v want="$user_name $user_ver" -F'\t' '$1==want {print $2; exit}')
+        if [ -z "$SENV_RESOLVED_URL" ]; then
+            err "install.sh:" "no build for $version with compiler $compiler"
+            printf 'available toolchains for %s:\n' "$version" >&2
+            printf '%s\n' "$candidates" \
+                | awk -F'\t' '{ split($1, p, " "); print "  " p[1] "-" p[2] }' >&2
+            return 1
+        fi
+        warn_compat_if_needed "$SENV_RESOLVED_URL"
+        return 0
+    fi
+
+    # 2) Single match: auto-pick.
+    count=$(printf '%s\n' "$candidates" | grep -c .)
+    if [ "$count" = "1" ]; then
+        SENV_RESOLVED_URL=$(printf '%s\n' "$candidates" | awk -F'\t' '{print $2}')
+        warn_compat_if_needed "$SENV_RESOLVED_URL"
+        return 0
+    fi
+
+    # 3) Multi match, non-interactive: refuse with the toolchain list.
+    if [ "$non_interactive" = "1" ] || [ ! -t 0 ]; then
+        err "install.sh:" "multiple builds available; pass --compiler <name>-<ver>:"
+        printf '%s\n' "$candidates" \
+            | awk -F'\t' '{ split($1, p, " "); print "  " p[1] "-" p[2] }' >&2
+        return 1
+    fi
+
+    # 4) Multi match, interactive: menu.
+    run_menu "$version" "$candidates"
+}
+
+# Show the interactive selection menu and read the user's choice. Each line
+# shows "<name> <version>" plus a per-line compat marker against what the
+# user has installed.
+run_menu() {
+    local version="$1" candidates="$2"
+    local detected i line field1 cand_name cand_ver marker user_ver choice
+
+    detected=$(detect_compilers | paste -sd, - | sed 's/,/, /g')
+
+    printf '%s\n' "$(paint bold "Multiple builds available for Sen $version.")"
+    if [ -n "$detected" ]; then
+        printf '%s\n' "$(paint dim "Detected on this system: $detected")"
+    fi
+    printf '\n'
+
+    i=1
+    while IFS= read -r line; do
+        field1="${line%%	*}"
+        cand_name="${field1%% *}"
+        cand_ver="${field1##* }"
+        marker=""
+        if user_ver=$(detect_compiler "$cand_name" 2>/dev/null); then
+            if [ "$user_ver" = "$cand_ver" ]; then
+                marker="  $(paint green "(matches your $cand_name)")"
+            else
+                marker="  $(paint dim "(your $cand_name: $user_ver)")"
+            fi
+        else
+            marker="  $(paint dim "(no $cand_name on your system)")"
+        fi
+        printf '  %s %s %s%s\n' \
+            "$(paint bold "$i)")" \
+            "$(paint cyan "$cand_name")" \
+            "$(paint cyan "$cand_ver")" \
+            "$marker"
+        i=$((i+1))
+    done <<EOF
+$candidates
+EOF
+    printf '\n%s ' "$(paint bold "select a build [1-$((i-1))]:")"
+    choice=""
+    if ! read -r choice </dev/tty 2>/dev/null; then
+        err "aborted:" "cannot read from terminal."
+        return 1
+    fi
+    case "$choice" in
+        ''|*[!0-9]*) err "aborted:" "invalid selection."; return 1 ;;
+    esac
+    if [ "$choice" -lt 1 ] || [ "$choice" -ge "$i" ]; then
+        err "aborted:" "selection out of range."
+        return 1
+    fi
+    SENV_RESOLVED_URL=$(printf '%s\n' "$candidates" \
+        | sed -n "${choice}p" \
+        | awk -F'\t' '{print $2}')
+    SENV_RESOLVED_USED_MENU=1
+}
+
+# Soft compatibility note. Suppressed when the menu was used (the menu showed
+# the per-line comparison already). Otherwise:
+#   - build's compiler not on PATH at all -> flag it.
+#   - on PATH at a different version      -> warn about potential ABI mismatch.
+#   - versions match                      -> stay silent.
+warn_compat_if_needed() {
+    local url="$1"
+    local toolchain build_name build_ver user_ver
+    [ "$SENV_RESOLVED_USED_MENU" = "1" ] && return 0
+    toolchain=$(parse_toolchain "$url") || return 0
+    build_name="${toolchain%% *}"
+    build_ver="${toolchain##* }"
+    if ! user_ver=$(detect_compiler "$build_name" 2>/dev/null); then
+        note "note:" "this build needs $build_name $build_ver; '$build_name' is not on your PATH."
+        return 0
+    fi
+    [ "$user_ver" = "$build_ver" ] && return 0
+    note "note:" "this build was compiled with $build_name $build_ver, your $build_name is $user_ver."
+    printf '%s\n' "$(paint dim '      ABI mismatches may show up at link time. proceeding.')" >&2
+}
+
+#---------------------------------------------------------------------------------------------------------------
+# Fetch + checksum verification
+#---------------------------------------------------------------------------------------------------------------
+
+# Place $url's archive at $SEN_HOME/cache/$fname. Cache hit when the file is
+# already present (it was written by a previous successful download under
+# the install lock). The post-download verify_checksum step catches a
+# corrupted cache hit when SHA256SUMS is published by the release; without
+# SHA256SUMS we trust the cache, which is bounded by "we put it there".
+# Sets SENV_ARCHIVE_PATH on success.
+fetch_archive() {
+    local url="$1" fname="$2"
+    local archive="$SEN_HOME/cache/$fname"
+    mkdir -p "$SEN_HOME/cache"
+    if [ -f "$archive" ]; then
+        printf '%s %s\n' "$(paint dim 'using cached')" "$fname"
+        SENV_ARCHIVE_PATH="$archive"
+        return 0
+    fi
+    printf '%s %s\n' "$(paint bold 'downloading')" "$fname"
+    if ! curl -fL --progress-bar "$url" -o "${archive}.part"; then
+        rm -f "${archive}.part"
+        err "install.sh:" "download failed."
+        return 1
+    fi
+    mv "${archive}.part" "$archive"
+    SENV_ARCHIVE_PATH="$archive"
+}
+
+# Best-effort SHA256SUMS verification. Returns 0 with a soft note when the
+# release doesn't publish SHA256SUMS or when there's no entry for $fname.
+# Returns 1 (and deletes $archive) on a real mismatch.
+verify_checksum() {
+    local version="$1" fname="$2" archive="$3"
+    local sums_url="$SEN_BASE_URL/releases/download/$version/SHA256SUMS"
+    local sums expected actual=""
+    if ! sums=$(curl -fsSL "$sums_url" 2>/dev/null); then
+        note "note:" "SHA256SUMS not published for $version; skipping verification."
+        return 0
+    fi
+    expected=$(printf '%s\n' "$sums" \
+        | awk -v f="$fname" '$2==f || $2=="*"f {print $1; exit}')
+    if [ -z "$expected" ]; then
+        warn "warning:" "no checksum entry for $fname in SHA256SUMS; skipping."
+        return 0
+    fi
+    if command -v sha256sum >/dev/null 2>&1; then
+        actual=$(sha256sum "$archive" | awk '{print $1}')
+    elif command -v shasum >/dev/null 2>&1; then
+        actual=$(shasum -a 256 "$archive" | awk '{print $1}')
+    else
+        warn "warning:" "no sha256sum tool found; skipping verification."
+        return 0
+    fi
+    if [ "$actual" = "$expected" ]; then
+        return 0
+    fi
+    err "install.sh:" "checksum mismatch for $fname"
+    printf '  expected: %s\n' "$expected" >&2
+    printf '  got:      %s\n' "$actual" >&2
+    rm -f "$archive"
+    return 1
+}
+
+#---------------------------------------------------------------------------------------------------------------
+# Extract + manifest + completion cache
+#---------------------------------------------------------------------------------------------------------------
+
+# Extract $archive into $prefix (promoting a single top-level dir if present),
+# pre-render Sen CLI completions into the build tree, then write the
+# per-install manifest. The order matters: completions are generated before
+# the manifest so they get integrity-checked alongside the rest of the build.
+#
+# Tar safety: we extract into a per-PID staging dir under $SEN_HOME/cache and
+# rely on the trust assumption documented in the README's security model
+# (a compromised release pipeline can publish a malicious build; we have no
+# out-of-band signing today). We do not pre-validate paths against `..`.
+unpack() {
+    local archive="$1" prefix="$2"
+    local tmp="$SEN_HOME/cache/.extract.$$"
+    local entries top_count top
+    rm -rf "$tmp"
+    mkdir -p "$tmp"
+    if ! tar -xf "$archive" -C "$tmp"; then
+        rm -rf "$tmp"
+        err "install.sh:" "extraction failed."
+        return 1
+    fi
+
+    entries=$(ls -1 "$tmp")
+    top_count=$(printf '%s\n' "$entries" | grep -c .)
+    if [ "$top_count" = "1" ] && [ -d "$tmp/$entries" ]; then
+        top="$tmp/$entries"
+    else
+        top="$tmp"
+    fi
+
+    mkdir -p "$(dirname "$prefix")"
+    if ! mv "$top" "$prefix"; then
+        rm -rf "$tmp"
+        err "install.sh:" "could not move build into place at $prefix"
+        return 1
+    fi
+    rm -rf "$tmp"
+
+    cache_completions "$prefix"
+    if ! generate_manifest "$prefix"; then
+        warn "warning:" "could not generate integrity manifest; you won't be able to verify this build later with sha256sum -c."
+    fi
+}
+
+# Walk the build tree and write a sha256sum-format manifest at the root
+# (one "<hex>  <relative-path>" per line, suitable for `sha256sum -c`).
+# Excludes the manifest itself and the activate scripts (which the installer
+# generates after extraction, so they wouldn't match). The activate scripts
+# being outside the manifest is consistent with the security model: tampering
+# with them is a "local write to $SEN_HOME" threat (see README), not a build
+# integrity threat.
+generate_manifest() {
+    local prefix="$1"
+    local manifest="$prefix/.sen-manifest.sha256"
+    command -v sha256sum >/dev/null 2>&1 || return 1
+    (cd "$prefix" \
+        && find . -type f \
+            ! -name '.sen-manifest.sha256' \
+            ! -name 'activate' \
+            ! -name 'activate.fish' \
+            -printf '%P\0' \
+        | LC_ALL=C sort -z \
+        | xargs -0 -r sha256sum > "$manifest" 2>/dev/null) \
+        || { rm -f "$manifest"; return 1; }
+    [ -s "$manifest" ] || { rm -f "$manifest"; return 1; }
+}
+
+# Pre-render Sen CLI completion scripts into the build tree. The activate
+# scripts source these from $SEN_PREFIX/share/sen-completions/<shell>.
+# Best-effort: a build whose `sen` binary lacks `completion <shell>` just
+# leaves the cache empty, and the activate's fallback re-runs the binary.
+cache_completions() {
+    local prefix="$1"
+    local cdir shell tmp
+    [ -x "$prefix/bin/sen" ] || return 0
+    cdir="$prefix/share/sen-completions"
+    mkdir -p "$cdir"
+    for shell in bash zsh fish; do
+        tmp="$cdir/$shell.tmp"
+        # Redirect stdin from /dev/null so a misbehaving binary that reads
+        # from stdin gets EOF immediately instead of stalling the install.
+        if "$prefix/bin/sen" completion "$shell" </dev/null > "$tmp" 2>/dev/null && [ -s "$tmp" ]; then
+            mv "$tmp" "$cdir/$shell"
+        else
+            rm -f "$tmp"
+        fi
+    done
+}
+
+#---------------------------------------------------------------------------------------------------------------
+# Activate-script generation
+#---------------------------------------------------------------------------------------------------------------
+
+# Write $prefix/activate (POSIX-style, sourceable from bash/zsh) and
+# $prefix/activate.fish (fish-native). Both:
+#   - bake $SEN_PREFIX as a literal so the script is self-contained;
+#   - strip any existing entries under $SEN_HOME/ from PATH and friends, so
+#     re-sourcing or sourcing a different build's activate is idempotent;
+#   - prepend the new build's bin/lib/include/pkgconfig dirs;
+#   - source the cached completion script for the current shell, falling
+#     back to `sen completion <shell>` at runtime if the cache isn't there.
+write_activate_scripts() {
+    local prefix="$1"
+    local sen_root="$SEN_HOME"
+
+    cat > "$prefix/activate" <<EOF
+# === activate (bash / zsh) ============================================================================================
+#                                               Sen Infrastructure
+#                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+#                                    See the LICENSE.txt file for more information.
+#                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+# ======================================================================================================================
+#
+# Source this file from bash or zsh:
+#     . $prefix/activate
+#
+# Sourcing a different build's activate first strips any prior Sen entries
+# from PATH and friends, so switching is just sourcing the new file.
+# To leave the env: re-open the shell (we do not provide a deactivate
+# function; it is not worth the complexity for a use-case that 'exec \$SHELL'
+# already covers).
+
+SEN_PREFIX='$prefix'
+export SEN_PREFIX
+_sen_root='$sen_root'
+
+_sen_strip() {
+    # Drop colon-separated entries under \$_sen_root/ from \$1; print the rest.
+    # POSIX-only parameter expansion (no awk, no fork). 'local' keeps the
+    # working vars from leaking into the caller's interactive shell.
+    local _in="\$1" _out="" _rest="\$1" _entry
+    [ -z "\$_in" ] && return 0
+    while [ -n "\$_rest" ]; do
+        if [ "\${_rest#*:}" != "\$_rest" ]; then
+            _entry="\${_rest%%:*}"
+            _rest="\${_rest#*:}"
+        else
+            _entry="\$_rest"
+            _rest=""
+        fi
+        case "\$_entry" in
+            "\$_sen_root"/*) ;;
+            "") ;;
+            *) _out="\${_out:+\$_out:}\$_entry" ;;
+        esac
+    done
+    printf '%s' "\$_out"
+}
+
+PATH=\$(_sen_strip "\$PATH")
+CMAKE_PREFIX_PATH=\$(_sen_strip "\${CMAKE_PREFIX_PATH:-}")
+PKG_CONFIG_PATH=\$(_sen_strip "\${PKG_CONFIG_PATH:-}")
+LD_LIBRARY_PATH=\$(_sen_strip "\${LD_LIBRARY_PATH:-}")
+
+PATH="\$SEN_PREFIX/bin\${PATH:+:\$PATH}"
+CMAKE_PREFIX_PATH="\$SEN_PREFIX\${CMAKE_PREFIX_PATH:+:\$CMAKE_PREFIX_PATH}"
+PKG_CONFIG_PATH="\$SEN_PREFIX/lib/pkgconfig\${PKG_CONFIG_PATH:+:\$PKG_CONFIG_PATH}"
+LD_LIBRARY_PATH="\$SEN_PREFIX/lib\${LD_LIBRARY_PATH:+:\$LD_LIBRARY_PATH}"
+
+export PATH CMAKE_PREFIX_PATH PKG_CONFIG_PATH LD_LIBRARY_PATH
+
+unset _sen_root
+unset -f _sen_strip 2>/dev/null || true
+
+# Sen CLI completion. Prefer the install-time cache; fall back to invoking
+# the binary so an older build (no completion script cached) still works.
+if [ -n "\${BASH_VERSION:-}" ]; then
+    if [ -r "\$SEN_PREFIX/share/sen-completions/bash" ]; then
+        # shellcheck disable=SC1091
+        . "\$SEN_PREFIX/share/sen-completions/bash" 2>/dev/null || true
+    elif command -v sen >/dev/null 2>&1; then
+        eval "\$(sen completion bash 2>/dev/null)" 2>/dev/null || true
+    fi
+elif [ -n "\${ZSH_VERSION:-}" ]; then
+    if [ -r "\$SEN_PREFIX/share/sen-completions/zsh" ]; then
+        # shellcheck disable=SC1091
+        . "\$SEN_PREFIX/share/sen-completions/zsh" 2>/dev/null || true
+    elif command -v sen >/dev/null 2>&1; then
+        eval "\$(sen completion zsh 2>/dev/null)" 2>/dev/null || true
+    fi
+fi
+EOF
+
+    cat > "$prefix/activate.fish" <<EOF
+# === activate.fish ====================================================================================================
+#                                               Sen Infrastructure
+#                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+#                                    See the LICENSE.txt file for more information.
+#                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+# ======================================================================================================================
+#
+# Source this file from fish:
+#     source $prefix/activate.fish
+
+set -gx SEN_PREFIX '$prefix'
+set -l _sen_root '$sen_root'
+
+function _sen_strip --no-scope-shadowing -a input
+    # Drop entries under \$_sen_root/ from a colon-separated string; print the rest.
+    if test -z "\$input"
+        return 0
+    end
+    set -l out
+    for e in (string split ':' -- \$input)
+        switch \$e
+            case "\$_sen_root/*"
+            case ""
+            case '*'
+                set -a out \$e
+        end
+    end
+    string join ':' -- \$out
+end
+
+set -l _sen_path           (_sen_strip "\$PATH")
+set -l _sen_cmake_path     (_sen_strip "\$CMAKE_PREFIX_PATH")
+set -l _sen_pkgconfig_path (_sen_strip "\$PKG_CONFIG_PATH")
+set -l _sen_ldlib_path     (_sen_strip "\$LD_LIBRARY_PATH")
+
+# fish PATH is naturally a list, not a colon-string; convert by splitting.
+set -gx PATH \$SEN_PREFIX/bin (string split ':' -- \$_sen_path)
+
+if test -n "\$_sen_cmake_path"
+    set -gx CMAKE_PREFIX_PATH "\$SEN_PREFIX:\$_sen_cmake_path"
+else
+    set -gx CMAKE_PREFIX_PATH "\$SEN_PREFIX"
+end
+if test -n "\$_sen_pkgconfig_path"
+    set -gx PKG_CONFIG_PATH "\$SEN_PREFIX/lib/pkgconfig:\$_sen_pkgconfig_path"
+else
+    set -gx PKG_CONFIG_PATH "\$SEN_PREFIX/lib/pkgconfig"
+end
+if test -n "\$_sen_ldlib_path"
+    set -gx LD_LIBRARY_PATH "\$SEN_PREFIX/lib:\$_sen_ldlib_path"
+else
+    set -gx LD_LIBRARY_PATH "\$SEN_PREFIX/lib"
+end
+
+functions -e _sen_strip
+
+# Sen CLI completion. Prefer the install-time cache; fall back to the binary.
+if test -r "\$SEN_PREFIX/share/sen-completions/fish"
+    source "\$SEN_PREFIX/share/sen-completions/fish" 2>/dev/null
+else if command -v sen >/dev/null 2>&1
+    sen completion fish 2>/dev/null | source
+end
+EOF
+    chmod 0644 "$prefix/activate" "$prefix/activate.fish"
+}
+
+#---------------------------------------------------------------------------------------------------------------
+# Self-copy: refetch install.sh into $SEN_HOME so future installs / re-runs
+# don't need a network round-trip to the bootstrap URL.
+#---------------------------------------------------------------------------------------------------------------
+
+self_copy_installer() {
+    local target tmp
+    [ -n "${SEN_INSTALLER_NO_SELF_COPY:-}" ] && return 0
+    target="$SEN_HOME/install.sh"
+    tmp="${target}.tmp.$$"
+    if curl -fsSL "$SEN_RAW_URL/resources/installer/install.sh" -o "$tmp" 2>/dev/null; then
+        mv "$tmp" "$target"
+        chmod 0755 "$target"
+    else
+        rm -f "$tmp"
+    fi
+}
+
+#---------------------------------------------------------------------------------------------------------------
+# Install lock
+#---------------------------------------------------------------------------------------------------------------
+
+# Run "$@" under an exclusive non-blocking flock on $SEN_HOME/.lock-install.
+# If flock isn't on PATH we run unwrapped (single-user systems without flock
+# are unlikely to race two concurrent installers).
+with_install_lock() {
+    if ! command -v flock >/dev/null 2>&1; then
+        "$@"
+        return $?
+    fi
+    mkdir -p "$SEN_HOME"
+    (
+        flock -n 9 || {
+            err "install.sh:" "another install is in progress."
+            exit 99
+        }
+        "$@"
+    ) 9>"$SEN_HOME/.lock-install"
+}
+
+#---------------------------------------------------------------------------------------------------------------
+# Orchestrator
+#---------------------------------------------------------------------------------------------------------------
+
+# Body of the install pipeline (runs under with_install_lock when flock is
+# present). Walks: resolve URL -> already-installed short-circuit -> download
+# (or cache hit) -> verify checksum -> extract + completions + manifest ->
+# activate scripts -> self-copy installer -> next-steps message.
+#
+# Rollback: once the build directory is created (by unpack), any subsequent
+# failure removes the half-installed prefix via an EXIT trap. Without this,
+# a failure between unpack and write_activate_scripts (disk full, signal,
+# etc.) would leave a directory the next install short-circuits on.
+do_install() {
+    local fname stem build prefix
+    resolve_url "$SENV_VERSION_ARG" "$SENV_COMPILER" "$SENV_NON_INTERACTIVE" || return $?
+
+    fname="${SENV_RESOLVED_URL##*/}"
+    stem="${fname%-release.tar.gz}"
+    build="${stem#sen-}"
+    prefix="$SEN_HOME/$build"
+
+    if [ -d "$prefix" ]; then
+        warn "already installed:" "$build"
+        printf "  prefix: %s\n" "$prefix"
+        printf "  remove the directory and re-run if you want to reinstall.\n"
+        return 0
+    fi
+
+    fetch_archive "$SENV_RESOLVED_URL" "$fname" || return $?
+    verify_checksum "$SENV_VERSION_ARG" "$fname" "$SENV_ARCHIVE_PATH" || return $?
+
+    # Arm the rollback. The trap fires when the (sub)shell exits, which
+    # happens on `set -e` abort, signal, or end-of-script. We disarm with
+    # `trap - EXIT` once the install is fully written.
+    trap "rm -rf '$prefix'" EXIT
+
+    unpack "$SENV_ARCHIVE_PATH" "$prefix" || return $?
+    write_activate_scripts "$prefix"
+    self_copy_installer
+
+    trap - EXIT
+
+    ok "installed:" "$build"
+    printf '  %s %s\n' "$(paint dim 'prefix:')" "$prefix"
+    printf '\n%s\n' "$(paint bold 'Next: source the activate file for your shell.')"
+    printf '  %s    %s\n' "$(paint cyan 'bash/zsh:')" ". $prefix/activate"
+    printf '  %s        %s\n' "$(paint cyan 'fish:')" "source $prefix/activate.fish"
+    printf '\n%s\n' "$(paint dim 'Add the same line to your shell rc to load Sen on every new shell.')"
+}
+
+main() {
+    parse_args "$@"
+    init_colors
+    ensure_not_root
+    ensure_linux
+    ensure_curl
+    ensure_tools
+
+    mkdir -p "$SEN_HOME"
+
+    if [ -z "$SENV_VERSION_ARG" ]; then
+        printf '%s\n' "$(paint bold "Available Sen releases:")"
+        ls_remote || return $?
+        printf '\n%s\n' "$(paint dim "Re-run with a version: sh install.sh <version>")"
+        return 0
+    fi
+
+    with_install_lock do_install
+}
+
+# Allow the test harness to source this file without executing main.
+[ "${SENV_INSTALLER_NORUN:-0}" = "1" ] || main "$@"
