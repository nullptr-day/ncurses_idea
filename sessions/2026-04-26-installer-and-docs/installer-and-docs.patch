+# === installer-tests.yaml  ============================================================================================
+#                                               Sen Infrastructure
+#                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+#                                    See the LICENSE.txt file for more information.
+#                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+# ======================================================================================================================
+#
+# Runs the Sen installer's bats test suite on every PR and push to main
+# that touches resources/installer/. Standalone job; doesn't depend on the
+# C++ build.
+
+name: Installer tests
+
+on:
+  pull_request:
+    paths:
+      - 'resources/installer/**'
+      - '.github/workflows/installer-tests.yaml'
+  push:
+    branches: [main]
+    paths:
+      - 'resources/installer/**'
+      - '.github/workflows/installer-tests.yaml'
+
+permissions:
+  contents: read
+
+jobs:
+  installer-tests:
+    name: "Installer test suite"
+    # Pin the runner image rather than ubuntu-latest. The combination of
+    # OS image + apt repo determines the bats / coreutils / dash versions
+    # the suite runs against; pinning makes those versions stable across
+    # CI runs. Bump deliberately when the image is deprecated.
+    runs-on: ubuntu-22.04
+    steps:
+      - uses: actions/checkout@v6
+
+      - name: Install bats and dash
+        run: |
+          sudo apt-get update
+          sudo apt-get install -y --no-install-recommends bats dash
+
+      - name: Pin-check bats version
+        # We don't hard-pin via the package version (would break on a
+        # different Ubuntu image), but we surface unexpected drift loudly.
+        # If this fails: audit the new bats version, run the suite locally
+        # against it, then bump EXPECTED_BATS_PREFIX below.
+        env:
+          EXPECTED_BATS_PREFIX: "1.2"
+        run: |
+          actual=$(bats --version | awk '{print $2}')
+          case "$actual" in
+              ${EXPECTED_BATS_PREFIX}*) echo "bats $actual (expected ${EXPECTED_BATS_PREFIX}*)" ;;
+              *)
+                  echo "::error::bats version drifted: expected ${EXPECTED_BATS_PREFIX}*, got $actual"
+                  exit 1 ;;
+          esac
+
+      - name: Run installer test suite (strict)
+        env:
+          SEN_DEV_STRICT: "1"   # missing tooling becomes a hard failure
+        run: sh resources/installer/test/run.sh
