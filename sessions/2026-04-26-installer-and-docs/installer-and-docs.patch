+complete_step() {
+    local msg="$1"
+    if [ -n "$_C_BOLD" ]; then
+        printf '\033[2A\r\033[2K  %s %s\n\033[2K' \
+            "$(paint green bold "${_G_OK% }")" \
+            "$msg"
+    else
+        step_done "$msg"
+    fi
+}
