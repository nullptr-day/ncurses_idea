+TextSpan tokenSpan(const StlToken& t)
+{
+  // CodeLocation::offset points to the position *after* the token (the scanner stores
+  // current_ at emit time), so the token starts at loc.offset - lexeme.size().
+  const std::size_t start = t.loc.offset >= t.lexeme.size() ? t.loc.offset - t.lexeme.size() : 0U;
+  return TextSpan {start, t.loc.offset};
+}
+
+TextSpan mergeSpans(const TextSpan& a, const TextSpan& b) { return TextSpan {a.begin, b.end}; }
+
+std::shared_ptr<StlExpr> makeExpr(StlExprVal value, const TextSpan& span)
+{
+  return std::make_shared<StlExpr>(StlExpr {std::move(value), span});
+}
+
+// Human-readable display form for a token, used inside diagnostic messages so users see what the
+// parser actually found (e.g. "end of input", "identifier 'foo'", "'SELECT'").
+std::string tokenDisplay(const StlToken& t)
+{
+  switch (t.type)  // NOSONAR
+  {
+    case StlTokenType::endOfFile:
+      return "end of input";
+    case StlTokenType::identifier:
+      return "identifier '" + t.lexeme + "'";
+    case StlTokenType::string:
+      return "string literal";
+    case StlTokenType::real:
+    case StlTokenType::integral:
+      return "number '" + t.lexeme + "'";
+    case StlTokenType::comment:
+      return "comment";
+    case StlTokenType::invalidChar:
+      return "invalid character '" + t.lexeme + "'";
+    case StlTokenType::partialString:
+      return "unterminated string";
+    default:
+      return t.lexeme.empty() ? std::string("token") : ("'" + t.lexeme + "'");
+  }
+}
+
+std::string expectedGot(const std::string& expected, const StlToken& got)
+{
+  return "Expected " + expected + "; got " + tokenDisplay(got);
+}
