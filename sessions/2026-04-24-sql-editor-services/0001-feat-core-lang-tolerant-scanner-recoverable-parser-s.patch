+/// @test
+/// Every expression node carries a span that covers its source range.
+TEST(Parser, querySpansCoverSource)
+{
+  std::string program = R"(SELECT rpr.Aircraft FROM se.env WHERE lat >= 13)";
+  StlScanner scanner(program);
+  auto tokens = scanner.scanTokens();
+
+  StlParser parser(tokens);
+  auto query = parser.parseQuery();
+
+  ASSERT_TRUE(query.type.has_value());
+  EXPECT_EQ(program.substr(query.type->span.begin, query.type->span.end - query.type->span.begin), "rpr.Aircraft");
+  EXPECT_EQ(program.substr(query.bus.span.begin, query.bus.span.end - query.bus.span.begin), "se.env");
+  ASSERT_TRUE(query.condition);
+  EXPECT_EQ(program.substr(query.condition->span.begin, query.condition->span.end - query.condition->span.begin),
+            "lat >= 13");
+  EXPECT_GE(query.span.end, query.condition->span.end);
+}
