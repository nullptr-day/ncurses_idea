+/// @test
+/// Parenthesized expressions carry a span that covers '(' through ')'.
+TEST(Parser, groupingSpanIncludesParens)
+{
+  std::string program = R"(SELECT rpr.A FROM se.env WHERE (a + 1) > 0)";
+  StlScanner scanner(program);
+  auto tokens = scanner.scanTokens();
+  StlParser parser(tokens);
+  auto query = parser.parseQuery();
+
+  ASSERT_TRUE(query.condition);
+  using sen::lang::StlBinaryExpr;
+  const auto* binary = std::get_if<StlBinaryExpr>(&query.condition->value);
+  ASSERT_NE(binary, nullptr);
+  ASSERT_TRUE(binary->lhs);
+  EXPECT_EQ(sliceBySpan(program, binary->lhs->span), "(a + 1)");
+}
