+  using sen::lang::ScanMode;
+
+  std::string program = "SELECT a FROM x.y WHERE a # 1";  // '#' triggers a scanner diagnostic
+  StlScanner scanner(program, ScanMode::tolerant);
+  auto tokens = scanner.scanTokens();
+  auto scannerDiags = scanner.diagnostics();
+  ASSERT_FALSE(scannerDiags.empty());
+
+  StlParser parser(tokens);
+  auto result = parser.parseQueryTolerant(std::move(scannerDiags));
+
+  bool sawScanDiag = false;
+  for (const auto& d: result.diagnostics)
+  {
+    if (d.code == DiagnosticCode::scanInvalidChar)
+    {
+      sawScanDiag = true;
+      break;
+    }
+  }
+  EXPECT_TRUE(sawScanDiag);
+}
