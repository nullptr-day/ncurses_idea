@@ -0,0 +1,80 @@
+// === diagnostic.h ====================================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#ifndef SEN_CORE_LANG_DIAGNOSTIC_H
+#define SEN_CORE_LANG_DIAGNOSTIC_H
+
+// sen
+#include "sen/core/lang/code_location.h"
+
+// std
+#include <string>
+#include <string_view>
+#include <vector>
+
+namespace sen::lang
+{
+
+/// \addtogroup lang
+/// @{
+
+/// How serious a diagnostic is. Follows the LSP convention.
+enum class Severity
+{
+  info,
+  warning,
+  error,
+};
+
+/// Stable identifier for a class of diagnostic.
+///
+/// Enumerator names may be refactored; the short tags returned by `toString` are the
+/// codebook contract that tests, doc anchors, logs, and future telemetry rely on.
+enum class DiagnosticCode
+{
+  // scanner
+  scanInvalidChar,
+  scanUnterminatedString,
+
+  // parser
+  parseSyntax,
+  parseChainedComparison,
+  parseBetweenInverted,
+
+  // validator (errors: property problem on a *known* class)
+  validateUnknownProperty,
+  validateTypeMismatch,
+
+  // validator (infos: self-clearing as the registry / bus lookup catches up)
+  validateUnknownClass,
+  validateUnknownSession,
+  validateUnknownBus,
+};
+
+/// Short, stable tag for a diagnostic code. Intended for logs, UI, and doc anchors.
+[[nodiscard]] std::string_view toString(DiagnosticCode code) noexcept;
+
+/// A structured message produced by the editor services (scanner, parser, validator, ...).
+///
+/// Diagnostics are position-bearing: each one carries a TextSpan into the source buffer so that
+/// tools can highlight the offending region. `code` is the machine-readable class;
+/// `message` is the human-readable text.
+struct Diagnostic
+{
+  TextSpan       span = {};
+  Severity       severity = Severity::error;
+  DiagnosticCode code = DiagnosticCode::parseSyntax;
+  std::string    message = {};
+};
+
+using DiagnosticList = std::vector<Diagnostic>;
+
+/// @}
+
+}  // namespace sen::lang
+
+#endif  // SEN_CORE_LANG_DIAGNOSTIC_H
