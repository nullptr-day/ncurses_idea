+// Helper to extract the source substring covered by an expression's span.
+namespace
+{
+std::string sliceBySpan(const std::string& program, const sen::lang::TextSpan& span)
+{
+  if (span.end <= span.begin || span.end > program.size())
+  {
+    return {};
+  }
+  return program.substr(span.begin, span.end - span.begin);
+}
