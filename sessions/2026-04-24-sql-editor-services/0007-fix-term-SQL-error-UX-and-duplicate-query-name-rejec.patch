-std::vector<Run> buildRuns(std::string_view sql, std::size_t baseOffset)
+std::vector<Run> buildRuns(std::string_view sql,
+                            std::size_t baseOffset,
+                            const std::vector<sen::lang::TextSpan>& errorSpans)
 {
+  const auto overlapsError = [&](const sen::lang::TextSpan& s) -> bool
+  {
+    for (const auto& es: errorSpans)
+    {
+      if (s.begin < es.end && es.begin < s.end) { return true; }
+    }
+    return false;
+  };
+
   std::vector<Run> runs;
   const auto tokens = sen::lang::query::tokenize(sql);
   runs.reserve(tokens.tokens.size());
   for (const auto& t: tokens.tokens)
   {
-    if (!kindIsStyled(t.kind)) { continue; }
-    runs.push_back({baseOffset + t.span.begin, baseOffset + t.span.end, decoratorFor(t.kind)});
+    const bool isError = overlapsError(t.span);
+    if (!kindIsStyled(t.kind) && !isError) { continue; }
+    const auto deco = isError ? styles::queryError() : decoratorFor(t.kind);
+    runs.push_back({baseOffset + t.span.begin, baseOffset + t.span.end, deco});
   }
   return runs;
 }
