+TEST(BuildRuns, errorSpanOnIdentifierAddsStyledRun)
+{
+  // A diagnostic spanning an identifier must produce a run covering that identifier
+  // even though plain identifiers are otherwise unstyled.
+  const std::string_view sql = "SELECT x FROM s.b WHERE foo = 1";
+  // Span over "foo" (24..27).
+  const std::vector<sen::lang::TextSpan> errorSpans {{24U, 27U}};
+  const auto runs = buildRuns(sql, 0U, errorSpans);
+  // Baseline: SELECT + FROM + WHERE + 1 = 4 styled runs without errors.
+  // With "foo" underlined, we get a fifth run.
+  ASSERT_EQ(runs.size(), 5U);
+  const auto* errRun = runAt(runs, 25U);
+  ASSERT_NE(errRun, nullptr);
+  EXPECT_EQ(errRun->begin, 24U);
+  EXPECT_EQ(errRun->end,   27U);
+}
+
+TEST(BuildRuns, errorSpanShiftsWithBaseOffset)
+{
+  const std::string_view sql = "foo";
+  const std::vector<sen::lang::TextSpan> errorSpans {{0U, 3U}};
+  const auto runs = buildRuns(sql, 10U, errorSpans);
+  ASSERT_EQ(runs.size(), 1U);
+  EXPECT_EQ(runs[0].begin, 10U);
+  EXPECT_EQ(runs[0].end,   13U);
+}
