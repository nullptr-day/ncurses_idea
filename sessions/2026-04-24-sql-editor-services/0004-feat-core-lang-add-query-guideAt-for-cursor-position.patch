+#ifndef SEN_CORE_LANG_QUERY_GUIDE_H
+#define SEN_CORE_LANG_QUERY_GUIDE_H
+
+// std
+#include <cstddef>
+#include <string_view>
+
+namespace sen::lang::query
+{
+
+/// \addtogroup lang
+/// @{
+
+/// Grammatical role of whatever the cursor is about to produce. Editors can pick an icon
+/// or styling off this; `hint` carries a default human-readable description for UIs that
+/// don't want to maintain their own message table.
+enum class GuidanceShape
+{
+  selectKeyword,           /// start of query; `SELECT` is expected
+  className,               /// after `SELECT` or a `.` in the class path
+  classPathContinuation,   /// after a class identifier; `FROM`
+  fromKeyword,             /// after `SELECT *`; `FROM`
+  sessionName,             /// after `FROM`
+  busSeparator,            /// after `<session>`; `.`
+  busName,                 /// after `<session>.`
+  whereOrEnd,              /// after the bus; `WHERE` or end of query
+  expression,              /// start of a WHERE expression
+  binaryOperator,          /// after a value; comparison / `AND` / `OR` / `BETWEEN` / `IN` / `NOT`
+  value,                   /// after a comparison operator
+  notContinuation,         /// after `NOT` in binary-op position; `BETWEEN` / `IN` / an expression
+  betweenLowerBound,       /// after `BETWEEN`
+  betweenAnd,              /// after `BETWEEN <value>`; structural `AND`
+  betweenUpperBound,       /// after `BETWEEN <value> AND`
+  inOpenParen,             /// after `IN` / `NOT IN`; `(`
+  inListValue,             /// inside `IN (...)`; a value
+  inListSeparatorOrClose,  /// after a value in `IN (...)`; `,` or `)`
+  none,                    /// nothing useful to hint
+};
+
+/// Guidance for what the cursor should produce next. `hint` is a default static message
+/// keyed off `shape`; callers wanting localization or custom phrasing can ignore it and
+/// derive their own from `shape`.
+struct Guidance
+{
+  GuidanceShape    shape = GuidanceShape::none;
+  std::string_view hint = {};
+};
+
+/// Classify the cursor position in `text` and return a single-shot grammar hint.
+///
+/// `cursor` is a byte offset in [0, text.size()]. Values past the end are clamped. The
+/// function tokenizes tolerantly and walks the same positional FSM as `complete()`, but
+/// consults neither a type registry nor a bus lookup; guidance is pure grammar. For
+/// richer class-aware hints (e.g. "property of Aircraft") consumers should pair this
+/// with `complete()` or render the shape differently.
+[[nodiscard]] Guidance guideAt(std::string_view text, std::size_t cursor) noexcept;
+
+/// @}
+
+}  // namespace sen::lang::query
+
+#endif  // SEN_CORE_LANG_QUERY_GUIDE_H
