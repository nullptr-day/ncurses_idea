+// === fsm.h ===========================================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#ifndef SEN_CORE_LANG_QUERY_FSM_H
+#define SEN_CORE_LANG_QUERY_FSM_H
+
+// sen
+#include "sen/core/lang/code_location.h"
+#include "sen/core/lang/stl_token.h"
+#include "sen/core/meta/class_type.h"
+#include "sen/core/meta/property.h"
+
+// std
+#include <cstddef>
+#include <memory>
+#include <string>
+#include <string_view>
+#include <vector>
+
+/// Internal positional-FSM shared by `complete()` and `guideAt()`. Neither the types nor
+/// the functions in this header are part of the public API.
+
+namespace sen::lang::query::detail
+{
+
+/// Re-scan of the source with byte-accurate spans. Keeps the raw `StlTokenType` so the FSM
+/// can distinguish `keywordSelect` from `keywordFrom` without re-parsing lexemes. Comments
+/// and EOF are dropped here; the FSM never needs them.
+struct FsmToken
+{
+  StlTokenType type = StlTokenType::endOfFile;
+  TextSpan     span = {};
+  std::string  lexeme = {};
+};
+
+[[nodiscard]] std::vector<FsmToken> scan(std::string_view text);
+
+/// Locate the token being edited, if any. Returns an index into `tokens` or `tokens.size()`
+/// when the cursor is between tokens (user is starting a new word).
+[[nodiscard]] std::size_t findCurrentToken(const std::vector<FsmToken>& tokens, std::size_t cursor) noexcept;
+
+/// Count tokens whose span ends at or before `cursor`: tokens the cursor has already
+/// passed and that should be replayed through the FSM. Used to pick the walk length
+/// when no token is being edited. Assumes `tokens` is in source order.
+[[nodiscard]] std::size_t countCommittedTokens(const std::vector<FsmToken>& tokens, std::size_t cursor) noexcept;
+
+/// Grammar slots the cursor can be in. Each slot drives which completion kinds and
+/// guidance shapes we emit.
+enum class Slot
+{
+  selectKeyword,     /// start of query; want `SELECT`
+  classPath,         /// after `SELECT` or a `.` in the class path
+  classPathTail,     /// after a class-name identifier; want `.` or `FROM`
+  fromKeyword,       /// after `SELECT *`; want `FROM`
+  sessionName,       /// after `FROM`
+  busDot,            /// after `<session>`; want `.`
+  busName,           /// after `<session>.`
+  whereOrEnd,        /// after `<session>.<bus>`; want `WHERE` or end
+  whereExpr,         /// start of an expression (fresh, after AND/OR, after `(`, after NOT)
+  binaryOp,          /// after a "value" in an expression
+  literal,           /// after a comparison op; want a value (typed if we know the LHS)
+  afterNotInExpr,    /// saw `NOT` in binaryOp slot; expect `BETWEEN` / `IN` / expression
+  betweenFirst,      /// after `BETWEEN`; want the min value
+  betweenAnd,        /// after `BETWEEN <lit>`; want structural `AND`
+  betweenSecond,     /// after `BETWEEN <lit> AND`; want the max value
+  inOpenParen,       /// after `IN` / `NOT IN`; want `(`
+  inListElem,        /// inside `IN (...)`; want a value
+  inListSepOrClose,  /// after a value in `IN (...)`; want `,` or `)`
+  done,              /// no useful suggestions
+};
+
+/// Pair of (slot, lhsProperty). The property is set while transitioning from binaryOp
+/// into literal / betweenFirst / inListElem when we can tie the LHS to a known class
+/// property, so typed-value completion has something to consult.
+struct FsmState
+{
+  Slot                            slot = Slot::selectKeyword;
+  std::shared_ptr<const Property> lhsProperty = nullptr;
+  std::string                     lastIdentifier = {};
+  std::string                     sessionName = {};
+};
+
+/// Advance the FSM by one token. `cls` may be null; when null the class-aware property
+/// binding is skipped (useful for guidance, which doesn't care about LHS identity).
+void step(FsmState& s, const FsmToken& t, const ClassType* cls);
+
+}  // namespace sen::lang::query::detail
+
+#endif  // SEN_CORE_LANG_QUERY_FSM_H
