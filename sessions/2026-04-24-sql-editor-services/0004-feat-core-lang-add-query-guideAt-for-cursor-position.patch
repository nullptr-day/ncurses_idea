+// === guide_test.cpp ==================================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#include "sen/core/lang/query/guide.h"
+
+// gtest
+#include <gtest/gtest.h>
+
+using sen::lang::query::Guidance;
+using sen::lang::query::guideAt;
+using sen::lang::query::GuidanceShape;
+
+namespace
+{
+
+Guidance at(const std::string& text) { return guideAt(text, text.size()); }
+
+Guidance at(const std::string& text, std::size_t cursor) { return guideAt(text, cursor); }
+
+TEST(QueryGuide, emptyInputExpectsSelect)
+{
+  const auto g = at("");
+  EXPECT_EQ(g.shape, GuidanceShape::selectKeyword);
+  EXPECT_FALSE(g.hint.empty());
+}
+
+TEST(QueryGuide, afterSelectExpectsClassName)
+{
+  const auto g = at("SELECT ");
+  EXPECT_EQ(g.shape, GuidanceShape::className);
+}
+
+TEST(QueryGuide, midClassNameStillExpectsClassName)
+{
+  const auto g = at("SELECT Air");
+  EXPECT_EQ(g.shape, GuidanceShape::className);
+}
+
+TEST(QueryGuide, afterClassIdentExpectsFrom)
+{
+  const auto g = at("SELECT Aircraft ");
+  EXPECT_EQ(g.shape, GuidanceShape::classPathContinuation);
+  EXPECT_EQ(g.hint, "`FROM`");
+}
+
+TEST(QueryGuide, afterClassDotExpectsClassName)
+{
+  const auto g = at("SELECT demo.");
+  EXPECT_EQ(g.shape, GuidanceShape::className);
+}
+
+TEST(QueryGuide, afterStarExpectsFrom)
+{
+  const auto g = at("SELECT * ");
+  EXPECT_EQ(g.shape, GuidanceShape::fromKeyword);
+}
+
+TEST(QueryGuide, afterFromExpectsSession)
+{
+  const auto g = at("SELECT Aircraft FROM ");
+  EXPECT_EQ(g.shape, GuidanceShape::sessionName);
+}
+
+TEST(QueryGuide, afterSessionExpectsDot)
+{
+  const auto g = at("SELECT Aircraft FROM sim ");
+  EXPECT_EQ(g.shape, GuidanceShape::busSeparator);
+}
+
+TEST(QueryGuide, afterSessionDotExpectsBus)
+{
+  const auto g = at("SELECT Aircraft FROM sim.");
+  EXPECT_EQ(g.shape, GuidanceShape::busName);
+}
+
+TEST(QueryGuide, afterBusExpectsWhereOrEnd)
+{
+  const auto g = at("SELECT Aircraft FROM sim.env ");
+  EXPECT_EQ(g.shape, GuidanceShape::whereOrEnd);
+}
+
+TEST(QueryGuide, afterWhereExpectsExpression)
+{
+  const auto g = at("SELECT Aircraft FROM sim.env WHERE ");
+  EXPECT_EQ(g.shape, GuidanceShape::expression);
+}
+
+TEST(QueryGuide, afterValueExpectsBinaryOperator)
+{
+  const auto g = at("SELECT Aircraft FROM sim.env WHERE altitude ");
+  EXPECT_EQ(g.shape, GuidanceShape::binaryOperator);
+}
+
+TEST(QueryGuide, afterCompareExpectsValue)
+{
+  const auto g = at("SELECT Aircraft FROM sim.env WHERE altitude > ");
+  EXPECT_EQ(g.shape, GuidanceShape::value);
+}
+
+TEST(QueryGuide, afterNotInBinaryOpExpectsBetweenOrIn)
+{
+  const auto g = at("SELECT Aircraft FROM sim.env WHERE altitude NOT ");
+  EXPECT_EQ(g.shape, GuidanceShape::notContinuation);
+}
+
+TEST(QueryGuide, afterBetweenExpectsLowerBound)
+{
+  const auto g = at("SELECT Aircraft FROM sim.env WHERE altitude BETWEEN ");
+  EXPECT_EQ(g.shape, GuidanceShape::betweenLowerBound);
+}
+
+TEST(QueryGuide, afterBetweenLowerExpectsAnd)
+{
+  const auto g = at("SELECT Aircraft FROM sim.env WHERE altitude BETWEEN 10 ");
+  EXPECT_EQ(g.shape, GuidanceShape::betweenAnd);
+}
+
+TEST(QueryGuide, afterBetweenAndExpectsUpperBound)
+{
+  const auto g = at("SELECT Aircraft FROM sim.env WHERE altitude BETWEEN 10 AND ");
+  EXPECT_EQ(g.shape, GuidanceShape::betweenUpperBound);
+}
+
+TEST(QueryGuide, afterInExpectsOpenParen)
+{
+  const auto g = at("SELECT Aircraft FROM sim.env WHERE force IN ");
+  EXPECT_EQ(g.shape, GuidanceShape::inOpenParen);
+}
+
+TEST(QueryGuide, insideInListExpectsValue)
+{
+  const auto g = at("SELECT Aircraft FROM sim.env WHERE force IN (");
+  EXPECT_EQ(g.shape, GuidanceShape::inListValue);
+}
+
+TEST(QueryGuide, afterInListValueExpectsSeparatorOrClose)
+{
+  const auto g = at("SELECT Aircraft FROM sim.env WHERE force IN (\"friendly\" ");
+  EXPECT_EQ(g.shape, GuidanceShape::inListSeparatorOrClose);
+}
+
+TEST(QueryGuide, cursorClampedBeyondEnd)
+{
+  const std::string text = "SELECT ";
+  const auto        g = at(text, text.size() + 100U);
+  EXPECT_EQ(g.shape, GuidanceShape::className);
+}
+
+TEST(QueryGuide, cursorBeforeSelectReportsSelectKeyword)
+{
+  const auto g = at("SELECT Aircraft FROM sim.env", 0U);
+  EXPECT_EQ(g.shape, GuidanceShape::selectKeyword);
+}
+
+TEST(QueryGuide, hintNonEmptyForNonDoneShapes)
+{
+  const auto g = at("SELECT Aircraft FROM sim.env WHERE altitude > ");
+  EXPECT_EQ(g.shape, GuidanceShape::value);
+  EXPECT_FALSE(g.hint.empty());
+}
+
+}  // namespace
