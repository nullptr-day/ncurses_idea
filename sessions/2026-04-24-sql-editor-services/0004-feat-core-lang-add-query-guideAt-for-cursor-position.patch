+// === guide.cpp =======================================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#include "sen/core/lang/query/guide.h"
+
+// sen
+#include "fsm.h"
+
+// std
+#include <cstddef>
+
+namespace sen::lang::query
+{
+
+namespace
+{
+
+using detail::countCommittedTokens;
+using detail::findCurrentToken;
+using detail::FsmState;
+using detail::scan;
+using detail::Slot;
+using detail::step;
+
+struct ShapeHint
+{
+  GuidanceShape    shape;
+  std::string_view hint;
+};
+
+[[nodiscard]] ShapeHint shapeForSlot(Slot slot) noexcept
+{
+  // Hints are shown inline as ghost text while the user is mid-query. They read as a label
+  // of what comes next ("`SELECT`", "a class name"), never as a complaint: the user has
+  // not "failed" to type anything yet.
+  switch (slot)
+  {
+    case Slot::selectKeyword:
+      return {GuidanceShape::selectKeyword, "`SELECT`"};
+    case Slot::classPath:
+      return {GuidanceShape::className, "a class name"};
+    case Slot::classPathTail:
+      return {GuidanceShape::classPathContinuation, "`FROM`"};
+    case Slot::fromKeyword:
+      return {GuidanceShape::fromKeyword, "`FROM`"};
+    case Slot::sessionName:
+      return {GuidanceShape::sessionName, "a session name"};
+    case Slot::busDot:
+      return {GuidanceShape::busSeparator, "`.`"};
+    case Slot::busName:
+      return {GuidanceShape::busName, "a bus name"};
+    case Slot::whereOrEnd:
+      return {GuidanceShape::whereOrEnd, "`WHERE` or end of query"};
+    case Slot::whereExpr:
+      return {GuidanceShape::expression, "a property, value, or sub-expression"};
+    case Slot::binaryOp:
+      return {GuidanceShape::binaryOperator,
+              "a comparison operator, `AND`, `OR`, `BETWEEN`, `IN`, or `NOT`"};
+    case Slot::literal:
+      return {GuidanceShape::value, "a value"};
+    case Slot::afterNotInExpr:
+      return {GuidanceShape::notContinuation, "`BETWEEN`, `IN`, or an expression"};
+    case Slot::betweenFirst:
+      return {GuidanceShape::betweenLowerBound, "a lower bound"};
+    case Slot::betweenAnd:
+      return {GuidanceShape::betweenAnd, "`AND`"};
+    case Slot::betweenSecond:
+      return {GuidanceShape::betweenUpperBound, "an upper bound"};
+    case Slot::inOpenParen:
+      return {GuidanceShape::inOpenParen, "`(`"};
+    case Slot::inListElem:
+      return {GuidanceShape::inListValue, "a value"};
+    case Slot::inListSepOrClose:
+      return {GuidanceShape::inListSeparatorOrClose, "`,` or `)`"};
+    case Slot::done:
+      return {GuidanceShape::none, {}};
+  }
+  return {GuidanceShape::none, {}};
+}
+
+}  // namespace
+
+Guidance guideAt(std::string_view text, std::size_t cursor) noexcept
+{
+  if (cursor > text.size())
+  {
+    cursor = text.size();
+  }
+
+  const auto tokens = scan(text);
+  const auto currentIdx = findCurrentToken(tokens, cursor);
+
+  // Walk tokens strictly before the current token (or the tokens the cursor has already
+  // passed when it sits between tokens). The slot at the end of the walk is the slot the
+  // cursor points at.
+  FsmState          state;
+  const std::size_t stopAt =
+    (currentIdx < tokens.size()) ? currentIdx : countCommittedTokens(tokens, cursor);
+  for (std::size_t i = 0U; i < stopAt; ++i)
+  {
+    step(state, tokens[i], /*cls=*/nullptr);
+  }
+
+  const auto sh = shapeForSlot(state.slot);
+  return Guidance {sh.shape, sh.hint};
+}
+
+}  // namespace sen::lang::query
