   const auto b = pop();
   const auto a = pop();
-  push(extract<bool>(a) && extract<bool>(b));
+  push(valueAsBool(a) && valueAsBool(b));
 }
 
 void VM::doOr()
 {
   const auto b = pop();
   const auto a = pop();
-  push(extract<bool>(a) || extract<bool>(b));
+  push(valueAsBool(a) || valueAsBool(b));
 }
 
