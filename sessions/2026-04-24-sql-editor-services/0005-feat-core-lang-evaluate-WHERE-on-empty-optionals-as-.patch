+namespace
+{
+
+/// Coerce a `Value` to `bool`, treating `std::monostate` (empty optional) as `false`.
+[[nodiscard]] inline bool valueAsBool(const Value& value)
+{
+  return holds<std::monostate>(value) ? false : extract<bool>(value);
+}
+
+}  // namespace
