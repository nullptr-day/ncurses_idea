+/// @test
+/// Checks that `std::monostate` in the environment (our "empty optional" marker) makes the
+/// WHERE clause evaluate to `false` without throwing, regardless of which side of the
+/// comparison or boolean operator it lands on.
+/// @requirements(SEN-363)
+TEST(Compiler, emptyOptionalYieldsFalse)
+{
+  // `count > 10` with an empty optional evaluates to false.
+  {
+    std::string program = R"(SELECT foo.Bar FROM s.b WHERE count > 10)";
+
+    VM vm;
+    auto result = vm.compile(vm.parse(program));
+    EXPECT_TRUE(result.isOk());
+    auto chunk = std::move(result).getValue();
+
+    std::vector<sen::lang::ValueGetter> environment = {[]() -> sen::lang::Value { return std::monostate {}; }};
+    auto codeResult = vm.interpret(chunk, environment);
+
+    EXPECT_TRUE(codeResult.isOk());
+    EXPECT_TRUE(std::holds_alternative<bool>(codeResult.getValue()));
+    EXPECT_FALSE(std::get<bool>(codeResult.getValue()));
+  }
+
+  // Empty AND anything -> false (short-circuits on the empty).
+  {
+    std::string program = R"(SELECT foo.Bar FROM s.b WHERE count > 0 AND other = "x")";
+
+    VM vm;
+    auto result = vm.compile(vm.parse(program));
+    EXPECT_TRUE(result.isOk());
+    auto chunk = std::move(result).getValue();
+
+    std::vector<sen::lang::ValueGetter> environment = {
+      []() -> sen::lang::Value { return std::monostate {}; },
+      []() -> sen::lang::Value { return std::string("x"); },
+    };
+    auto codeResult = vm.interpret(chunk, environment);
+
+    EXPECT_TRUE(codeResult.isOk());
+    EXPECT_TRUE(std::holds_alternative<bool>(codeResult.getValue()));
+    EXPECT_FALSE(std::get<bool>(codeResult.getValue()));
+  }
+
+  // Empty on the RHS of a comparison is also false.
+  {
+    std::string program = R"(SELECT foo.Bar FROM s.b WHERE 10 < count)";
+
+    VM vm;
+    auto result = vm.compile(vm.parse(program));
+    EXPECT_TRUE(result.isOk());
+    auto chunk = std::move(result).getValue();
+
+    std::vector<sen::lang::ValueGetter> environment = {[]() -> sen::lang::Value { return std::monostate {}; }};
+    auto codeResult = vm.interpret(chunk, environment);
+
+    EXPECT_TRUE(codeResult.isOk());
+    EXPECT_TRUE(std::holds_alternative<bool>(codeResult.getValue()));
+    EXPECT_FALSE(std::get<bool>(codeResult.getValue()));
+  }
+}
