diff --git a/libs/core/test/lang/query/tokenize_test.cpp b/libs/core/test/lang/query/tokenize_test.cpp
new file mode 100644
index 0000000..bec9e23
--- /dev/null
+++ b/libs/core/test/lang/query/tokenize_test.cpp
@@ -0,0 +1,203 @@
+// === tokenize_test.cpp ===============================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#include "sen/core/lang/query/tokenize.h"
+
+// gtest
+#include <gtest/gtest.h>
+
+// std
+#include <string>
+#include <string_view>
+
+using sen::lang::DiagnosticCode;
+using sen::lang::Severity;
+using sen::lang::query::Token;
+using sen::lang::query::TokenizeResult;
+using sen::lang::query::TokenKind;
+using sen::lang::query::tokenize;
+
+namespace
+{
+
+[[nodiscard]] std::string sliceOf(std::string_view source, const Token& tok)
+{
+  return std::string {source.substr(tok.span.begin, tok.span.end - tok.span.begin)};
+}
+
+}  // namespace
+
+/// @test
+/// Every non-EOF token's span, taken from the source, equals the token's lexeme.
+TEST(QueryTokenize, spansCoverLexemes)
+{
+  const std::string_view source = "SELECT a.b FROM se.env WHERE a > 1";
+  const TokenizeResult   r = tokenize(source);
+
+  ASSERT_FALSE(r.tokens.empty());
+  EXPECT_EQ(r.tokens.back().kind, TokenKind::endOfFile);
+
+  for (const auto& tok: r.tokens)
+  {
+    if (tok.kind == TokenKind::endOfFile)
+    {
+      EXPECT_EQ(tok.span.begin, source.size());
+      EXPECT_EQ(tok.span.end, source.size());
+      continue;
+    }
+    EXPECT_LE(tok.span.begin, tok.span.end);
+    EXPECT_LE(tok.span.end, source.size());
+    EXPECT_EQ(sliceOf(source, tok), tok.lexeme);
+  }
+}
+
+/// @test
+/// Token kinds cover keyword, identifier, operator, punctuation, number in a typical query.
+TEST(QueryTokenize, kindCoverage)
+{
+  const std::string_view source = "SELECT altitude FROM s.b WHERE altitude > 1000";
+  const TokenizeResult   r = tokenize(source);
+
+  ASSERT_TRUE(r.diagnostics.empty());
+
+  bool sawKeyword = false;
+  bool sawIdent = false;
+  bool sawOp = false;
+  bool sawPunct = false;
+  bool sawNumber = false;
+  for (const auto& tok: r.tokens)
+  {
+    sawKeyword = sawKeyword || tok.kind == TokenKind::keyword;
+    sawIdent = sawIdent || tok.kind == TokenKind::identifier;
+    sawOp = sawOp || tok.kind == TokenKind::operator_;
+    sawPunct = sawPunct || tok.kind == TokenKind::punctuation;
+    sawNumber = sawNumber || tok.kind == TokenKind::number;
+  }
+  EXPECT_TRUE(sawKeyword);
+  EXPECT_TRUE(sawIdent);
+  EXPECT_TRUE(sawOp);
+  EXPECT_TRUE(sawPunct);
+  EXPECT_TRUE(sawNumber);
+}
+
+/// @test
+/// A double-quoted string literal is surfaced with quotes included in the span/lexeme.
+TEST(QueryTokenize, stringLexemeIncludesQuotes)
+{
+  const std::string_view source = "SELECT a FROM s.b WHERE n = \"hello\"";
+  const TokenizeResult   r = tokenize(source);
+
+  ASSERT_TRUE(r.diagnostics.empty());
+
+  bool found = false;
+  for (const auto& tok: r.tokens)
+  {
+    if (tok.kind == TokenKind::string)
+    {
+      EXPECT_EQ(tok.lexeme, "\"hello\"");
+      EXPECT_EQ(sliceOf(source, tok), "\"hello\"");
+      found = true;
+    }
+  }
+  EXPECT_TRUE(found);
+}
+
+/// @test
+/// Unterminated strings surface as error tokens and a `scanUnterminatedString` diagnostic.
+TEST(QueryTokenize, unterminatedStringProducesErrorTokenAndDiagnostic)
+{
+  const std::string_view source = "SELECT a FROM s.b WHERE n = \"oops";
+  const TokenizeResult   r = tokenize(source);
+
+  ASSERT_EQ(r.diagnostics.size(), 1U);
+  EXPECT_EQ(r.diagnostics.front().code, DiagnosticCode::scanUnterminatedString);
+  EXPECT_EQ(r.diagnostics.front().severity, Severity::error);
+
+  bool sawStringErrorToken = false;
+  for (const auto& tok: r.tokens)
+  {
+    if (tok.kind == TokenKind::string && tok.span.end == source.size())
+    {
+      sawStringErrorToken = true;
+    }
+  }
+  EXPECT_TRUE(sawStringErrorToken);
+}
+
+/// @test
+/// Invalid characters surface as error tokens and a `scanInvalidChar` diagnostic.
+TEST(QueryTokenize, invalidCharProducesErrorTokenAndDiagnostic)
+{
+  const std::string_view source = "SELECT a FROM s.b WHERE a # 1";
+  const TokenizeResult   r = tokenize(source);
+
+  ASSERT_FALSE(r.diagnostics.empty());
+  bool sawInvalid = false;
+  for (const auto& d: r.diagnostics)
+  {
+    if (d.code == DiagnosticCode::scanInvalidChar)
+    {
+      sawInvalid = true;
+    }
+  }
+  EXPECT_TRUE(sawInvalid);
+
+  bool sawErrorToken = false;
+  for (const auto& tok: r.tokens)
+  {
+    if (tok.kind == TokenKind::error && tok.lexeme == "#")
+    {
+      sawErrorToken = true;
+    }
+  }
+  EXPECT_TRUE(sawErrorToken);
+}
+
+/// @test
+/// Empty input produces a single endOfFile token at offset 0 and no diagnostics.
+TEST(QueryTokenize, emptyInput)
+{
+  const TokenizeResult r = tokenize("");
+
+  ASSERT_EQ(r.tokens.size(), 1U);
+  EXPECT_EQ(r.tokens.front().kind, TokenKind::endOfFile);
+  EXPECT_EQ(r.tokens.front().span.begin, 0U);
+  EXPECT_EQ(r.tokens.front().span.end, 0U);
+  EXPECT_TRUE(r.diagnostics.empty());
+}
+
+/// @test
+/// Whitespace-only input produces a single endOfFile token and no diagnostics.
+TEST(QueryTokenize, whitespaceOnly)
+{
+  const std::string_view source = "   \t\n  ";
+  const TokenizeResult   r = tokenize(source);
+
+  ASSERT_EQ(r.tokens.size(), 1U);
+  EXPECT_EQ(r.tokens.front().kind, TokenKind::endOfFile);
+  EXPECT_EQ(r.tokens.front().span.begin, source.size());
+  EXPECT_TRUE(r.diagnostics.empty());
+}
+
+/// @test
+/// Line comments are surfaced as TokenKind::comment with quotes in the lexeme.
+TEST(QueryTokenize, commentsSurfaceAsCommentKind)
+{
+  const std::string_view source = "SELECT a // trailing comment";
+  const TokenizeResult   r = tokenize(source);
+
+  ASSERT_TRUE(r.diagnostics.empty());
+  bool sawComment = false;
+  for (const auto& tok: r.tokens)
+  {
+    if (tok.kind == TokenKind::comment)
+    {
+      sawComment = true;
+    }
+  }
+  EXPECT_TRUE(sawComment);
+}
