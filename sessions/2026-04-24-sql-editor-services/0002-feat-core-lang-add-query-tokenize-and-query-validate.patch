@@ -0,0 +1,215 @@
+// === validate_test.cpp ===============================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#include "sen/core/lang/query/validate.h"
+
+// sen
+#include "sen/core/lang/query/bus_lookup.h"
+#include "sen/core/meta/class_type.h"
+#include "sen/core/meta/native_types.h"
+#include "sen/core/meta/property.h"
+#include "sen/core/meta/type_registry.h"
+
+// gtest
+#include <gtest/gtest.h>
+
+// std
+#include <string>
+#include <vector>
+
+using sen::ClassSpec;
+using sen::ClassType;
+using sen::CustomTypeRegistry;
+using sen::PropertyCategory;
+using sen::PropertySpec;
+using sen::TransportMode;
+using sen::lang::DiagnosticCode;
+using sen::lang::DiagnosticList;
+using sen::lang::Severity;
+using sen::lang::query::BusLookup;
+using sen::lang::query::validate;
+using sen::lang::query::ValidateResult;
+
+namespace
+{
+
+// Shared class fixture used across the validate tests. Properties are chosen to exercise
+// every literal-type kind: string, integral, bool.
+ClassSpec aircraftSpec()
+{
+  std::vector<PropertySpec> properties;
+  properties.emplace_back("callsign",
+                          "",
+                          sen::StringType::get(),
+                          PropertyCategory::dynamicRW,
+                          TransportMode::multicast,
+                          false,
+                          std::vector<std::string> {});
+  properties.emplace_back("altitude",
+                          "",
+                          sen::UInt32Type::get(),
+                          PropertyCategory::dynamicRW,
+                          TransportMode::multicast,
+                          false,
+                          std::vector<std::string> {});
+  properties.emplace_back("active",
+                          "",
+                          sen::BoolType::get(),
+                          PropertyCategory::dynamicRW,
+                          TransportMode::multicast,
+                          false,
+                          std::vector<std::string> {});
+  return ClassSpec {"Aircraft", "demo.Aircraft", "", std::move(properties), {}, {}, {}, {}, false, false, {}, {}};
+}
+
+// Registers `demo.Aircraft` and pins the class handle in a static so the registry's
+// weak references stay resolvable across test invocations.
+const CustomTypeRegistry& registryWithAircraft()
+{
+  static const auto kAircraft = ClassType::make(aircraftSpec());
+  static CustomTypeRegistry registry;
+  static const bool seeded = [&]()
+  {
+    registry.add(kAircraft);
+    return true;
+  }();
+  (void)seeded;
+  return registry;
+}
+
+BusLookup makeBusLookup(std::vector<std::string> sessions, std::vector<std::string> buses)
+{
+  BusLookup lookup;
+  lookup.sessions = [sessions = std::move(sessions)]() { return sessions; };
+  lookup.buses = [buses = std::move(buses)](std::string_view) { return buses; };
+  return lookup;
+}
+
+bool hasDiagnosticWith(const DiagnosticList& diags, DiagnosticCode code, Severity severity)
+{
+  for (const auto& d: diags)
+  {
+    if (d.code == code && d.severity == severity)
+    {
+      return true;
+    }
+  }
+  return false;
+}
+
+}  // namespace
+
+/// @test
+/// A fully known query (class + property + session + bus) produces no diagnostics.
+TEST(QueryValidate, cleanQueryProducesNoDiagnostics)
+{
+  const auto& registry = registryWithAircraft();
+  const auto  buses = makeBusLookup({"s"}, {"b"});
+
+  const ValidateResult r = validate("SELECT demo.Aircraft FROM s.b WHERE altitude > 100", registry, buses);
+
+  EXPECT_TRUE(r.diagnostics.empty()) << "got " << r.diagnostics.size() << " unexpected diagnostics";
+}
+
+/// @test
+/// An unknown class produces a single info diagnostic with code `validateUnknownClass`.
+TEST(QueryValidate, unknownClassIsInfo)
+{
+  const auto& registry = registryWithAircraft();
+  const auto  buses = makeBusLookup({"s"}, {"b"});
+
+  const ValidateResult r = validate("SELECT demo.Missing FROM s.b WHERE 1 = 1", registry, buses);
+
+  EXPECT_TRUE(hasDiagnosticWith(r.diagnostics, DiagnosticCode::validateUnknownClass, Severity::info));
+}
+
+/// @test
+/// A known class with an unknown property produces an error with code `validateUnknownProperty`.
+TEST(QueryValidate, unknownPropertyOnKnownClassIsError)
+{
+  const auto& registry = registryWithAircraft();
+  const auto  buses = makeBusLookup({"s"}, {"b"});
+
+  const ValidateResult r = validate("SELECT demo.Aircraft FROM s.b WHERE speed > 100", registry, buses);
+
+  EXPECT_TRUE(hasDiagnosticWith(r.diagnostics, DiagnosticCode::validateUnknownProperty, Severity::error));
+}
+
+/// @test
+/// A known class, known property, mismatching literal type yields `validateTypeMismatch`.
+TEST(QueryValidate, literalTypeMismatchIsError)
+{
+  const auto& registry = registryWithAircraft();
+  const auto  buses = makeBusLookup({"s"}, {"b"});
+
+  // `altitude` is UInt32; comparing with a string literal is a mismatch.
+  const ValidateResult r = validate("SELECT demo.Aircraft FROM s.b WHERE altitude = \"hi\"", registry, buses);
+
+  EXPECT_TRUE(hasDiagnosticWith(r.diagnostics, DiagnosticCode::validateTypeMismatch, Severity::error));
+}
+
+/// @test
+/// A string literal matches a StringType property (no type-mismatch).
+TEST(QueryValidate, stringLiteralMatchesStringProperty)
+{
+  const auto& registry = registryWithAircraft();
+  const auto  buses = makeBusLookup({"s"}, {"b"});
+
+  const ValidateResult r = validate("SELECT demo.Aircraft FROM s.b WHERE callsign = \"AFR123\"", registry, buses);
+
+  EXPECT_FALSE(hasDiagnosticWith(r.diagnostics, DiagnosticCode::validateTypeMismatch, Severity::error));
+}
+
+/// @test
+/// An unknown session produces a single info diagnostic with code `validateUnknownSession`.
+TEST(QueryValidate, unknownSessionIsInfo)
+{
+  const auto& registry = registryWithAircraft();
+  const auto  buses = makeBusLookup({"other"}, {"b"});
+
+  const ValidateResult r = validate("SELECT demo.Aircraft FROM missing.b WHERE altitude > 0", registry, buses);
+
+  EXPECT_TRUE(hasDiagnosticWith(r.diagnostics, DiagnosticCode::validateUnknownSession, Severity::info));
+}
+
+/// @test
+/// A known session with an unknown bus produces `validateUnknownBus` at info.
+TEST(QueryValidate, knownSessionUnknownBusIsInfo)
+{
+  const auto& registry = registryWithAircraft();
+  const auto  buses = makeBusLookup({"s"}, {"only-this-one"});
+
+  const ValidateResult r = validate("SELECT demo.Aircraft FROM s.nope WHERE altitude > 0", registry, buses);
+
+  EXPECT_TRUE(hasDiagnosticWith(r.diagnostics, DiagnosticCode::validateUnknownBus, Severity::info));
+  EXPECT_FALSE(hasDiagnosticWith(r.diagnostics, DiagnosticCode::validateUnknownSession, Severity::info));
+}
+
+/// @test
+/// Syntax errors forward through the validate call with parser codes.
+TEST(QueryValidate, parserDiagnosticsForward)
+{
+  const auto& registry = registryWithAircraft();
+  const auto  buses = makeBusLookup({"s"}, {"b"});
+
+  const ValidateResult r = validate("SELECT FROM s.b WHERE altitude > 0", registry, buses);
+
+  EXPECT_TRUE(hasDiagnosticWith(r.diagnostics, DiagnosticCode::parseSyntax, Severity::error));
+}
+
+/// @test
+/// A known class / property / session / bus with a real literal on an integral property
+/// currently surfaces as a type mismatch (reals don't downcast to integers in this pass).
+TEST(QueryValidate, realLiteralOnIntegralPropertyIsMismatch)
+{
+  const auto& registry = registryWithAircraft();
+  const auto  buses = makeBusLookup({"s"}, {"b"});
+
+  const ValidateResult r = validate("SELECT demo.Aircraft FROM s.b WHERE altitude = 1.5", registry, buses);
+
+  EXPECT_TRUE(hasDiagnosticWith(r.diagnostics, DiagnosticCode::validateTypeMismatch, Severity::error));
+}
