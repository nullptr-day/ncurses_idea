+// === bus_lookup.h ====================================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#ifndef SEN_CORE_LANG_QUERY_BUS_LOOKUP_H
+#define SEN_CORE_LANG_QUERY_BUS_LOOKUP_H
+
+// std
+#include <functional>
+#include <string>
+#include <string_view>
+#include <vector>
+
+namespace sen::lang::query
+{
+
+/// \addtogroup lang
+/// @{
+
+/// Injection point for bus topology. Plain struct of `std::function` so the kernel side
+/// can satisfy it however it likes (direct kernel calls in prod, scripted lambdas in
+/// tests, cache-refreshed lookups in term). Scale is bounded in Sen deployments
+/// (~50 sessions, ~500 buses total), so linear enumeration of the returned vectors is
+/// fine; no `hasSession` / `hasBus` fast paths needed.
+struct BusLookup
+{
+  /// All sessions known right now. An empty vector means the caller has not discovered
+  /// any sessions yet (or has none); either way, any bus reference will be classified
+  /// as `validateUnknownSession`.
+  std::function<std::vector<std::string>()> sessions;
+
+  /// All buses in the given session. An empty vector means either the session is unknown
+  /// or it has no buses; the caller distinguishes by checking `sessions()` first.
+  std::function<std::vector<std::string>(std::string_view session)> buses;
+};
+
+/// @}
+
+}  // namespace sen::lang::query
+
+#endif  // SEN_CORE_LANG_QUERY_BUS_LOOKUP_H
