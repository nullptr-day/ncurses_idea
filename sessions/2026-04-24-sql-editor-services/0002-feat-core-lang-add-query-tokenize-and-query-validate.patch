+// === validate.h ======================================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#ifndef SEN_CORE_LANG_QUERY_VALIDATE_H
+#define SEN_CORE_LANG_QUERY_VALIDATE_H
+
+// sen
+#include "sen/core/lang/diagnostic.h"
+#include "sen/core/lang/query/bus_lookup.h"
+#include "sen/core/lang/stl_statement.h"
+
+// std
+#include <string_view>
+
+namespace sen
+{
+class CustomTypeRegistry;
+}
+
+namespace sen::lang::query
+{
+
+/// \addtogroup lang
+/// @{
+
+/// Outcome of a static check of a query string.
+///
+/// `diagnostics` contains one entry per problem surface (syntax, unknown class, unknown
+/// property on a known class, literal/property type mismatch, unknown session, unknown
+/// bus, ...). Severity mirrors the policy in the Stage 2 design:
+/// unknown-class / unknown-session / unknown-bus are `Severity::info` because they
+/// self-clear once the registry or the bus lookup catches up, and syntax /
+/// property-missing-on-known-class / literal-type-mismatch are `Severity::error`.
+///
+/// `ast` is whatever the tolerant parser managed to build. Even on a bad query it is
+/// populated with partial fragments (whatever the parser got through before it gave up),
+/// so downstream stages (`complete`, `guideAt`) can still reason over the pieces that
+/// were parsed.
+struct ValidateResult
+{
+  DiagnosticList diagnostics = {};
+  QueryStatement ast = {};
+};
+
+/// Full static check of a query string.
+///
+/// Drives the tolerant scanner + tolerant parser, then walks the partial AST against
+/// `types` (for the SELECTed class and its properties) and `buses` (for the FROM
+/// session.bus reference). The returned diagnostics are the concatenation of scanner
+/// diagnostics, parser diagnostics, and the validator's own semantic checks; no
+/// de-duplication is attempted (each stage owns its own codes).
+///
+/// Pure function. No caching: callers that need the 2-second class-handle recheck
+/// described in the Stage 2 design hold their own state.
+[[nodiscard]] ValidateResult validate(std::string_view           text,
+                                      const CustomTypeRegistry&  types,
+                                      const BusLookup&           buses);
+
+/// @}
+
+}  // namespace sen::lang::query
+
+#endif  // SEN_CORE_LANG_QUERY_VALIDATE_H
diff --git a/libs/core/src/lang/query/tokenize.cpp b/libs/core/src/lang/query/tokenize.cpp
new file mode 100644
index 0000000..2290611
--- /dev/null
+++ b/libs/core/src/lang/query/tokenize.cpp
@@ -0,0 +1,150 @@
+// === tokenize.cpp ====================================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#include "sen/core/lang/query/tokenize.h"
+
+// sen
+#include "sen/core/base/compiler_macros.h"
+#include "sen/core/lang/stl_scanner.h"
+#include "sen/core/lang/stl_token.h"
+
+namespace sen::lang::query
+{
+
+namespace
+{
+
+[[nodiscard]] bool isWhitespace(char c) noexcept { return c == ' ' || c == '\t' || c == '\n' || c == '\r'; }
+
+[[nodiscard]] TokenKind classify(StlTokenType type) noexcept
+{
+  switch (type)
+  {
+    case StlTokenType::leftParen:
+    case StlTokenType::rightParen:
+    case StlTokenType::comma:
+    case StlTokenType::dot:
+      return TokenKind::punctuation;
+
+    case StlTokenType::leftBrace:
+    case StlTokenType::rightBrace:
+    case StlTokenType::leftBracket:
+    case StlTokenType::rightBracket:
+    case StlTokenType::colon:
+    case StlTokenType::semicolon:
+    case StlTokenType::at:
+      return TokenKind::punctuation;
+
+    case StlTokenType::minus:
+    case StlTokenType::plus:
+    case StlTokenType::slash:
+    case StlTokenType::star:
+    case StlTokenType::bang:
+    case StlTokenType::bangEqual:
+    case StlTokenType::equal:
+    case StlTokenType::equalEqual:
+    case StlTokenType::greater:
+    case StlTokenType::greaterEqual:
+    case StlTokenType::less:
+    case StlTokenType::lessEqual:
+      return TokenKind::operator_;
+
+    case StlTokenType::identifier:
+      return TokenKind::identifier;
+
+    case StlTokenType::string:
+    case StlTokenType::partialString:
+      return TokenKind::string;
+
+    case StlTokenType::real:
+    case StlTokenType::integral:
+      return TokenKind::number;
+
+    case StlTokenType::keywordSelect:
+    case StlTokenType::keywordFrom:
+    case StlTokenType::keywordWhere:
+    case StlTokenType::keywordAnd:
+    case StlTokenType::keywordOr:
+    case StlTokenType::keywordNot:
+    case StlTokenType::keywordIn:
+    case StlTokenType::keywordBetween:
+    case StlTokenType::keywordTrue:
+    case StlTokenType::keywordFalse:
+      return TokenKind::keyword;
+
+    case StlTokenType::keywordAbstract:
+    case StlTokenType::keywordClass:
+    case StlTokenType::keywordInterface:
+    case StlTokenType::keywordExtends:
+    case StlTokenType::keywordImplements:
+    case StlTokenType::keywordStruct:
+    case StlTokenType::keywordVariant:
+    case StlTokenType::keywordFunction:
+    case StlTokenType::keywordEvent:
+    case StlTokenType::keywordVar:
+    case StlTokenType::keywordImport:
+    case StlTokenType::keywordOptional:
+    case StlTokenType::keywordPackage:
+    case StlTokenType::keywordEnum:
+    case StlTokenType::keywordSequence:
+    case StlTokenType::keywordArray:
+    case StlTokenType::keywordQuantity:
+    case StlTokenType::keywordAlias:
+      // STL-definition keywords are not part of the query language, but if one slips into
+      // query text we still surface it as a keyword: the parser will reject it, and
+      // treating it as an identifier would mis-color it.
+      return TokenKind::keyword;
+
+    case StlTokenType::comment:
+      return TokenKind::comment;
+
+    case StlTokenType::invalidChar:
+      return TokenKind::error;
+
+    case StlTokenType::endOfFile:
+      return TokenKind::endOfFile;
+  }
+  SEN_UNREACHABLE();
+}
+
+}  // namespace
+
+TokenizeResult tokenize(std::string_view text)
+{
+  // Own the text in a std::string because StlScanner's API needs a std::string reference.
+  const std::string source(text);
+  StlScanner       scanner(source, ScanMode::tolerant);
+  const auto&      rawTokens = scanner.scanTokens();
+
+  TokenizeResult result;
+  result.tokens.reserve(rawTokens.size());
+  result.diagnostics = scanner.diagnostics();
+
+  std::size_t cursor = 0U;
+  for (const auto& raw: rawTokens)
+  {
+    while (cursor < source.size() && isWhitespace(source[cursor]))
+    {
+      ++cursor;
+    }
+
+    const std::size_t end = raw.loc.offset;
+    const std::size_t begin = (cursor <= end) ? cursor : end;
+
+    Token tok;
+    tok.kind = classify(raw.type);
+    tok.span = TextSpan {begin, end};
+    tok.lexeme = (end > begin) ? source.substr(begin, end - begin) : std::string {};
+    result.tokens.push_back(std::move(tok));
+
+    cursor = end;
+  }
+
+  return result;
+}
+
+}  // namespace sen::lang::query
diff --git a/libs/core/src/lang/query/validate.cpp b/libs/core/src/lang/query/validate.cpp
new file mode 100644
index 0000000..4c24aef
--- /dev/null
+++ b/libs/core/src/lang/query/validate.cpp
@@ -0,0 +1,359 @@
+// === validate.cpp ====================================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#include "sen/core/lang/query/validate.h"
+
+// sen
+#include "sen/core/lang/stl_parser.h"
+#include "sen/core/lang/stl_scanner.h"
+#include "sen/core/meta/alias_type.h"
+#include "sen/core/meta/class_type.h"
+#include "sen/core/meta/native_types.h"
+#include "sen/core/meta/property.h"
+#include "sen/core/meta/type.h"
+#include "sen/core/meta/type_registry.h"
+
+// std
+#include <algorithm>
+#include <memory>
+#include <string>
+#include <utility>
+
+namespace sen::lang::query
+{
+
+namespace
+{
+
+[[nodiscard]] TextSpan tokenSpan(const StlToken& t) noexcept
+{
+  const std::size_t begin = (t.loc.offset >= t.lexeme.size()) ? (t.loc.offset - t.lexeme.size()) : 0U;
+  return TextSpan {begin, t.loc.offset};
+}
+
+/// Walks AliasType chains so that callers compare against the underlying type.
+[[nodiscard]] const Type* unwrapAliases(const Type* type) noexcept
+{
+  while (type != nullptr && type->isAliasType())
+  {
+    const auto* alias = type->asAliasType();
+    type = alias->getAliasedType().type();
+  }
+  return type;
+}
+
+/// Best-effort literal-vs-property-type match.
+///
+/// Returns `true` when we know the pair is compatible, `false` when we know it's a
+/// mismatch. We only flag clear mismatches: ambiguous cases (quantities, enums,
+/// variants, optionals, sequences, structs) return `true` to stay conservative. The
+/// design-doc policy is "nothing for we genuinely can't evaluate".
+[[nodiscard]] bool literalMatchesPropertyType(StlTokenType literal, const Type& propType) noexcept
+{
+  const Type* effective = unwrapAliases(&propType);
+  if (effective == nullptr)
+  {
+    return true;
+  }
+
+  switch (literal)
+  {
+    case StlTokenType::string:
+    case StlTokenType::partialString:
+      return effective->isStringType();
+
+    case StlTokenType::integral:
+      return effective->isNumericType();
+
+    case StlTokenType::real:
+      return effective->isRealType();
+
+    case StlTokenType::keywordTrue:
+    case StlTokenType::keywordFalse:
+      return effective->isBoolType();
+
+    default:
+      return true;
+  }
+}
+
+/// Friendly short tag for a literal, used in type-mismatch messages.
+[[nodiscard]] const char* literalKindName(StlTokenType literal) noexcept
+{
+  switch (literal)
+  {
+    case StlTokenType::string:
+    case StlTokenType::partialString:
+      return "string";
+    case StlTokenType::integral:
+      return "integer";
+    case StlTokenType::real:
+      return "real";
+    case StlTokenType::keywordTrue:
+    case StlTokenType::keywordFalse:
+      return "boolean";
+    default:
+      return "literal";
+  }
+}
+
+class WhereWalker
+{
+public:
+  WhereWalker(const ClassType& cls, DiagnosticList& out) noexcept: class_(cls), out_(out) {}
+
+  void walk(const std::shared_ptr<StlExpr>& expr)
+  {
+    if (expr == nullptr)
+    {
+      return;
+    }
+    std::visit(*this, expr->value);
+  }
+
+  void operator()(const std::monostate&) const noexcept {}
+
+  void operator()(const StlLiteralExpr&) const noexcept {}
+
+  void operator()(const StlVariableExpr& expr) { visitVariable(expr, nullptr); }
+
+  void operator()(const StlUnaryExpr& expr) { walk(expr.expr); }
+
+  void operator()(const StlGroupingExpr& expr) { walk(expr.expr); }
+
+  void operator()(const StlLogicalExpr& expr)
+  {
+    walk(expr.lhs);
+    walk(expr.rhs);
+  }
+
+  void operator()(const StlBinaryExpr& expr)
+  {
+    // For `<property> <op> <literal>` check the literal's type against the property's.
+    checkComparison(expr.lhs, expr.rhs);
+    checkComparison(expr.rhs, expr.lhs);
+
+    // Also walk sides generically so variable references on both sides get resolved.
+    walk(expr.lhs);
+    walk(expr.rhs);
+  }
+
+  void operator()(const StlBetweenExpr& expr)
+  {
+    checkComparison(expr.lhs, expr.min);
+    checkComparison(expr.lhs, expr.max);
+    walk(expr.lhs);
+    walk(expr.min);
+    walk(expr.max);
+  }
+
+  void operator()(const StlInExpr& expr)
+  {
+    for (const auto& elem: expr.set)
+    {
+      checkComparison(expr.lhs, elem);
+    }
+    walk(expr.lhs);
+    for (const auto& elem: expr.set)
+    {
+      walk(elem);
+    }
+  }
+
+private:
+  /// If `varSide` is a single-segment variable and `litSide` is a literal, flag the pair
+  /// when the literal's kind clearly doesn't match the property's type.
+  void checkComparison(const std::shared_ptr<StlExpr>& varSide, const std::shared_ptr<StlExpr>& litSide)
+  {
+    if (varSide == nullptr || litSide == nullptr)
+    {
+      return;
+    }
+    const auto* variable = std::get_if<StlVariableExpr>(&varSide->value);
+    const auto* literal = std::get_if<StlLiteralExpr>(&litSide->value);
+    if (variable == nullptr || literal == nullptr)
+    {
+      return;
+    }
+    const Property* prop = nullptr;
+    visitVariable(*variable, &prop);
+    if (prop == nullptr)
+    {
+      return;
+    }
+    const auto typeHandle = prop->getType();
+    if (typeHandle.type() == nullptr)
+    {
+      return;
+    }
+    if (literalMatchesPropertyType(literal->value.type, *typeHandle.type()))
+    {
+      return;
+    }
+    std::string msg;
+    msg.append("Property '");
+    msg.append(std::string {prop->getName()});
+    msg.append("' is of type '");
+    msg.append(std::string {typeHandle.type()->getName()});
+    msg.append("', cannot compare with ");
+    msg.append(literalKindName(literal->value.type));
+    msg.append(" literal");
+    out_.push_back(Diagnostic {litSide->span, Severity::error, DiagnosticCode::validateTypeMismatch, std::move(msg)});
+  }
+
+  /// Resolves a single-segment variable reference against the class. Multi-segment paths
+  /// (struct field access) are out of scope for Stage 2 commit 3 and are skipped. If
+  /// `propOut` is non-null, writes the resolved property pointer there (or leaves it
+  /// alone when unresolved / multi-segment).
+  void visitVariable(const StlVariableExpr& expr, const Property** propOut)
+  {
+    if (expr.path.size() != 1U)
+    {
+      return;
+    }
+    const auto& token = expr.path.front();
+    const Property* prop = class_.searchPropertyByName(token.lexeme);
+    if (prop == nullptr)
+    {
+      // Only emit the diagnostic once per variable node. When `propOut` is given, this is
+      // a "look up for type-match" call driven by `checkComparison` and the caller will
+      // walk the variable separately, producing the diagnostic from the other path. We
+      // only emit when called in the standalone `operator()(StlVariableExpr)` path (no
+      // `propOut`).
+      if (propOut == nullptr)
+      {
+        std::string msg;
+        msg.append("Property '");
+        msg.append(token.lexeme);
+        msg.append("' is not a property of class '");
+        msg.append(std::string {class_.getQualifiedName()});
+        msg.append("'");
+        out_.push_back(Diagnostic {tokenSpan(token),
+                                   Severity::error,
+                                   DiagnosticCode::validateUnknownProperty,
+                                   std::move(msg)});
+      }
+      return;
+    }
+    if (propOut != nullptr)
+    {
+      *propOut = prop;
+    }
+  }
+
+  const ClassType& class_;
+  DiagnosticList&  out_;
+};
+
+void validateBus(const BusNameStatement& bus, const BusLookup& lookup, DiagnosticList& out)
+{
+  if (bus.session.lexeme.empty())
+  {
+    return;
+  }
+  const auto sessions = lookup.sessions ? lookup.sessions() : std::vector<std::string> {};
+  const bool sessionKnown = std::find(sessions.begin(), sessions.end(), bus.session.lexeme) != sessions.end();
+  if (!sessionKnown)
+  {
+    std::string msg;
+    msg.append("Session '");
+    msg.append(bus.session.lexeme);
+    msg.append("' is not known yet");
+    out.push_back(Diagnostic {tokenSpan(bus.session),
+                              Severity::info,
+                              DiagnosticCode::validateUnknownSession,
+                              std::move(msg)});
+    return;
+  }
+  if (bus.bus.lexeme.empty())
+  {
+    return;
+  }
+  const auto busesInSession =
+    lookup.buses ? lookup.buses(std::string_view {bus.session.lexeme}) : std::vector<std::string> {};
+  const bool busKnown = std::find(busesInSession.begin(), busesInSession.end(), bus.bus.lexeme) != busesInSession.end();
+  if (!busKnown)
+  {
+    std::string msg;
+    msg.append("Bus '");
+    msg.append(bus.bus.lexeme);
+    msg.append("' is not known in session '");
+    msg.append(bus.session.lexeme);
+    msg.append("'");
+    out.push_back(
+      Diagnostic {tokenSpan(bus.bus), Severity::info, DiagnosticCode::validateUnknownBus, std::move(msg)});
+  }
+}
+
+}  // namespace
+
+ValidateResult validate(std::string_view text, const CustomTypeRegistry& types, const BusLookup& buses)
+{
+  const std::string source(text);
+
+  StlScanner  scanner(source, ScanMode::tolerant);
+  const auto& rawTokens = scanner.scanTokens();
+  auto        scannerDiagnostics = scanner.diagnostics();
+
+  StlParser parser(rawTokens);
+  auto      parsed = parser.parseQueryTolerant(std::move(scannerDiagnostics));
+
+  ValidateResult result;
+  result.diagnostics = std::move(parsed.diagnostics);
+  result.ast = std::move(parsed.query);
+
+  // Resolve the class if a type was parsed.
+  const ClassType* classType = nullptr;
+  if (result.ast.type.has_value() && !result.ast.type->qualifiedName.empty())
+  {
+    const auto typeHandle = types.get(result.ast.type->qualifiedName);
+    if (!typeHandle.has_value())
+    {
+      std::string msg;
+      msg.append("Class '");
+      msg.append(result.ast.type->qualifiedName);
+      msg.append("' is not known yet");
+      result.diagnostics.push_back(Diagnostic {result.ast.type->span,
+                                               Severity::info,
+                                               DiagnosticCode::validateUnknownClass,
+                                               std::move(msg)});
+    }
+    else
+    {
+      const auto classHandle = dynamicTypeHandleCast<const ClassType>(*typeHandle);
+      if (!classHandle.has_value())
+      {
+        std::string msg;
+        msg.append("'");
+        msg.append(result.ast.type->qualifiedName);
+        msg.append("' is not a class");
+        result.diagnostics.push_back(Diagnostic {result.ast.type->span,
+                                                 Severity::info,
+                                                 DiagnosticCode::validateUnknownClass,
+                                                 std::move(msg)});
+      }
+      else
+      {
+        classType = classHandle->type();
+      }
+    }
+  }
+
+  // Walk the WHERE expression against the resolved class.
+  if (classType != nullptr && result.ast.condition != nullptr)
+  {
+    WhereWalker walker(*classType, result.diagnostics);
+    walker.walk(result.ast.condition);
+  }
+
+  // Check the bus reference.
+  validateBus(result.ast.bus, buses, result.diagnostics);
+
+  return result;
+}
+
+}  // namespace sen::lang::query
