@@ -0,0 +1,68 @@
+// === tokenize.h ======================================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#ifndef SEN_CORE_LANG_QUERY_TOKENIZE_H
+#define SEN_CORE_LANG_QUERY_TOKENIZE_H
+
+// sen
+#include "sen/core/lang/code_location.h"
+#include "sen/core/lang/diagnostic.h"
+
+// std
+#include <string>
+#include <string_view>
+#include <vector>
+
+namespace sen::lang::query
+{
+
+/// \addtogroup lang
+/// @{
+
+/// Semantic classification of a token. Coarser than `StlTokenType`: editors map this to
+/// theme colors, LSP clients map it to `SemanticTokenType`. Any token surfaced here can be
+/// handed to a highlighter without further inspection.
+enum class TokenKind
+{
+  keyword,      /// SELECT, FROM, WHERE, AND, OR, BETWEEN, IN, NOT, TRUE, FALSE
+  identifier,   /// property paths, session names, bus names, class names
+  string,       /// quoted string literal
+  number,       /// integral or real literal
+  operator_,    /// = != < <= > >= + - * /
+  punctuation,  /// . , ( )
+  comment,      /// line comment
+  error,        /// `invalidChar` / `partialString` from the tolerant scanner
+  endOfFile,    /// synthetic terminator at text.size()
+};
+
+/// One classified lexeme with its byte-accurate span into the source.
+struct Token
+{
+  TokenKind   kind = TokenKind::endOfFile;
+  TextSpan    span = {};
+  std::string lexeme = {};  /// raw text as it appears in the source (includes quotes for strings)
+};
+
+/// Result of a tolerant tokenization. Never throws, always returns every byte of input
+/// as either a token or whitespace between two tokens.
+struct TokenizeResult
+{
+  std::vector<Token> tokens = {};
+  DiagnosticList     diagnostics = {};
+};
+
+/// Tokenize query text tolerantly. Unrecognized characters become `TokenKind::error` tokens
+/// (with a `scanInvalidChar` diagnostic); unterminated strings become `TokenKind::error`
+/// tokens (with a `scanUnterminatedString` diagnostic). The result always ends with a
+/// single `TokenKind::endOfFile` token whose span begins at `text.size()`.
+[[nodiscard]] TokenizeResult tokenize(std::string_view text);
+
+/// @}
+
+}  // namespace sen::lang::query
+
+#endif  // SEN_CORE_LANG_QUERY_TOKENIZE_H
