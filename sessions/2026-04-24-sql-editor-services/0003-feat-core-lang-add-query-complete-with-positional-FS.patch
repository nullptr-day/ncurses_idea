+#ifndef SEN_CORE_LANG_QUERY_COMPLETE_H
+#define SEN_CORE_LANG_QUERY_COMPLETE_H
+
+// sen
+#include "sen/core/lang/code_location.h"
+#include "sen/core/lang/query/bus_lookup.h"
+#include "sen/core/meta/class_type.h"
+#include "sen/core/meta/property.h"
+#include "sen/core/meta/type.h"
+
+// std
+#include <cstddef>
+#include <memory>
+#include <string>
+#include <string_view>
+#include <variant>
+#include <vector>
+
+namespace sen
+{
+class CustomTypeRegistry;
+}
+
+namespace sen::lang::query
+{
+
+/// \addtogroup lang
+/// @{
+
+/// A reserved word or grammar-level literal symbol (including `*` in `SELECT *`). The text
+/// is the exact token that should be inserted; casing matches the grammar (upper for
+/// control keywords, lower for `true` / `false`).
+struct KeywordCompletion
+{
+  std::string text;
+};
+
+/// A class reachable from the `CustomTypeRegistry`. The text to insert is
+/// `type->getQualifiedName()`; the handle also gives consumers access to docs,
+/// properties, and inheritance without re-resolving the registry.
+struct ClassNameCompletion
+{
+  ConstTypeHandle<ClassType> type;
+};
+
+/// A session name discovered via `BusLookup::sessions`.
+struct SessionCompletion
+{
+  std::string name;
+};
+
+/// A bus name discovered via `BusLookup::buses(session)`. `session` is echoed back so the
+/// UI can label the completion in-context.
+struct BusCompletion
+{
+  std::string session;
+  std::string name;
+};
+
+/// A property of the selected class. The text to insert is `property->getName()`; the
+/// handle is kept alive by the caller registering the `ClassType`, so consumers can read
+/// its type, category, tags, etc.
+struct PropertyCompletion
+{
+  std::shared_ptr<const Property> property;
+};
+
+/// A value literal whose set of valid forms is enumerable (currently: enum values for an
+/// `EnumType` property). `text` is the literal as it should appear in the query (including
+/// surrounding quotes for string-shaped values). `valueType` is the meta type the value
+/// belongs to (typically the property's type) so consumers can filter or re-label.
+struct TypedValueCompletion
+{
+  std::string      text;
+  ConstTypeHandle<> valueType;
+};
+
+/// One completion candidate. The variant members are non-overlapping categories; consumers
+/// typically render them with distinct icons / grouping.
+using Completion = std::variant<KeywordCompletion,
+                                ClassNameCompletion,
+                                SessionCompletion,
+                                BusCompletion,
+                                PropertyCompletion,
+                                TypedValueCompletion>;
+
+/// Result of a completion request.
+///
+/// `replacement` is the text span in the source that a chosen completion should overwrite
+/// (an empty span at the cursor means "insert without replacing"). `items` is the list of
+/// candidates, filtered by whatever prefix the cursor is sitting on; order is left to the
+/// caller to re-sort / re-score.
+struct CompleteResult
+{
+  TextSpan                replacement = {};
+  std::vector<Completion> items = {};
+};
+
+/// Compute completion candidates at `cursor` inside `text`.
+///
+/// `cursor` is a byte offset in [0, text.size()]. Values past the end are clamped. The
+/// function tokenizes tolerantly, classifies the grammar slot at the cursor with a small
+/// positional FSM, then fills candidates by consulting `types` and `buses` for the slot
+/// (class names after `SELECT`, session names after `FROM`, bus names after `session.`,
+/// property names after `WHERE` on a known class, enum values on a typed RHS, etc.).
+///
+/// The returned `items` are already prefix-filtered against whatever partial word the
+/// cursor sits on; an empty prefix returns every candidate for the slot. Scope for this
+/// pass: single-segment property paths only (struct / variant field access deferred),
+/// typed-value completion for `EnumType` and `BoolType` properties only.
+[[nodiscard]] CompleteResult complete(std::string_view          text,
+                                      std::size_t               cursor,
+                                      const CustomTypeRegistry& types,
+                                      const BusLookup&          buses);
+
+/// @}
+
+}  // namespace sen::lang::query
+
+#endif  // SEN_CORE_LANG_QUERY_COMPLETE_H
