+/// Re-scan of the source with byte-accurate spans. Shares its span-reconstruction logic
+/// with `tokenize.cpp` but keeps the raw `StlTokenType` so the FSM can distinguish
+/// `keywordSelect` from `keywordFrom` without re-parsing lexemes. Comments and EOF are
+/// dropped here; the FSM never needs them.
+struct FsmToken
+{
+  StlTokenType type = StlTokenType::endOfFile;
+  TextSpan     span = {};
+  std::string  lexeme = {};
+};
+
+[[nodiscard]] bool isWhitespace(char c) noexcept { return c == ' ' || c == '\t' || c == '\n' || c == '\r'; }
+
+[[nodiscard]] std::vector<FsmToken> scan(std::string_view text)
+{
+  const std::string source(text);
+  StlScanner        scanner(source, ScanMode::tolerant);
+  const auto&       raw = scanner.scanTokens();
+
+  std::vector<FsmToken> out;
+  out.reserve(raw.size());
+
+  std::size_t cursor = 0U;
+  for (const auto& t: raw)
+  {
+    while (cursor < source.size() && isWhitespace(source[cursor]))
+    {
+      ++cursor;
+    }
+    std::size_t       end = t.loc.offset;
+    const std::size_t rawBegin = (cursor <= end) ? cursor : end;
+
+    if (t.type == StlTokenType::comment || t.type == StlTokenType::endOfFile)
+    {
+      cursor = end;
+      continue;
+    }
+
+    // The scanner's `number()` consumes trailing whitespace (legacy support for
+    // `- 5` signed numerics). Trim it off so the reconstructed span ends at the
+    // last actual token character.
+    while (end > rawBegin && isWhitespace(source[end - 1U]))
+    {
+      --end;
+    }
+
+    FsmToken f;
+    f.type = t.type;
+    f.span = TextSpan {rawBegin, end};
+    f.lexeme = (end > rawBegin) ? source.substr(rawBegin, end - rawBegin) : std::string {};
+    out.push_back(std::move(f));
+    cursor = t.loc.offset;
+  }
+  return out;
+}
+
+/// Tokens that are "word-like" — the cursor sitting inside or immediately after one of
+/// these is editing that word.
+[[nodiscard]] bool isEditableToken(StlTokenType t) noexcept
+{
+  switch (t)
+  {
+    case StlTokenType::identifier:
+    case StlTokenType::string:
+    case StlTokenType::partialString:
+    case StlTokenType::real:
+    case StlTokenType::integral:
+    case StlTokenType::invalidChar:
+      return true;
+    default:
+      break;
+  }
+  // All keyword* token types are editable (user may be mid-typing a keyword).
+  if (t >= StlTokenType::keywordAbstract && t <= StlTokenType::keywordBetween)
+  {
+    return true;
+  }
+  return false;
+}
+
+/// Locate the token being edited, if any. Returns an index into `tokens` or `tokens.size()`
+/// when the cursor is between tokens (user is starting a new word).
+[[nodiscard]] std::size_t findCurrentToken(const std::vector<FsmToken>& tokens, std::size_t cursor) noexcept
+{
+  for (std::size_t i = 0U; i < tokens.size(); ++i)
+  {
+    const auto& t = tokens[i];
+    if (cursor > t.span.begin && cursor <= t.span.end && isEditableToken(t.type))
+    {
+      return i;
+    }
+  }
+  return tokens.size();
+}
+
+/// Grammar slots the cursor can be in. Each slot drives which completion kinds we emit.
+enum class Slot
+{
+  selectKeyword,      /// start of query; want `SELECT`
+  classPath,          /// after `SELECT` or a `.` in the class path
+  classPathTail,      /// after a class-name identifier; want `.` or `FROM`
+  fromKeyword,        /// after `SELECT *`; want `FROM`
+  sessionName,        /// after `FROM`
+  busDot,             /// after `<session>`; want `.`
+  busName,            /// after `<session>.`
+  whereOrEnd,         /// after `<session>.<bus>`; want `WHERE` or end
+  whereExpr,          /// start of an expression (fresh, after AND/OR, after `(`, after NOT)
+  binaryOp,           /// after a "value" in an expression
+  literal,            /// after a comparison op; want a value (typed if we know the LHS)
+  afterNotInExpr,     /// saw `NOT` in binaryOp slot; expect `BETWEEN` / `IN` / expression
+  betweenFirst,       /// after `BETWEEN`; want the min value
+  betweenAnd,         /// after `BETWEEN <lit>`; want structural `AND`
+  betweenSecond,      /// after `BETWEEN <lit> AND`; want the max value
+  inOpenParen,        /// after `IN` / `NOT IN`; want `(`
+  inListElem,         /// inside `IN (...)`; want a value
+  inListSepOrClose,   /// after a value in `IN (...)`; want `,` or `)`
+  done,               /// no useful suggestions
+};
+
+/// Decide whether a token behaves as a "value" in an expression (an operand). Strings,
+/// numbers, booleans, identifiers — parenthesized groups close into this too via `)`.
+[[nodiscard]] bool isValueStart(StlTokenType t) noexcept
+{
+  switch (t)
+  {
+    case StlTokenType::identifier:
+    case StlTokenType::string:
+    case StlTokenType::partialString:
+    case StlTokenType::integral:
+    case StlTokenType::real:
+    case StlTokenType::keywordTrue:
+    case StlTokenType::keywordFalse:
+      return true;
+    default:
+      return false;
+  }
+}
+
+/// Pair of (slot, lhsProperty). The property is set while transitioning from binaryOp
+/// into literal / betweenFirst / inListElem when we can tie the LHS to a known class
+/// property — so typed-value completion has something to consult.
+struct FsmState
+{
+  Slot                              slot = Slot::selectKeyword;
+  std::shared_ptr<const Property>   lhsProperty = nullptr;
+  std::string                       lastIdentifier = {};  /// raw lexeme of the last value identifier
+  std::string                       sessionName = {};     /// captured between FROM and the session dot
+};
+
+/// Walk tokens and advance the FSM. Returns the state "waiting at" the end of the walk —
+/// that's what the cursor is pointed at.
+void step(FsmState& s, const FsmToken& t, const ClassType* cls)
+{
+  const auto type = t.type;
+  switch (s.slot)
+  {
+    case Slot::selectKeyword:
+      if (type == StlTokenType::keywordSelect)
+      {
+        s.slot = Slot::classPath;
+      }
+      break;
+
+    case Slot::classPath:
+      if (type == StlTokenType::star)
+      {
+        s.slot = Slot::fromKeyword;
+      }
+      else if (type == StlTokenType::identifier)
+      {
+        s.slot = Slot::classPathTail;
+      }
+      break;
+
+    case Slot::classPathTail:
+      if (type == StlTokenType::dot)
+      {
+        s.slot = Slot::classPath;
+      }
+      else if (type == StlTokenType::keywordFrom)
+      {
+        s.slot = Slot::sessionName;
+      }
+      break;
+
+    case Slot::fromKeyword:
+      if (type == StlTokenType::keywordFrom)
+      {
+        s.slot = Slot::sessionName;
+      }
+      break;
+
+    case Slot::sessionName:
+      if (type == StlTokenType::identifier)
+      {
+        s.sessionName = t.lexeme;
+        s.slot = Slot::busDot;
+      }
+      break;
+
+    case Slot::busDot:
+      if (type == StlTokenType::dot)
+      {
+        s.slot = Slot::busName;
+      }
+      break;
+
+    case Slot::busName:
+      if (type == StlTokenType::identifier)
+      {
+        s.slot = Slot::whereOrEnd;
+      }
+      break;
+
+    case Slot::whereOrEnd:
+      if (type == StlTokenType::keywordWhere)
+      {
+        s.slot = Slot::whereExpr;
+      }
+      break;
+
+    case Slot::whereExpr:
+      if (type == StlTokenType::keywordNot || type == StlTokenType::bang || type == StlTokenType::minus ||
+          type == StlTokenType::plus)
+      {
+        // unary prefix; stay in whereExpr
+      }
+      else if (type == StlTokenType::leftParen)
+      {
+        // enter a parenthesized sub-expression; stay in whereExpr
+      }
+      else if (type == StlTokenType::rightParen)
+      {
+        s.slot = Slot::binaryOp;
+      }
+      else if (isValueStart(type))
+      {
+        if (type == StlTokenType::identifier && cls != nullptr)
+        {
+          const Property* p = cls->searchPropertyByName(t.lexeme);
+          if (p != nullptr)
+          {
+            // searchPropertyByName returns a raw pointer; getProperties returns shared_ptrs.
+            // Look up the shared_ptr to carry meta handle through to typed-value completion.
+            const auto all = cls->getProperties(ClassType::SearchMode::includeParents);
+            for (const auto& sp: all)
+            {
+              if (sp.get() == p)
+              {
+                s.lhsProperty = sp;
+                break;
+              }
+            }
+          }
+          else
+          {
+            s.lhsProperty.reset();
+          }
+          s.lastIdentifier = t.lexeme;
+        }
+        else
+        {
+          s.lhsProperty.reset();
+          s.lastIdentifier = {};
+        }
+        s.slot = Slot::binaryOp;
+      }
+      break;
+
+    case Slot::binaryOp:
+      if (type == StlTokenType::keywordAnd || type == StlTokenType::keywordOr)
+      {
+        s.lhsProperty.reset();
+        s.lastIdentifier = {};
+        s.slot = Slot::whereExpr;
+      }
+      else if (type == StlTokenType::keywordBetween)
+      {
+        s.slot = Slot::betweenFirst;
+      }
+      else if (type == StlTokenType::keywordIn)
+      {
+        s.slot = Slot::inOpenParen;
+      }
+      else if (type == StlTokenType::keywordNot)
+      {
+        s.slot = Slot::afterNotInExpr;
+      }
+      else if (type == StlTokenType::equal || type == StlTokenType::equalEqual || type == StlTokenType::bangEqual ||
+               type == StlTokenType::less || type == StlTokenType::lessEqual || type == StlTokenType::greater ||
+               type == StlTokenType::greaterEqual)
+      {
+        s.slot = Slot::literal;
+      }
+      else if (type == StlTokenType::plus || type == StlTokenType::minus || type == StlTokenType::star ||
+               type == StlTokenType::slash)
+      {
+        s.lhsProperty.reset();
+        s.lastIdentifier = {};
+        s.slot = Slot::whereExpr;
+      }
+      else if (type == StlTokenType::rightParen)
+      {
+        // still a value-ish position, stay
+      }
+      break;
+
+    case Slot::literal:
+      if (isValueStart(type))
+      {
+        s.slot = Slot::binaryOp;
+      }
+      else if (type == StlTokenType::minus || type == StlTokenType::plus)
+      {
+        // unary sign on numeric literal; stay
+      }
+      break;
+
+    case Slot::afterNotInExpr:
+      if (type == StlTokenType::keywordBetween)
+      {
+        s.slot = Slot::betweenFirst;
+      }
+      else if (type == StlTokenType::keywordIn)
+      {
+        s.slot = Slot::inOpenParen;
+      }
+      else
+      {
+        s.slot = Slot::done;
+      }
+      break;
+
+    case Slot::betweenFirst:
+      if (isValueStart(type))
+      {
+        s.slot = Slot::betweenAnd;
+      }
+      break;
+
+    case Slot::betweenAnd:
+      if (type == StlTokenType::keywordAnd)
+      {
+        s.slot = Slot::betweenSecond;
+      }
+      break;
+
+    case Slot::betweenSecond:
+      if (isValueStart(type))
+      {
+        s.slot = Slot::binaryOp;
+      }
+      break;
+
+    case Slot::inOpenParen:
+      if (type == StlTokenType::leftParen)
+      {
+        s.slot = Slot::inListElem;
+      }
+      break;
+
+    case Slot::inListElem:
+      if (isValueStart(type))
+      {
+        s.slot = Slot::inListSepOrClose;
+      }
+      break;
+
+    case Slot::inListSepOrClose:
+      if (type == StlTokenType::comma)
+      {
+        s.slot = Slot::inListElem;
+      }
+      else if (type == StlTokenType::rightParen)
+      {
+        s.slot = Slot::binaryOp;
+      }
+      break;
+
+    case Slot::done:
+      break;
+  }
+}
+
+/// Resolve the `SELECT`ed class by scanning until `FROM` (or end). Returns null when the
+/// class name is absent, multi-segment with unresolved parts, or not in the registry.
+[[nodiscard]] const ClassType* resolveSelectedClass(const std::vector<FsmToken>& tokens,
+                                                    const CustomTypeRegistry&    types)
+{
+  std::string qualifiedName;
+  bool        inSelect = false;
+  for (const auto& t: tokens)
+  {
+    if (!inSelect)
+    {
+      if (t.type == StlTokenType::keywordSelect)
+      {
+        inSelect = true;
+      }
+      continue;
+    }
+    if (t.type == StlTokenType::keywordFrom || t.type == StlTokenType::star)
+    {
+      break;
+    }
+    if (t.type == StlTokenType::identifier)
+    {
+      if (!qualifiedName.empty())
+      {
+        qualifiedName.push_back('.');
+      }
+      qualifiedName.append(t.lexeme);
+    }
+    else if (t.type != StlTokenType::dot)
+    {
+      break;
+    }
+  }
+  if (qualifiedName.empty())
+  {
+    return nullptr;
+  }
+  const auto handle = types.get(qualifiedName);
+  if (!handle.has_value())
+  {
+    return nullptr;
+  }
+  const auto classHandle = dynamicTypeHandleCast<const ClassType>(*handle);
+  if (!classHandle.has_value())
+  {
+    return nullptr;
+  }
+  return classHandle->type();
+}
+
+/// Prefix-filter helper. The language is case-sensitive (UPPER control keywords, lower
+/// `true`/`false`, case-preserving identifiers) so a plain substring compare is what
+/// editors want here.
+[[nodiscard]] bool startsWith(std::string_view candidate, std::string_view prefix) noexcept
+{
+  return candidate.size() >= prefix.size() && candidate.compare(0, prefix.size(), prefix) == 0;
+}
+
+/// Walk `AliasType` chains so enum/native detection works on aliased declarations.
+[[nodiscard]] const Type* unwrapAliases(const Type* type) noexcept
+{
+  while (type != nullptr && type->isAliasType())
+  {
+    const auto* alias = type->asAliasType();
+    type = alias->getAliasedType().type();
+  }
+  return type;
+}
+
+/// Helpers to push completion candidates with a prefix filter.
+void pushKeyword(std::vector<Completion>& out, std::string_view kw, std::string_view prefix)
+{
+  if (startsWith(kw, prefix))
+  {
+    out.push_back(KeywordCompletion {std::string {kw}});
+  }
+}
+
+/// Convenience overload: fetch the canonical lexeme from `lexemeOf` so call sites don't
+/// repeat the string literal. Useful for grammar keywords (SELECT, FROM, AND, ...) and
+/// for the `true` / `false` bool literals.
+void pushKeyword(std::vector<Completion>& out, StlTokenType type, std::string_view prefix)
+{
+  pushKeyword(out, lexemeOf(type), prefix);
+}
+
+void pushClassCandidates(std::vector<Completion>&  out,
+                         const CustomTypeRegistry& types,
+                         std::string_view          prefix)
+{
+  pushKeyword(out, "*", prefix);
+  for (const auto& [name, handle]: types.getAll())
+  {
+    const auto classHandle = dynamicTypeHandleCast<const ClassType>(handle);
+    if (!classHandle.has_value())
+    {
+      continue;
+    }
+    if (startsWith(name, prefix))
+    {
+      out.push_back(ClassNameCompletion {*classHandle});
+    }
+  }
+}
+
+void pushSessionCandidates(std::vector<Completion>& out, const BusLookup& buses, std::string_view prefix)
+{
+  if (!buses.sessions)
+  {
+    return;
+  }
+  const auto names = buses.sessions();
+  for (const auto& n: names)
+  {
+    if (startsWith(n, prefix))
+    {
+      out.push_back(SessionCompletion {n});
+    }
+  }
+}
+
+void pushBusCandidates(std::vector<Completion>& out,
+                       const BusLookup&         buses,
+                       std::string_view         session,
+                       std::string_view         prefix)
+{
+  if (!buses.buses || session.empty())
+  {
+    return;
+  }
+  const auto names = buses.buses(session);
+  for (const auto& n: names)
+  {
+    if (startsWith(n, prefix))
+    {
+      out.push_back(BusCompletion {std::string {session}, n});
+    }
+  }
+}
+
+void pushPropertyCandidates(std::vector<Completion>& out, const ClassType& cls, std::string_view prefix)
+{
+  const auto props = cls.getProperties(ClassType::SearchMode::includeParents);
+  for (const auto& p: props)
+  {
+    if (startsWith(p->getName(), prefix))
+    {
+      out.push_back(PropertyCompletion {p});
+    }
+  }
+}
+
+/// Emit typed-value suggestions for the LHS's type, if we can enumerate it. Enum values
+/// are quoted per the language spec; bool values are the lowercase keywords. Everything
+/// else returns no candidates.
+void pushTypedValueCandidates(std::vector<Completion>& out, const Property& prop, std::string_view prefix)
+{
+  const auto typeHandle = prop.getType();
+  const Type* effective = unwrapAliases(typeHandle.type());
+  if (effective == nullptr)
+  {
+    return;
+  }
+  if (effective->isBoolType())
+  {
+    for (const auto type: {StlTokenType::keywordTrue, StlTokenType::keywordFalse})
+    {
+      const auto v = lexemeOf(type);
+      if (startsWith(v, prefix))
+      {
+        out.push_back(TypedValueCompletion {std::string {v}, typeHandle});
+      }
+    }
+    return;
+  }
+  if (!effective->isEnumType())
+  {
+    return;
+  }
+  const auto* enumType = effective->asEnumType();
+  if (enumType == nullptr)
+  {
+    return;
+  }
+  // The value shape is a double-quoted string containing the enumerator name.
+  // If the caller is already mid-string, match against the inner name; otherwise
+  // match against the full quoted form.
+  const bool  insideString = !prefix.empty() && (prefix.front() == '"' || prefix.front() == '\'');
+  const char  quote = insideString ? prefix.front() : '"';
+  const auto  innerPrefix = insideString ? prefix.substr(1) : std::string_view {};
+  for (const auto& e: enumType->getEnums())
+  {
+    std::string literal;
+    literal.push_back(quote);
+    literal.append(e.name);
+    literal.push_back(quote);
+
+    const bool matches =
+      insideString ? startsWith(e.name, innerPrefix) : startsWith(literal, prefix);
+    if (matches)
+    {
+      out.push_back(TypedValueCompletion {std::move(literal), typeHandle});
+    }
+  }
+}
+
+}  // namespace
+
+CompleteResult complete(std::string_view          text,
+                        std::size_t               cursor,
+                        const CustomTypeRegistry& types,
+                        const BusLookup&          buses)
+{
+  if (cursor > text.size())
+  {
+    cursor = text.size();
+  }
+
+  const auto tokens = scan(text);
+  const auto currentIdx = findCurrentToken(tokens, cursor);
+
+  std::string prefix;
+  TextSpan    replacement {cursor, cursor};
+  if (currentIdx < tokens.size())
+  {
+    const auto& cur = tokens[currentIdx];
+    prefix = text.substr(cur.span.begin, cursor - cur.span.begin);
+    replacement = cur.span;
+  }
+
+  // Walk tokens strictly before the current token (or all of them, when cursor is between
+  // tokens). `cls` is resolved up-front so we can feed typed-value completion and property
+  // lists off it.
+  const ClassType* cls = resolveSelectedClass(tokens, types);
+  FsmState         state;
+  const std::size_t stopAt = (currentIdx < tokens.size()) ? currentIdx : tokens.size();
+  for (std::size_t i = 0U; i < stopAt; ++i)
+  {
+    step(state, tokens[i], cls);
+  }
+
+  // Class-path candidates are fully qualified (e.g. `demo.Aircraft`), but the source
+  // holds the path as `identifier . identifier . ...`. If the cursor sits after one of
+  // those dots, we widen the replacement to cover the whole accumulated path so the
+  // filter prefix matches against the candidate's qualified name.
+  if (state.slot == Slot::classPath)
+  {
+    std::size_t rbegin = stopAt;
+    while (rbegin >= 2U && tokens[rbegin - 1U].type == StlTokenType::dot &&
+           tokens[rbegin - 2U].type == StlTokenType::identifier)
+    {
+      rbegin -= 2U;
+    }
+    if (rbegin < stopAt)
+    {
+      const std::size_t begin = tokens[rbegin].span.begin;
+      const std::size_t end = (currentIdx < tokens.size()) ? tokens[currentIdx].span.end : cursor;
+      replacement = TextSpan {begin, end};
+      prefix = std::string {text.substr(begin, cursor - begin)};
+    }
+  }
+
+  CompleteResult result;
+  result.replacement = replacement;
+
+  switch (state.slot)
+  {
+    case Slot::selectKeyword:
+      pushKeyword(result.items, StlTokenType::keywordSelect, prefix);
+      break;
+
+    case Slot::classPath:
+      pushClassCandidates(result.items, types, prefix);
+      break;
+
+    case Slot::classPathTail:
+      pushKeyword(result.items, StlTokenType::keywordFrom, prefix);
+      break;
+
+    case Slot::fromKeyword:
+      pushKeyword(result.items, StlTokenType::keywordFrom, prefix);
+      break;
+
+    case Slot::sessionName:
+      pushSessionCandidates(result.items, buses, prefix);
+      break;
+
+    case Slot::busDot:
+      // Nothing useful to complete: user needs to type `.`. Leave empty.
+      break;
+
+    case Slot::busName:
+      pushBusCandidates(result.items, buses, state.sessionName, prefix);
+      break;
+
+    case Slot::whereOrEnd:
+      pushKeyword(result.items, StlTokenType::keywordWhere, prefix);
+      break;
+
+    case Slot::whereExpr:
+      if (cls != nullptr)
+      {
+        pushPropertyCandidates(result.items, *cls, prefix);
+      }
+      pushKeyword(result.items, StlTokenType::keywordNot, prefix);
+      pushKeyword(result.items, StlTokenType::keywordTrue, prefix);
+      pushKeyword(result.items, StlTokenType::keywordFalse, prefix);
+      break;
+
+    case Slot::binaryOp:
+      pushKeyword(result.items, StlTokenType::keywordAnd, prefix);
+      pushKeyword(result.items, StlTokenType::keywordOr, prefix);
+      pushKeyword(result.items, StlTokenType::keywordBetween, prefix);
+      pushKeyword(result.items, StlTokenType::keywordIn, prefix);
+      pushKeyword(result.items, StlTokenType::keywordNot, prefix);
+      break;
+
+    case Slot::literal:
+    case Slot::betweenFirst:
+    case Slot::betweenSecond:
+    case Slot::inListElem:
+      if (state.lhsProperty != nullptr)
+      {
+        pushTypedValueCandidates(result.items, *state.lhsProperty, prefix);
+      }
+      break;
+
+    case Slot::afterNotInExpr:
+      pushKeyword(result.items, StlTokenType::keywordBetween, prefix);
+      pushKeyword(result.items, StlTokenType::keywordIn, prefix);
+      break;
+
+    case Slot::betweenAnd:
+      pushKeyword(result.items, StlTokenType::keywordAnd, prefix);
+      break;
+
+    case Slot::inOpenParen:
+      // Nothing to complete; user needs `(`.
+      break;
+
+    case Slot::inListSepOrClose:
+      // Users rarely want punctuation completion; leave empty.
+      break;
+
+    case Slot::done:
+      break;
+  }
+
+  return result;
+}
+
+}  // namespace sen::lang::query
