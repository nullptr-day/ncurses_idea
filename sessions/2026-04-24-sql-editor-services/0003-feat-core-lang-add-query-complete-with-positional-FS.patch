+/// @test
+/// After a property identifier in the WHERE clause, we offer comparison-op / logical-op
+/// keywords. The op tokens themselves aren't in the suggestion list since they are
+/// operator tokens, not completion candidates.
+TEST(QueryComplete, afterPropertyOffersComparisonKeywords)
+{
+  const auto& registry = registryWithAircraft();
+  const auto  buses = makeBusLookup({"alpha"}, {"b1"});
+
+  const CompleteResult r = complete("SELECT demo.Aircraft FROM alpha.b1 WHERE altitude ", 50U, registry, buses);
+
+  EXPECT_TRUE(hasKeyword(r, "AND"));
+  EXPECT_TRUE(hasKeyword(r, "OR"));
+  EXPECT_TRUE(hasKeyword(r, "BETWEEN"));
+  EXPECT_TRUE(hasKeyword(r, "IN"));
+  EXPECT_TRUE(hasKeyword(r, "NOT"));
+}
