+// Aircraft class with mixed property kinds so we can exercise typed-value completion:
+// `force` is an enum, `active` is a bool, `altitude` is an integer, `callsign` is a string.
+EnumSpec forceEnumSpec()
+{
+  std::vector<Enumerator> enums {{"friendly", 0, ""}, {"neutral", 1, ""}, {"opposing", 2, ""}};
+  return EnumSpec {"ForceId", "demo.ForceId", "", std::move(enums), sen::UInt8Type::get()};
+}
+
+ClassSpec aircraftSpec(sen::ConstTypeHandle<EnumType> forceEnum)
+{
+  std::vector<PropertySpec> properties;
+  properties.emplace_back("callsign",
+                          "",
+                          sen::StringType::get(),
+                          PropertyCategory::dynamicRW,
+                          TransportMode::multicast,
+                          false,
+                          std::vector<std::string> {});
+  properties.emplace_back("altitude",
+                          "",
+                          sen::UInt32Type::get(),
+                          PropertyCategory::dynamicRW,
+                          TransportMode::multicast,
+                          false,
+                          std::vector<std::string> {});
+  properties.emplace_back("active",
+                          "",
+                          sen::BoolType::get(),
+                          PropertyCategory::dynamicRW,
+                          TransportMode::multicast,
+                          false,
+                          std::vector<std::string> {});
+  properties.emplace_back("force",
+                          "",
+                          std::move(forceEnum),
+                          PropertyCategory::dynamicRW,
+                          TransportMode::multicast,
+                          false,
+                          std::vector<std::string> {});
+  return ClassSpec {"Aircraft", "demo.Aircraft", "", std::move(properties), {}, {}, {}, {}, false, false, {}, {}};
+}
+
+const CustomTypeRegistry& registryWithAircraft()
+{
+  static const auto kForce = EnumType::make(forceEnumSpec());
+  static const auto kAircraft = ClassType::make(aircraftSpec(kForce));
+  static CustomTypeRegistry registry;
+  static const bool seeded = [&]()
+  {
+    registry.add(kForce);
+    registry.add(kAircraft);
+    return true;
+  }();
+  (void)seeded;
+  return registry;
+}
+
+BusLookup makeBusLookup(std::vector<std::string> sessions, std::vector<std::string> buses)
+{
+  BusLookup lookup;
+  lookup.sessions = [sessions = std::move(sessions)]() { return sessions; };
+  lookup.buses = [buses = std::move(buses)](std::string_view) { return buses; };
+  return lookup;
+}
+
+template <class T>
+bool anyItemIs(const CompleteResult& r)
+{
+  for (const auto& c: r.items)
+  {
+    if (std::holds_alternative<T>(c))
+    {
+      return true;
+    }
+  }
+  return false;
+}
+
+bool hasKeyword(const CompleteResult& r, std::string_view text)
+{
+  for (const auto& c: r.items)
+  {
+    if (const auto* k = std::get_if<KeywordCompletion>(&c); k != nullptr && k->text == text)
+    {
+      return true;
+    }
+  }
+  return false;
+}
+
+bool hasClassName(const CompleteResult& r, std::string_view name)
+{
+  for (const auto& c: r.items)
+  {
+    if (const auto* cn = std::get_if<ClassNameCompletion>(&c); cn != nullptr && cn->type->getQualifiedName() == name)
+    {
+      return true;
+    }
+  }
+  return false;
+}
+
+bool hasPropertyNamed(const CompleteResult& r, std::string_view name)
+{
+  for (const auto& c: r.items)
+  {
+    if (const auto* p = std::get_if<PropertyCompletion>(&c); p != nullptr && p->property->getName() == name)
+    {
+      return true;
+    }
+  }
+  return false;
+}
+
+bool hasTypedValue(const CompleteResult& r, std::string_view text)
+{
+  for (const auto& c: r.items)
+  {
+    if (const auto* v = std::get_if<TypedValueCompletion>(&c); v != nullptr && v->text == text)
+    {
+      return true;
+    }
+  }
+  return false;
+}
+
+bool hasSession(const CompleteResult& r, std::string_view name)
+{
+  for (const auto& c: r.items)
+  {
+    if (const auto* s = std::get_if<SessionCompletion>(&c); s != nullptr && s->name == name)
+    {
+      return true;
+    }
+  }
+  return false;
+}
+
+bool hasBus(const CompleteResult& r, std::string_view name)
+{
+  for (const auto& c: r.items)
+  {
+    if (const auto* b = std::get_if<BusCompletion>(&c); b != nullptr && b->name == name)
+    {
+      return true;
+    }
+  }
+  return false;
+}
