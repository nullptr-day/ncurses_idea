+# -------------------------------------------------------------------------------------------------------------
+# Shell completion scripts
+#
+# Each CLI binary is run with --dump-spec at build time to produce a JSON spec of its commands,
+# options and flags. The merged spec is then rendered by `cli_gen completions` into bash, zsh,
+# fish and PowerShell scripts, which are installed to share/sen/completions/.
+# -------------------------------------------------------------------------------------------------------------
+
+set(cli_spec_dir ${CMAKE_CURRENT_BINARY_DIR}/cli_spec)
+set(cli_completions_dir ${CMAKE_BINARY_DIR}/share/sen/completions)
+
+file(MAKE_DIRECTORY ${cli_spec_dir})
+file(MAKE_DIRECTORY ${cli_completions_dir})
+
+set(cli_spec_binaries cli_sen cli_run cli_gen cli_archive cli_package cli_remote_shell)
+set(cli_spec_files)
+foreach(_bin IN LISTS cli_spec_binaries)
+  set(_spec ${cli_spec_dir}/${_bin}.json)
+  add_custom_command(
+    OUTPUT ${_spec}
+    COMMAND $<TARGET_FILE:${_bin}> --dump-spec > ${_spec}
+    DEPENDS ${_bin}
+    COMMENT "Dumping CLI spec for ${_bin}"
+    VERBATIM
+  )
+  list(APPEND cli_spec_files ${_spec})
+endforeach()
+
+set(cli_completion_outputs
+    ${cli_completions_dir}/sen.bash
+    ${cli_completions_dir}/_sen
+    ${cli_completions_dir}/sen.fish
+    ${cli_completions_dir}/sen.ps1
+)
+
+set(_spec_args)
+foreach(_spec IN LISTS cli_spec_files)
+  list(APPEND _spec_args --spec ${_spec})
+endforeach()
+
+add_custom_command(
+  OUTPUT ${cli_completion_outputs}
+  COMMAND $<TARGET_FILE:cli_gen> completions ${_spec_args} --out-dir ${cli_completions_dir}
+  DEPENDS cli_gen ${cli_spec_files}
+  COMMENT "Rendering shell completion scripts"
+  VERBATIM
+)
+
+add_custom_target(cli_completions ALL DEPENDS ${cli_completion_outputs})
+
+install(FILES ${cli_completion_outputs} DESTINATION share/sen/completions)
