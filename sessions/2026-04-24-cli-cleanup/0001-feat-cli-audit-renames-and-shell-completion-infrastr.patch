+# === CMakeLists.txt ===================================================================================================
+#                                               Sen Infrastructure
+#                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+#                                    See the LICENSE.txt file for more information.
+#                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+# ======================================================================================================================
+
+include(tps/json)
+include(tps/inja)
+
+# Unit tests for the completions generator. The production source files live in
+# ../src/completions/; we compile them directly into the test binary so each TEST_F can exercise
+# them without needing a separate shared library. The shell templates get their own header
+# dumps in a test-local output dir to keep this target self-contained.
+set(completions_src_dir ${CMAKE_CURRENT_SOURCE_DIR}/../../src)
+
+set(completions_templates
+    ${completions_src_dir}/completions/templates/bash.j2
+    ${completions_src_dir}/completions/templates/fish.j2
+    ${completions_src_dir}/completions/templates/powershell.j2
+    ${completions_src_dir}/completions/templates/zsh.j2
+)
+
+sen_internal_generate_template_headers(
+  OUTDIR
+  ${CMAKE_CURRENT_BINARY_DIR}/completions_templates
+  GEN_FILE_LIST
+  completions_template_dumps
+  TEMPLATE_FILES
+  ${completions_templates}
+)
+
+set(completions_src
+    ${completions_src_dir}/completions/completion_tree.cpp
+    ${completions_src_dir}/completions/emitters.cpp
+    ${completions_src_dir}/completions/spec_merge.cpp
+)
+
+set(completions_tests
+    completion_tree_test.cpp
+    emitters_test.cpp
+    spec_merge_test.cpp
+)
+
+add_sen_unit_test_suite(
+  completions_test
+  ${completions_src}
+  ${completions_tests}
+  ${completions_template_dumps}
+  LINK_DEPS
+  sen::core
+  $<BUILD_INTERFACE:nlohmann_json::nlohmann_json>
+  $<BUILD_INTERFACE:pantor::inja>
+)
+
+target_include_directories(
+  completions_test
+  PRIVATE ${completions_src_dir}
+  PRIVATE ${CMAKE_CURRENT_BINARY_DIR}
+)
+
+set_target_properties(
+  completions_test PROPERTIES FOLDER "test" RUNTIME_OUTPUT_DIRECTORY "${CMAKE_CURRENT_BINARY_DIR}/bin"
+)
diff --git a/apps/cli_gen/test/completions/completion_tree_test.cpp b/apps/cli_gen/test/completions/completion_tree_test.cpp
new file mode 100644
index 0000000..23e3cb9
--- /dev/null
+++ b/apps/cli_gen/test/completions/completion_tree_test.cpp
@@ -0,0 +1,186 @@
+// === completion_tree_test.cpp =======================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#include "completions/completion_tree.h"
+
+// nlohmann
+#include <nlohmann/json.hpp>
+
+// google test
+#include <gtest/gtest.h>
+
+namespace completions
+{
+
+namespace
+{
+
+/// Helper that returns a minimal spec mirroring what build_spec emits for a small CLI.
+nlohmann::json makeSampleSpec()
+{
+  return nlohmann::json::parse(R"JSON({
+    "name": "sen",
+    "path": ["sen"],
+    "description": "Welcome to sen",
+    "allow_extras": false,
+    "require_subcommand": false,
+    "options": [],
+    "subcommands": [
+      {
+        "name": "run",
+        "path": ["sen", "run"],
+        "description": "Run a sen kernel",
+        "allow_extras": true,
+        "require_subcommand": false,
+        "options": [
+          { "kind": "positional", "name": "config", "long": [], "short": [],
+            "type_name": "TEXT:PATH(existing)", "choices": [], "required": false,
+            "description": "Configuration file", "deprecated": false },
+          { "kind": "option", "name": "--preset", "long": ["--preset"], "short": [],
+            "type_name": "TEXT:{shell,explorer,replay}",
+            "choices": ["shell", "explorer", "replay"],
+            "required": false, "description": "Preset name", "deprecated": false },
+          { "kind": "flag", "name": "--start-stop", "long": ["--start-stop"], "short": [],
+            "type_name": "", "choices": [], "required": false,
+            "description": "Stop after start", "deprecated": false }
+        ],
+        "subcommands": []
+      },
+      {
+        "name": "legacy",
+        "path": ["sen", "legacy"],
+        "description": "deprecated alias",
+        "allow_extras": false,
+        "require_subcommand": false,
+        "options": [],
+        "subcommands": [],
+        "deprecated": true
+      }
+    ]
+  })JSON");
+}
+
+const NodeFacts* findNode(const CompletionTree& tree, const std::string& path)
+{
+  for (const auto& node: tree.nodes)
+  {
+    if (node.path == path)
+    {
+      return &node;
+    }
+  }
+  return nullptr;
+}
+
+}  // namespace
+
+/// @test
+/// Walker produces one NodeFacts per non-deprecated node, with path built from spec's path array.
+TEST(CompletionTreeTest, nodePathsAndSubcommands)
+{
+  const auto tree = buildCompletionTree(makeSampleSpec());
+
+  // Two non-deprecated nodes: "sen" and "sen run". Deprecated "sen legacy" is skipped.
+  ASSERT_EQ(tree.nodes.size(), 2U);
+
+  const auto* root = findNode(tree, "sen");
+  ASSERT_NE(root, nullptr);
+  // Deprecated "legacy" subcommand is filtered from root's subcommand list too.
+  ASSERT_EQ(root->subcommands.size(), 1U);
+  EXPECT_EQ(root->subcommands[0].name, "run");
+  EXPECT_EQ(root->subcommands[0].description, "Run a sen kernel");
+
+  const auto* run = findNode(tree, "sen run");
+  ASSERT_NE(run, nullptr);
+  EXPECT_TRUE(run->subcommands.empty());
+}
+
+/// @test
+/// Flags and value-taking options are distinguished; both appear in allOptionTokens but only
+/// value-taking options appear in optionsTakingValue.
+TEST(CompletionTreeTest, optionsTakingValueSeparation)
+{
+  const auto tree = buildCompletionTree(makeSampleSpec());
+  const auto* run = findNode(tree, "sen run");
+  ASSERT_NE(run, nullptr);
+
+  ASSERT_EQ(run->allOptionTokens.size(), 2U);
+  EXPECT_EQ(run->allOptionTokens[0].name, "--preset");
+  EXPECT_EQ(run->allOptionTokens[0].description, "Preset name");
+  EXPECT_EQ(run->allOptionTokens[1].name, "--start-stop");
+  EXPECT_EQ(run->allOptionTokens[1].description, "Stop after start");
+
+  ASSERT_EQ(run->optionsTakingValue.size(), 1U);
+  EXPECT_EQ(run->optionsTakingValue[0].name, "--preset");
+}
+
+/// @test
+/// Positional type and choice list are captured on the owner node.
+TEST(CompletionTreeTest, positionalInfo)
+{
+  const auto tree = buildCompletionTree(makeSampleSpec());
+  const auto* run = findNode(tree, "sen run");
+  ASSERT_NE(run, nullptr);
+
+  EXPECT_EQ(run->positionalType, "TEXT:PATH(existing)");
+  EXPECT_TRUE(run->positionalChoices.empty());
+}
+
+/// @test
+/// Value-taking options produce one OptionFacts entry per token with choices attached.
+TEST(CompletionTreeTest, optionFactsRecordsChoices)
+{
+  const auto tree = buildCompletionTree(makeSampleSpec());
+  ASSERT_EQ(tree.options.size(), 1U);
+
+  const auto& opt = tree.options.front();
+  EXPECT_EQ(opt.path, "sen run");
+  EXPECT_EQ(opt.token, "--preset");
+  EXPECT_EQ(opt.typeName, "TEXT:{shell,explorer,replay}");
+  ASSERT_EQ(opt.choices.size(), 3U);
+  EXPECT_EQ(opt.choices[0].name, "shell");
+  EXPECT_EQ(opt.choices[1].name, "explorer");
+  EXPECT_EQ(opt.choices[2].name, "replay");
+}
+
+/// @test
+/// KVList helpers convert tree contents to the (key, space-joined-value) representation that
+/// shell emitters consume.
+TEST(CompletionTreeTest, subcommandsByPathProjection)
+{
+  const auto tree = buildCompletionTree(makeSampleSpec());
+  const auto kv = subcommandsByPath(tree);
+
+  ASSERT_EQ(kv.size(), 2U);
+  EXPECT_EQ(kv[0].first, "sen");
+  EXPECT_EQ(kv[0].second, "run");
+  EXPECT_EQ(kv[1].first, "sen run");
+  EXPECT_EQ(kv[1].second, "");
+}
+
+/// @test
+/// Per-option KVLists use "path|token" as the key.
+TEST(CompletionTreeTest, optionChoicesByKeyFormat)
+{
+  const auto tree = buildCompletionTree(makeSampleSpec());
+  const auto kv = optionChoicesByKey(tree);
+
+  ASSERT_EQ(kv.size(), 1U);
+  EXPECT_EQ(kv[0].first, "sen run|--preset");
+  EXPECT_EQ(kv[0].second, "shell explorer replay");
+}
+
+/// @test
+/// joinSpace produces the canonical space-joined form and copes with empty input.
+TEST(CompletionTreeTest, joinSpaceFormats)
+{
+  EXPECT_EQ(joinSpace({}), "");
+  EXPECT_EQ(joinSpace({"a"}), "a");
+  EXPECT_EQ(joinSpace({"a", "b", "c"}), "a b c");
+}
+
+}  // namespace completions
