diff --git a/apps/cli_common/include/sen/cli/spec.h b/apps/cli_common/include/sen/cli/spec.h
new file mode 100644
index 0000000..7335805
--- /dev/null
+++ b/apps/cli_common/include/sen/cli/spec.h
@@ -0,0 +1,109 @@
+// === spec.h =========================================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#ifndef SEN_APPS_CLI_COMMON_SPEC_H
+#define SEN_APPS_CLI_COMMON_SPEC_H
+
+// cli11
+#include <CLI/App.hpp>
+
+// std
+#include <string>
+#include <vector>
+
+// --------------------------------------------------------------------------------------------
+// Spec JSON format
+//
+// buildSpecJson produces a document with the following shape. The format is the sole contract
+// between each CLI binary (which emits it via --dump-spec) and the shell-completion generator
+// (cli_gen gen completions) that consumes it. Tools reading the spec should tolerate unknown
+// extra fields so additions do not break consumers.
+//
+//   {
+//     "name":               "sen run",           // display name from CLI::App::name()
+//     "path":               ["sen", "run"],      // subcommand path from root; tokens are the
+//                                                // leaf names of each enclosing app
+//     "description":        "Run a sen kernel",
+//     "allow_extras":       false,               // CLI::App::allow_extras()
+//     "require_subcommand": false,               // true if CLI::App::require_subcommand_min()>0
+//     "options": [
+//       {
+//         "kind":        "option",               // one of "option", "flag", "positional"
+//         "name":        "--preset",             // CLI11's get_name() form
+//         "long":        ["--preset"],           // long names, each with leading "--"
+//         "short":       [],                     // short names, each with leading "-"
+//         "description": "Preset name",
+//         "required":    false,
+//         "type_name":   "TEXT:{shell,explorer,replay}", // CLI11 type hint (see below)
+//         "choices":     ["shell", "explorer", "replay"], // set only by sen::cli::addChoice
+//         "deprecated":  false                   // true for hidden aliases (stage 3)
+//       }
+//     ],
+//     "subcommands": [ /* recursive: same shape */ ]
+//   }
+//
+// The "kind" field classifies options:
+//   - "positional": positional argument (no leading dashes; "type_name" describes it)
+//   - "flag":       boolean switch that takes no value
+//   - "option":     named option that consumes a value
+//
+// The "type_name" field mirrors CLI11's type hint and follows the form "<base>[:<validator>]".
+// Common suffixes: ":FILE" (existing file), ":DIR" (existing directory), ":PATH(existing)"
+// (existing path, file or directory), ":{a,b,c}" (IsMember choice set). Emitters look for
+// these suffixes to drive file / directory / choice completion.
+//
+// Built-in --help and --version flags are included in the spec alongside the tool's own
+// options; modern CLIs (docker, gh, terraform) surface them in shell completions and users
+// expect the same.
+// --------------------------------------------------------------------------------------------
+
+namespace sen::cli
+{
+
+/// Walks a configured CLI11 App tree and produces a JSON document describing subcommands,
+/// options, flags and positional arguments. Returned string is pretty-printed with a 2-space
+/// indent. See the block comment above for the exact schema.
+std::string buildSpecJson(const CLI::App& app);
+
+/// A choice value paired with a human-readable description, consumed by addChoice's described
+/// overload to carry per-value hints into the generated completion scripts.
+struct Choice
+{
+  std::string value;
+  std::string description;
+};
+
+/// Adds a choice-validated option to a CLI11 app and records the choice list so buildSpecJson
+/// can surface it under the option's "choices" field. Functionally equivalent to
+/// app.add_option(...)->check(CLI::IsMember(choices)); the difference is that the choices
+/// survive CLI11's validator encoding and reach the spec intact.
+CLI::Option* addChoice(CLI::App& app,
+                       const std::string& name,
+                       std::string& target,
+                       std::vector<std::string> choices,
+                       const std::string& description);
+
+/// Same as addChoice but attaches a human-readable description to each choice value. The
+/// descriptions surface in the generated completion scripts for shells that render per-
+/// candidate descriptions (zsh, fish, PowerShell).
+CLI::Option* addChoice(CLI::App& app,
+                       const std::string& name,
+                       std::string& target,
+                       std::vector<Choice> choices,
+                       const std::string& description);
+
+/// Checks argv for the `--dump-spec` flag. If present, prints the JSON spec of the given
+/// CLI11 app to stdout and exits the process with status 0. Otherwise returns without side
+/// effects.
+///
+/// Must be called after the app has been fully configured (all subcommands, options and flags
+/// registered) and before CLI11_PARSE runs.
+void dumpSpecIfRequested(int argc, char* argv[], const CLI::App& app);
+
+}  // namespace sen::cli
+
+#endif  // SEN_APPS_CLI_COMMON_SPEC_H
diff --git a/apps/cli_common/src/spec.cpp b/apps/cli_common/src/spec.cpp
new file mode 100644
index 0000000..56724f7
--- /dev/null
+++ b/apps/cli_common/src/spec.cpp
@@ -0,0 +1,220 @@
+// === spec.cpp =======================================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#include "sen/cli/spec.h"
+
+// cli11
+#include <CLI/App.hpp>
+#include <CLI/Option.hpp>
+#include <CLI/Validators.hpp>
+
+// nlohmann
+#include <nlohmann/json.hpp>
+
+// std
+#include <cstdlib>
+#include <iostream>
+#include <sstream>
+#include <string>
+#include <string_view>
+#include <unordered_map>
+#include <utility>
+#include <vector>
+
+namespace sen::cli
+{
+
+namespace
+{
+
+// --------------------------------------------------------------------------------------------
+// Choice side-table
+//
+// CLI11 stores IsMember validators but does not expose the original choice list, so addChoice
+// tucks it into a process-global map keyed by the returned Option pointer. buildSpecJson reads
+// this map to surface choices in the emitted JSON. Lifetime matches the process; CLI setup is
+// single-threaded so no synchronization is needed.
+// --------------------------------------------------------------------------------------------
+
+using ChoiceMap = std::unordered_map<const CLI::Option*, std::vector<Choice>>;
+
+ChoiceMap& choiceMap()
+{
+  static ChoiceMap map;
+  return map;
+}
+
+const std::vector<Choice>& choicesOf(const CLI::Option* option)
+{
+  static const std::vector<Choice> empty;
+  auto it = choiceMap().find(option);
+  return it == choiceMap().end() ? empty : it->second;
+}
+
+// --------------------------------------------------------------------------------------------
+// Spec builder
+// --------------------------------------------------------------------------------------------
+
+std::vector<std::string> withPrefix(const std::vector<std::string>& names, std::string_view prefix)
+{
+  std::vector<std::string> out;
+  out.reserve(names.size());
+  for (const auto& n: names)
+  {
+    out.emplace_back(std::string(prefix) + n);
+  }
+  return out;
+}
+
+nlohmann::json buildOptionJson(const CLI::Option& opt)
+{
+  nlohmann::json j;
+
+  j["kind"] = opt.get_positional()         ? "positional"
+              : opt.get_type_name().empty() ? "flag"
+                                            : "option";
+  j["name"] = opt.get_name();
+  j["long"] = withPrefix(opt.get_lnames(), "--");
+  j["short"] = withPrefix(opt.get_snames(), "-");
+  j["description"] = opt.get_description();
+  j["required"] = opt.get_required();
+  j["type_name"] = opt.get_type_name();
+
+  // Choices are stored in the side-table as (value, description) pairs. The spec surfaces the
+  // values as a flat array (unchanged schema) plus a parallel descriptions array; consumers
+  // that do not care about descriptions can read `choices` alone.
+  const auto& choices = choicesOf(&opt);
+  std::vector<std::string> values;
+  std::vector<std::string> descriptions;
+  values.reserve(choices.size());
+  descriptions.reserve(choices.size());
+  for (const auto& c: choices)
+  {
+    values.push_back(c.value);
+    descriptions.push_back(c.description);
+  }
+  j["choices"] = values;
+  j["choiceDescriptions"] = descriptions;
+
+  // An empty CLI11 group marks an option as hidden from --help; by convention the sen CLI
+  // uses this to flag deprecated aliases. Completion scripts skip entries with deprecated=true.
+  j["deprecated"] = opt.get_group().empty();
+
+  return j;
+}
+
+/// Tokenizes a whitespace-separated app name like "sen run" into ["sen", "run"]. Root binaries
+/// set a multi-word name via app.name() for friendly --help output; subcommands only store
+/// their leaf name (CLI11 does not expose a parent pointer).
+std::vector<std::string> tokenizeAppName(const std::string& name)
+{
+  std::vector<std::string> tokens;
+  std::istringstream iss(name);
+  std::string word;
+  while (iss >> word)
+  {
+    tokens.push_back(word);
+  }
+  return tokens;
+}
+
+nlohmann::json buildAppJson(const CLI::App& app, const std::vector<std::string>& path)
+{
+  nlohmann::json j;
+  j["name"] = app.get_name();
+  j["path"] = path;
+  j["description"] = app.get_description();
+  j["allow_extras"] = app.get_allow_extras();
+  j["require_subcommand"] = app.get_require_subcommand_min() > 0;
+  // Deprecated aliases are marked with an empty CLI11 group (which also hides them from
+  // --help). The completion walker filters subcommands with deprecated=true.
+  j["deprecated"] = app.get_group().empty();
+
+  // --help and --version are first-class options on every sen CLI, so they belong in the
+  // spec alongside the tool's own flags. Most modern tools (docker, gh, terraform) surface
+  // them in shell completions as well.
+  nlohmann::json options = nlohmann::json::array();
+  for (const auto* opt: app.get_options())
+  {
+    if (opt != nullptr)
+    {
+      options.push_back(buildOptionJson(*opt));
+    }
+  }
+  j["options"] = options;
+
+  nlohmann::json subs = nlohmann::json::array();
+  for (const auto* sub: app.get_subcommands({}))
+  {
+    if (sub == nullptr)
+    {
+      continue;
+    }
+    auto childPath = path;
+    childPath.push_back(sub->get_name());
+    subs.push_back(buildAppJson(*sub, childPath));
+  }
+  j["subcommands"] = subs;
+
+  return j;
+}
+
+}  // namespace
+
+std::string buildSpecJson(const CLI::App& app)
+{
+  const auto rootPath = tokenizeAppName(app.get_name());
+  return buildAppJson(app, rootPath).dump(2);
+}
+
+CLI::Option* addChoice(CLI::App& app,
+                       const std::string& name,
+                       std::string& target,
+                       std::vector<std::string> choices,
+                       const std::string& description)
+{
+  auto* option = app.add_option(name, target, description)->check(CLI::IsMember(choices));
+  std::vector<Choice> paired;
+  paired.reserve(choices.size());
+  for (auto& v: choices)
+  {
+    paired.push_back({std::move(v), ""});
+  }
+  choiceMap().emplace(option, std::move(paired));
+  return option;
+}
+
+CLI::Option* addChoice(CLI::App& app,
+                       const std::string& name,
+                       std::string& target,
+                       std::vector<Choice> choices,
+                       const std::string& description)
+{
+  std::vector<std::string> values;
+  values.reserve(choices.size());
+  for (const auto& c: choices)
+  {
+    values.push_back(c.value);
+  }
+  auto* option = app.add_option(name, target, description)->check(CLI::IsMember(values));
+  choiceMap().emplace(option, std::move(choices));
+  return option;
+}
+
+void dumpSpecIfRequested(int argc, char* argv[], const CLI::App& app)
+{
+  for (int i = 1; i < argc; ++i)
+  {
+    if (std::string_view(argv[i]) == "--dump-spec")  // NOLINT(cppcoreguidelines-pro-bounds-pointer-arithmetic)
+    {
+      std::cout << buildSpecJson(app) << '\n';
+      std::exit(EXIT_SUCCESS);
+    }
+  }
+}
+
+}  // namespace sen::cli
