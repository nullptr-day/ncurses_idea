@@ -0,0 +1,93 @@
+// === completions_generator.cpp ======================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#include "completions_generator.h"
+
+// app
+#include "completion_tree.h"
+#include "spec_merge.h"
+
+// nlohmann
+#include <nlohmann/json.hpp>
+
+// std
+#include <filesystem>
+#include <fstream>
+#include <memory>
+#include <stdexcept>
+#include <string>
+#include <vector>
+
+namespace
+{
+
+struct Args
+{
+  std::vector<std::filesystem::path> specFiles;
+  std::filesystem::path outDir;
+};
+
+nlohmann::json readJsonFile(const std::filesystem::path& path)
+{
+  std::ifstream file(path);
+  if (!file.is_open())
+  {
+    throw std::runtime_error("completions: cannot open spec file: " + path.string());
+  }
+  nlohmann::json j;
+  file >> j;
+  return j;
+}
+
+void writeScript(const std::filesystem::path& outDir,
+                 const std::string& fileName,
+                 completions::Shell shell,
+                 const nlohmann::json& merged)
+{
+  std::filesystem::create_directories(outDir);
+  const auto outPath = outDir / fileName;
+  std::ofstream out(outPath);
+  if (!out.is_open())
+  {
+    throw std::runtime_error("completions: cannot write " + outPath.string());
+  }
+  completions::emit(shell, merged, out);
+}
+
+}  // namespace
+
+void CompletionsGenerator::setup(CLI::App& app)
+{
+  auto args = std::make_shared<Args>();
+  // Invoked only by Sen's CMake tooling (see apps/cli_gen/CMakeLists.txt) to render the shell
+  // scripts at build time. Hidden from --help and completion; real users install completions
+  // via 'sen completion <shell>' instead.
+  auto cmd = app.add_subcommand("completions", "Render shell completion scripts from per-binary specs");
+  cmd->group("");
+  cmd->add_option("--spec", args->specFiles, "CLI spec JSON file (repeatable)")
+    ->required()
+    ->check(CLI::ExistingFile);
+  cmd->add_option("--out-dir", args->outDir, "Directory to write completion scripts into")->required();
+
+  cmd->callback(
+    [args]()
+    {
+      std::vector<nlohmann::json> specs;
+      specs.reserve(args->specFiles.size());
+      for (const auto& path: args->specFiles)
+      {
+        specs.push_back(readJsonFile(path));
+      }
+
+      const auto merged = completions::mergeSpecs(specs);
+
+      writeScript(args->outDir, "sen.bash", completions::Shell::bash, merged);
+      writeScript(args->outDir, "_sen", completions::Shell::zsh, merged);
+      writeScript(args->outDir, "sen.fish", completions::Shell::fish, merged);
+      writeScript(args->outDir, "sen.ps1", completions::Shell::powershell, merged);
+    });
+}
