+// === spec_merge_test.cpp ============================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#include "completions/spec_merge.h"
+
+// nlohmann
+#include <nlohmann/json.hpp>
+
+// google test
+#include <gtest/gtest.h>
+
+// std
+#include <stdexcept>
+
+namespace completions
+{
+
+namespace
+{
+
+nlohmann::json rootSpec()
+{
+  return nlohmann::json::parse(R"JSON({
+    "name": "sen",
+    "path": ["sen"],
+    "subcommands": [
+      { "name": "run",  "path": ["sen","run"],  "options": [], "subcommands": [] },
+      { "name": "gen",  "path": ["sen","gen"],  "options": [], "subcommands": [] }
+    ]
+  })JSON");
+}
+
+nlohmann::json runSpec()
+{
+  return nlohmann::json::parse(R"JSON({
+    "name": "sen run",
+    "path": ["sen", "run"],
+    "allow_extras": true,
+    "require_subcommand": false,
+    "options": [
+      { "kind": "option", "name": "--preset", "long": ["--preset"], "short": [],
+        "type_name": "TEXT", "choices": ["shell","explorer"], "required": false,
+        "description": "", "deprecated": false }
+    ],
+    "subcommands": []
+  })JSON");
+}
+
+}  // namespace
+
+/// @test
+/// A child spec's options and subcommands replace the matching placeholder under the root.
+TEST(SpecMergeTest, graftsChildUnderMatchingSubcommand)
+{
+  const auto merged = mergeSpecs({rootSpec(), runSpec()});
+
+  ASSERT_TRUE(merged.contains("subcommands"));
+  const auto& subs = merged["subcommands"];
+  ASSERT_EQ(subs.size(), 2U);
+
+  const auto& run = subs[0];
+  EXPECT_EQ(run["name"], "run");
+  ASSERT_EQ(run["options"].size(), 1U);
+  EXPECT_EQ(run["options"][0]["name"], "--preset");
+  EXPECT_EQ(run["allow_extras"], true);
+}
+
+/// @test
+/// A child spec whose path does not match any slot in the root is silently ignored, not applied
+/// somewhere else. (Protects against a renamed binary corrupting the tree.)
+TEST(SpecMergeTest, childWithUnknownPathIsIgnored)
+{
+  auto stray = runSpec();
+  stray["name"] = "sen unknown";
+  stray["path"] = nlohmann::json::array({"sen", "unknown"});
+
+  const auto merged = mergeSpecs({rootSpec(), stray});
+
+  // Root children untouched; "run" has its original (empty) options, not stray's.
+  const auto& subs = merged["subcommands"];
+  ASSERT_EQ(subs.size(), 2U);
+  EXPECT_EQ(subs[0]["name"], "run");
+  EXPECT_TRUE(subs[0]["options"].empty());
+}
+
+/// @test
+/// Order of specs in the input vector does not matter; the root can appear anywhere.
+TEST(SpecMergeTest, rootCanAppearAnywhereInInput)
+{
+  const auto merged = mergeSpecs({runSpec(), rootSpec()});
+  ASSERT_EQ(merged.value("name", ""), "sen");
+  EXPECT_EQ(merged["subcommands"][0]["options"][0]["name"], "--preset");
+}
+
+/// @test
+/// Missing root spec is a hard error.
+TEST(SpecMergeTest, throwsWhenRootMissing)
+{
+  EXPECT_THROW(mergeSpecs({runSpec()}), std::runtime_error);
+}
+
+}  // namespace completions
