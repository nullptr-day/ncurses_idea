+++ b/apps/cli_gen/test/completions/emitters_test.cpp
@@ -0,0 +1,131 @@
+// === emitters_test.cpp ==============================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#include "completions/completion_tree.h"
+
+// nlohmann
+#include <nlohmann/json.hpp>
+
+// google test
+#include <gtest/gtest.h>
+
+// std
+#include <sstream>
+#include <string>
+
+namespace completions
+{
+
+namespace
+{
+
+nlohmann::json trivialSpec()
+{
+  return nlohmann::json::parse(R"JSON({
+    "name": "sen",
+    "path": ["sen"],
+    "allow_extras": false,
+    "require_subcommand": false,
+    "options": [],
+    "subcommands": [
+      {
+        "name": "run",
+        "path": ["sen","run"],
+        "allow_extras": true,
+        "require_subcommand": false,
+        "options": [
+          { "kind": "option", "name": "--preset", "long": ["--preset"], "short": [],
+            "type_name": "TEXT", "choices": ["shell","explorer"], "required": false,
+            "description": "", "deprecated": false }
+        ],
+        "subcommands": []
+      }
+    ]
+  })JSON");
+}
+
+std::string renderFor(Shell shell)
+{
+  std::ostringstream oss;
+  emit(shell, trivialSpec(), oss);
+  return oss.str();
+}
+
+bool containsSubstring(const std::string& haystack, const std::string& needle)
+{
+  return haystack.find(needle) != std::string::npos;
+}
+
+}  // namespace
+
+/// @test
+/// The bash emitter declares every data section as an associative array. Spot-checking two
+/// (the first and one that exercises the registry iteration) is enough; the rest follow the
+/// same template expansion.
+TEST(EmittersTest, bashDeclaresDataSections)
+{
+  const auto script = renderFor(Shell::bash);
+  EXPECT_TRUE(containsSubstring(script, "declare -A _sen_subs=("));
+  EXPECT_TRUE(containsSubstring(script, "declare -A _sen_option_choices=("));
+}
+
+/// @test
+/// Subcommand names are emitted under the owning path.
+TEST(EmittersTest, bashSubcommandsMappedToParentPath)
+{
+  const auto script = renderFor(Shell::bash);
+  EXPECT_TRUE(containsSubstring(script, "[\"sen\"]=\"run\""));
+}
+
+/// @test
+/// A value-taking option with choices produces entries in both the option-type and
+/// option-choice tables, keyed by "path|token".
+TEST(EmittersTest, bashOptionChoicesKeyedByPathAndToken)
+{
+  const auto script = renderFor(Shell::bash);
+  EXPECT_TRUE(containsSubstring(script, "[\"sen run|--preset\"]=\"TEXT\""));
+  EXPECT_TRUE(containsSubstring(script, "[\"sen run|--preset\"]=\"shell explorer\""));
+}
+
+/// @test
+/// The walker + dispatch logic are emitted verbatim at the end.
+TEST(EmittersTest, bashEmitsCompletionRegistration)
+{
+  const auto script = renderFor(Shell::bash);
+  EXPECT_TRUE(containsSubstring(script, "complete -F _sen_complete sen"));
+}
+
+/// @test
+/// Every shell produces output that includes the subcommand name from the spec. This is a
+/// sanity check that the template-plus-context wiring is alive for all four shells, without
+/// coupling the test to each shell's syntax.
+TEST(EmittersTest, everyShellMentionsRegisteredSubcommand)
+{
+  for (auto shell: {Shell::bash, Shell::zsh, Shell::fish, Shell::powershell})
+  {
+    std::ostringstream oss;
+    emit(shell, trivialSpec(), oss);
+    EXPECT_TRUE(containsSubstring(oss.str(), "run")) << "shell enum value: " << static_cast<int>(shell);
+  }
+}
+
+/// @test
+/// The PowerShell emitter escapes single quotes in data values (since the generated syntax
+/// wraps keys/values in single quotes).
+TEST(EmittersTest, powerShellEscapesSingleQuotes)
+{
+  // Craft a spec with a single quote in a choice value; verify the emitted script doubles it.
+  auto spec = trivialSpec();
+  auto& opt = spec["subcommands"][0]["options"][0];
+  opt["choices"] = nlohmann::json::array({"it's"});
+
+  std::ostringstream oss;
+  emit(Shell::powershell, spec, oss);
+  EXPECT_TRUE(containsSubstring(oss.str(), "it''s"));
+}
+
+}  // namespace completions
