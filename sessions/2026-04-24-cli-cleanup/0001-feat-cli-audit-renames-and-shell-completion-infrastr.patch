+// === spec_merge.h ===================================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#ifndef SEN_APPS_CLI_GEN_COMPLETIONS_SPEC_MERGE_H
+#define SEN_APPS_CLI_GEN_COMPLETIONS_SPEC_MERGE_H
+
+// The input JSON shape operated on by mergeSpecs is documented in
+// apps/cli_common/include/sen/cli/spec.h (the producer).
+
+// nlohmann
+#include <nlohmann/json.hpp>
+
+// std
+#include <vector>
+
+namespace completions
+{
+
+/// Builds the merged spec tree from the per-binary specs. The root of the merged tree is the
+/// spec whose name is "sen" (i.e. cli_sen's dump). Every other spec is grafted into the root's
+/// subcommand hierarchy at the location indicated by its "path" array: for a spec with
+/// path=["sen","run"], root.subcommands[name=="run"] has its options and subcommand list
+/// replaced with that spec's.
+///
+/// Throws std::runtime_error if the "sen" root spec is not present in the input.
+nlohmann::json mergeSpecs(const std::vector<nlohmann::json>& specs);
+
+}  // namespace completions
+
+#endif  // SEN_APPS_CLI_GEN_COMPLETIONS_SPEC_MERGE_H
diff --git a/apps/cli_gen/src/completions/templates/bash.j2 b/apps/cli_gen/src/completions/templates/bash.j2
new file mode 100644
index 0000000..f6cd6cc
--- /dev/null
+++ b/apps/cli_gen/src/completions/templates/bash.j2
@@ -0,0 +1,117 @@
+# sen completion for bash (requires bash >= 4)
+# Generated by 'sen gen completions'. Do not edit by hand.
+
+## for section in sections
+declare -A {{ section.var_name }}=(
+## for entry in section.entries
+  ["{{ entry.key }}"]="{{ entry.value }}"
+## endfor
+)
+
+## endfor
+_sen_complete_by_type() {
+  local type=$1
+  local cur=$2
+  if [[ "$type" == *":DIR"* ]]; then
+    COMPREPLY+=( $(compgen -d -- "$cur") )
+  elif [[ "$type" == *":FILE"* ]] || [[ "$type" == *":PATH(existing)"* ]] || [[ "$type" == *":PATH"* ]]; then
+    COMPREPLY+=( $(compgen -f -- "$cur") )
+  fi
+}
+
+# Emit option/flag candidates for the given path, filtering out any flag that has already
+# been typed. Value-taking options (opts_val) are never filtered because they may repeat
+# (e.g. '-i path1 -i path2'); even single-value options are safe to re-offer.
+_sen_emit_opts() {
+  local path="$1"
+  local cur="$2"
+  local typed=" $3 "
+  local all="${_sen_opts[$path]}"
+  [[ -z "$all" ]] && return
+  local filtered=""
+  for name in $all; do
+    if [[ "$typed" != *" $name "* ]]; then
+      filtered="$filtered $name"
+    fi
+  done
+  COMPREPLY+=( $(compgen -W "$filtered" -- "$cur") )
+}
+
+_sen_complete() {
+  local cword=$COMP_CWORD
+  local cur="${COMP_WORDS[cword]}"
+  local prev=""
+  if (( cword > 0 )); then
+    prev="${COMP_WORDS[cword-1]}"
+  fi
+
+  local path="sen"
+  local i=1
+  while (( i < cword )); do
+    local w="${COMP_WORDS[i]}"
+    if [[ "$w" == -* ]]; then
+      local vlist="${_sen_opts_val[$path]}"
+      if [[ " $vlist " == *" $w "* ]]; then
+        (( i++ ))
+      fi
+      (( i++ ))
+      continue
+    fi
+    local subs="${_sen_subs[$path]}"
+    if [[ " $subs " == *" $w "* ]]; then
+      path="$path $w"
+    fi
+    (( i++ ))
+  done
+
+  # Collect already-typed flags (non-value-taking tokens) so _sen_emit_opts can filter them.
+  local typed_flags=""
+  local vlist_here="${_sen_opts_val[$path]}"
+  local k=1
+  while (( k < cword )); do
+    local tok="${COMP_WORDS[k]}"
+    if [[ "$tok" == -* ]] && [[ " $vlist_here " != *" $tok "* ]]; then
+      typed_flags="$typed_flags $tok"
+    fi
+    (( k++ ))
+  done
+
+  COMPREPLY=()
+
+  if [[ "$prev" == -* ]]; then
+    local vlist="${_sen_opts_val[$path]}"
+    if [[ " $vlist " == *" $prev "* ]]; then
+      local key="$path|$prev"
+      local choices="${_sen_option_choices[$key]}"
+      if [[ -n "$choices" ]]; then
+        COMPREPLY=( $(compgen -W "$choices" -- "$cur") )
+      else
+        _sen_complete_by_type "${_sen_option_type[$key]}" "$cur"
+      fi
+      return
+    fi
+  fi
+
+  if [[ "$cur" == -* ]]; then
+    _sen_emit_opts "$path" "$cur" "$typed_flags"
+    return
+  fi
+
+  local subs="${_sen_subs[$path]}"
+  if [[ -n "$subs" ]]; then
+    COMPREPLY+=( $(compgen -W "$subs" -- "$cur") )
+  fi
+  local pchoices="${_sen_positional_choices[$path]}"
+  if [[ -n "$pchoices" ]]; then
+    COMPREPLY+=( $(compgen -W "$pchoices" -- "$cur") )
+  fi
+  local ptype="${_sen_positional_type[$path]}"
+  if [[ -n "$ptype" ]]; then
+    _sen_complete_by_type "$ptype" "$cur"
+  fi
+  # Also offer flags alongside subcommands/positional; sen's flag surface is small enough
+  # that flags do not drown out other candidates.
+  _sen_emit_opts "$path" "$cur" "$typed_flags"
+}
+
+complete -F _sen_complete sen
