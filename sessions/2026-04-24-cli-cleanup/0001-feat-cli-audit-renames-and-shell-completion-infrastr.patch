+++ b/apps/cli_gen/src/completions/templates/fish.j2
@@ -0,0 +1,128 @@
+# sen completion for fish
+# Generated by 'sen gen completions'. Do not edit by hand.
+
+## for section in sections
+function {{ section.var_name }}
+    switch $argv[1]
+## for entry in section.entries
+        case '{{ entry.key }}'
+            echo '{{ entry.value }}'
+## endfor
+    end
+end
+
+## if section.has_items
+function {{ section.var_name }}_desc
+    switch $argv[1]
+## for entry in section.entries
+        case '{{ entry.key }}'
+## for item in entry.items
+            printf '%s\t%s\n' '{{ item.name }}' '{{ item.description }}'
+## endfor
+## endfor
+    end
+end
+
+## endif
+## endfor
+function __sen_complete_by_type
+    set -l type $argv[1]
+    set -l cur $argv[2]
+    if string match -q '*:DIR*' -- $type
+        __fish_complete_directories $cur
+    else if string match -q '*:FILE*' -- $type; or string match -q '*:PATH*' -- $type
+        __fish_complete_path $cur
+    end
+end
+
+# Emit option/flag candidates for the given path, filtering out any flag that has already
+# been typed. Value-taking options (opts_val) are never filtered because they may repeat
+# (e.g. '-i path1 -i path2'); even single-value options are safe to re-offer.
+function __sen_emit_opts
+    set -l path $argv[1]
+    set -l typed " $argv[2] "
+    for line in (__sen_opts_desc "$path")
+        set -l name (string split -m 1 \t -- $line)[1]
+        if not string match -q -- "* $name *" "$typed"
+            echo $line
+        end
+    end
+end
+
+function __sen_complete
+    set -l cmd (commandline -opc)
+    set -l cur (commandline -ct)
+    set -l cmd_count (count $cmd)
+
+    set -l path "sen"
+    set -l i 2
+    while test $i -le $cmd_count
+        set -l w $cmd[$i]
+        if string match -q -- '-*' $w
+            set -l vlist (__sen_opts_val "$path")
+            if string match -q -- "* $w *" " $vlist "
+                set i (math $i + 1)
+            end
+            set i (math $i + 1)
+            continue
+        end
+        set -l subs (__sen_subs "$path")
+        if string match -q -- "* $w *" " $subs "
+            set path "$path $w"
+        end
+        set i (math $i + 1)
+    end
+
+    # Collect already-typed flags at the resolved path so __sen_emit_opts can filter them.
+    set -l typed_flags ""
+    set -l vlist_here (__sen_opts_val "$path")
+    set -l k 2
+    while test $k -le $cmd_count
+        set -l tok $cmd[$k]
+        if string match -q -- '-*' $tok
+            if not string match -q -- "* $tok *" " $vlist_here "
+                set typed_flags "$typed_flags $tok"
+            end
+        end
+        set k (math $k + 1)
+    end
+
+    set -l prev ""
+    if test $cmd_count -ge 2
+        set prev $cmd[$cmd_count]
+    end
+
+    if string match -q -- '-*' $prev
+        set -l vlist (__sen_opts_val "$path")
+        if string match -q -- "* $prev *" " $vlist "
+            set -l key "$path|$prev"
+            set -l choices (__sen_option_choices "$key")
+            if test -n "$choices"
+                __sen_option_choices_desc "$key"
+            else
+                __sen_complete_by_type (__sen_option_type "$key") $cur
+            end
+            return
+        end
+    end
+
+    if string match -q -- '-*' $cur
+        __sen_emit_opts "$path" "$typed_flags"
+        return
+    end
+
+    __sen_subs_desc "$path"
+    set -l pchoices (__sen_positional_choices "$path")
+    for c in (string split ' ' -- $pchoices)
+        test -n "$c"; and echo $c
+    end
+    set -l ptype (__sen_positional_type "$path")
+    if test -n "$ptype"
+        __sen_complete_by_type $ptype $cur
+    end
+    # Also offer flags alongside subcommands/positional; sen's flag surface is small enough
+    # that flags do not drown out other candidates.
+    __sen_emit_opts "$path" "$typed_flags"
+end
+
+complete -c sen -f -a '(__sen_complete)'
