new file mode 100644
index 0000000..c18d679
--- /dev/null
+++ b/apps/cli_gen/src/completions/emitters.cpp
@@ -0,0 +1,141 @@
+// === emitters.cpp ===================================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#include "completion_tree.h"
+
+// generated code
+#include "completions_templates/bash.h"
+#include "completions_templates/fish.h"
+#include "completions_templates/powershell.h"
+#include "completions_templates/zsh.h"
+
+// sen
+#include "sen/core/base/compiler_macros.h"
+#include "sen/core/base/hash32.h"
+#include "sen/core/base/string_case.h"
+
+// inja
+#include <inja/environment.hpp>
+
+// std
+#include <string>
+#include <string_view>
+
+namespace completions
+{
+
+namespace
+{
+
+/// PowerShell single-quoted strings escape an embedded apostrophe by doubling it.
+std::string escapeSingleQuotes(std::string_view s)
+{
+  std::string out;
+  out.reserve(s.size());
+  for (auto c: s)
+  {
+    if (c == '\'')
+    {
+      out.append("''");
+    }
+    else
+    {
+      out.push_back(c);
+    }
+  }
+  return out;
+}
+
+/// zsh's _describe parses each element as "name:description"; a raw ':' or '\\' inside the
+/// description confuses the parser. Escape both.
+std::string escapeZshDescription(std::string_view s)
+{
+  std::string out;
+  out.reserve(s.size());
+  for (auto c: s)
+  {
+    if (c == '\\' || c == ':')
+    {
+      out.push_back('\\');
+    }
+    out.push_back(c);
+  }
+  return out;
+}
+
+/// The PowerShell templates embed descriptions inside 'name|description' single-quoted array
+/// entries, so '|' is reserved as the separator. Also escape single quotes (doubled).
+std::string escapePowerShellDescription(std::string_view s)
+{
+  std::string out;
+  out.reserve(s.size());
+  for (auto c: s)
+  {
+    if (c == '\'')
+    {
+      out.append("''");
+    }
+    else if (c == '|')
+    {
+      // Unlikely in Sen descriptions today; guard anyway. A backslash would also work; we pick
+      // a visible replacement so the problem is spotted if a description ever introduces '|'.
+      out.push_back('/');
+    }
+    else
+    {
+      out.push_back(c);
+    }
+  }
+  return out;
+}
+
+struct ShellConfig
+{
+  const unsigned* templateData;
+  unsigned templateSize;
+  VarNameFn varName;
+  EscapeFn valueEscape;
+  EscapeFn descriptionEscape;
+};
+
+ShellConfig configFor(Shell shell)
+{
+  switch (shell)
+  {
+    case Shell::bash:
+      return {bash, bashSize,
+              [](const char* n) { return std::string("_sen_") + n; },
+              nullptr, nullptr};
+    case Shell::zsh:
+      return {zsh, zshSize,
+              [](const char* n) { return std::string("_sen_") + n; },
+              nullptr, escapeZshDescription};
+    case Shell::fish:
+      return {fish, fishSize,
+              [](const char* n) { return std::string("__sen_") + n; },
+              nullptr, nullptr};
+    case Shell::powershell:
+      return {powershell, powershellSize,
+              [](const char* n) { return "Sen" + sen::toPascalCase(n); },
+              escapeSingleQuotes, escapePowerShellDescription};
+  }
+  SEN_UNREACHABLE();
+}
+
+}  // namespace
+
+void emit(Shell shell, const nlohmann::json& mergedSpec, std::ostream& out)
+{
+  const auto tree = buildCompletionTree(mergedSpec);
+  const auto cfg = configFor(shell);
+  const auto ctx = buildSectionsContext(tree, cfg.varName, cfg.valueEscape, cfg.descriptionEscape);
+
+  inja::Environment env;
+  out << env.render(sen::decompressSymbolToString(cfg.templateData, cfg.templateSize), ctx);
+}
+
+}  // namespace completions
diff --git a/apps/cli_gen/src/completions/spec_merge.cpp b/apps/cli_gen/src/completions/spec_merge.cpp
new file mode 100644
index 0000000..3dab191
--- /dev/null
+++ b/apps/cli_gen/src/completions/spec_merge.cpp
@@ -0,0 +1,100 @@
+// === spec_merge.cpp =================================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#include "spec_merge.h"
+
+// nlohmann
+#include <nlohmann/json.hpp>
+
+// std
+#include <cstddef>
+#include <stdexcept>
+#include <string>
+#include <string_view>
+#include <vector>
+
+namespace completions
+{
+
+namespace
+{
+
+nlohmann::json* findSubcommand(nlohmann::json& parent, std::string_view name)
+{
+  if (!parent.contains("subcommands"))
+  {
+    return nullptr;
+  }
+  for (auto& sub: parent["subcommands"])
+  {
+    if (sub.value("name", "") == name)
+    {
+      return &sub;
+    }
+  }
+  return nullptr;
+}
+
+void graftChildSpec(nlohmann::json& root, const nlohmann::json& childSpec)
+{
+  const std::vector<std::string> path = childSpec.value("path", std::vector<std::string> {});
+  if (path.size() <= 1U)
+  {
+    return;  // childSpec IS the root (e.g. cli_sen); handled by mergeSpecs before this call.
+  }
+
+  nlohmann::json* node = &root;
+  for (std::size_t i = 1; i < path.size(); ++i)
+  {
+    auto* next = findSubcommand(*node, path[i]);
+    if (next == nullptr)
+    {
+      return;  // no matching slot; silently ignore (e.g. deprecated or unknown binary)
+    }
+    node = next;
+  }
+
+  for (const auto& key: {"options", "subcommands", "allow_extras", "require_subcommand"})
+  {
+    if (childSpec.contains(key))
+    {
+      (*node)[key] = childSpec[key];
+    }
+  }
+}
+
+}  // namespace
+
+nlohmann::json mergeSpecs(const std::vector<nlohmann::json>& specs)
+{
+  const nlohmann::json* rootSpec = nullptr;
+  for (const auto& spec: specs)
+  {
+    if (spec.value("name", "") == "sen")
+    {
+      rootSpec = &spec;
+      break;
+    }
+  }
+  if (rootSpec == nullptr)
+  {
+    throw std::runtime_error("completions: no spec with name 'sen' found (cli_sen spec is required)");
+  }
+
+  nlohmann::json merged = *rootSpec;
+  for (const auto& spec: specs)
+  {
+    if (&spec == rootSpec)
+    {
+      continue;
+    }
+    graftChildSpec(merged, spec);
+  }
+  return merged;
+}
+
+}  // namespace completions
