@@ -0,0 +1,128 @@
+#compdef sen
+# sen completion for zsh
+# Generated by 'sen gen completions'. Do not edit by hand.
+
+## for section in sections
+typeset -gA {{ section.var_name }}=(
+## for entry in section.entries
+  "{{ entry.key }}" "{{ entry.value }}"
+## endfor
+)
+
+## if section.has_items
+typeset -gA {{ section.var_name }}_desc=(
+## for entry in section.entries
+  "{{ entry.key }}" $'{% for item in entry.items %}{% if not loop.is_first %}\n{% endif %}{{ item.name }}:{{ item.description }}{% endfor %}'
+## endfor
+)
+
+## endif
+## endfor
+_sen_complete_by_type() {
+  local type=$1
+  if [[ "$type" == *":DIR"* ]]; then
+    _files -/
+  elif [[ "$type" == *":FILE"* ]] || [[ "$type" == *":PATH(existing)"* ]] || [[ "$type" == *":PATH"* ]]; then
+    _files
+  fi
+}
+
+# Emit option/flag candidates for the given path, filtering out any flag that the user already
+# typed. Value-taking options (opts_val) are never filtered; they may legitimately repeat
+# (e.g., '-i path1 -i path2'), and even single-value options do no harm when re-offered.
+_sen_emit_opts() {
+  local path="$1"
+  local typed=" $2 "
+  local raw="${_sen_opts_desc[$path]}"
+  [[ -z "$raw" ]] && return
+  local -a opts
+  opts=()
+  local line name
+  for line in "${(@f)raw}"; do
+    name="${line%%:*}"
+    if [[ "$typed" != *" $name "* ]]; then
+      opts+=("$line")
+    fi
+  done
+  _describe -V 'option' opts
+}
+
+_sen() {
+  local path="sen"
+  local i=2
+  while (( i < CURRENT )); do
+    local w="${words[i]}"
+    if [[ "$w" == -* ]]; then
+      local vlist="${_sen_opts_val[$path]}"
+      if [[ " $vlist " == *" $w "* ]]; then
+        (( i++ ))
+      fi
+      (( i++ ))
+      continue
+    fi
+    local subs="${_sen_subs[$path]}"
+    if [[ " $subs " == *" $w "* ]]; then
+      path="$path $w"
+    fi
+    (( i++ ))
+  done
+
+  # Collect already-typed flags at the resolved path so we can filter them from suggestions.
+  # Only non-value-taking tokens are tracked; value-taking options may legitimately repeat.
+  local typed_flags=""
+  local vlist="${_sen_opts_val[$path]}"
+  local k=2
+  while (( k < CURRENT )); do
+    local tok="${words[k]}"
+    if [[ "$tok" == -* ]] && [[ " $vlist " != *" $tok "* ]]; then
+      typed_flags="$typed_flags $tok"
+    fi
+    (( k++ ))
+  done
+
+  local cur="${words[CURRENT]}"
+  local prev=""
+  if (( CURRENT > 1 )); then
+    prev="${words[CURRENT-1]}"
+  fi
+
+  if [[ "$prev" == -* ]]; then
+    local vlist="${_sen_opts_val[$path]}"
+    if [[ " $vlist " == *" $prev "* ]]; then
+      local key="$path|$prev"
+      if [[ -n "${_sen_option_choices[$key]}" ]]; then
+        local -a choice_items
+        choice_items=("${(@f)_sen_option_choices_desc[$key]}")
+        _describe -V 'value' choice_items
+      else
+        _sen_complete_by_type "${_sen_option_type[$key]}"
+      fi
+      return
+    fi
+  fi
+
+  if [[ "$cur" == -* ]]; then
+    _sen_emit_opts "$path" "$typed_flags"
+    return
+  fi
+
+  local subs_raw="${_sen_subs_desc[$path]}"
+  if [[ -n "$subs_raw" ]]; then
+    local -a subs
+    subs=("${(@f)subs_raw}")
+    _describe -V 'subcommand' subs
+  fi
+  local pchoices="${_sen_positional_choices[$path]}"
+  if [[ -n "$pchoices" ]]; then
+    compadd -- ${=pchoices}
+  fi
+  local ptype="${_sen_positional_type[$path]}"
+  if [[ -n "$ptype" ]]; then
+    _sen_complete_by_type "$ptype"
+  fi
+  # Also offer flags even when the user has not typed a leading dash. sen's command surface is
+  # small enough that flags do not drown out subcommand/positional candidates.
+  _sen_emit_opts "$path" "$typed_flags"
+}
+
+compdef _sen sen
