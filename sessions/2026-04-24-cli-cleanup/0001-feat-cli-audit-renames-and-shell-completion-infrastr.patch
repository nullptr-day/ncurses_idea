diff --git a/apps/cli_common/test/spec_test.cpp b/apps/cli_common/test/spec_test.cpp
new file mode 100644
index 0000000..856f1fe
--- /dev/null
+++ b/apps/cli_common/test/spec_test.cpp
@@ -0,0 +1,198 @@
+// === spec_test.cpp ==================================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#include "sen/cli/spec.h"
+
+// cli11
+#include <CLI/App.hpp>
+#include <CLI/CLI.hpp>  // NOLINT(misc-include-cleaner): cli11 needs all headers for vtables
+#include <CLI/Validators.hpp>
+
+// nlohmann
+#include <nlohmann/json.hpp>
+
+// google test
+#include <gtest/gtest.h>
+
+// std
+#include <string>
+#include <tuple>
+
+namespace sen::cli
+{
+
+namespace
+{
+
+nlohmann::json dumpAs(const CLI::App& app)
+{
+  return nlohmann::json::parse(buildSpecJson(app));
+}
+
+const nlohmann::json* findOption(const nlohmann::json& spec, const std::string& name)
+{
+  for (const auto& opt: spec.at("options"))
+  {
+    if (opt.value("name", "") == name)
+    {
+      return &opt;
+    }
+    // Hidden options (empty CLI11 group) come back with get_name() = "" but still carry
+    // the long/short forms; match on those too so tests can locate them by their user-typed
+    // form regardless of visibility.
+    for (const auto& ln: opt.value("long", nlohmann::json::array()))
+    {
+      if (ln.get<std::string>() == name)
+      {
+        return &opt;
+      }
+    }
+  }
+  return nullptr;
+}
+
+}  // namespace
+
+/// @test
+/// Every registered option appears in the spec with its kind classified as option / flag /
+/// positional, and dashes are attached to the long and short forms.
+TEST(SpecTest, classifiesOptionsFlagsAndPositionals)
+{
+  CLI::App app {"test"};
+  app.name("sen test");
+
+  std::string target;
+  bool onoff = false;
+  std::string pos;
+  app.add_option("-i,--input", target, "Input file");
+  app.add_flag("--enable", onoff, "Turn feature on");
+  app.add_option("output", pos, "Output path");
+
+  const auto spec = dumpAs(app);
+
+  const auto* input = findOption(spec, "--input");
+  ASSERT_NE(input, nullptr);
+  EXPECT_EQ(input->at("kind"), "option");
+  EXPECT_EQ(input->at("long"), nlohmann::json::array({"--input"}));
+  EXPECT_EQ(input->at("short"), nlohmann::json::array({"-i"}));
+
+  const auto* enable = findOption(spec, "--enable");
+  ASSERT_NE(enable, nullptr);
+  EXPECT_EQ(enable->at("kind"), "flag");
+
+  const auto* output = findOption(spec, "output");
+  ASSERT_NE(output, nullptr);
+  EXPECT_EQ(output->at("kind"), "positional");
+}
+
+/// @test
+/// --help and --version appear in the spec alongside the tool's own flags. Most modern CLIs
+/// surface them in completion; sen matches that convention so users see them in TAB output.
+TEST(SpecTest, includesBuiltinHelpFlag)
+{
+  CLI::App app {"test"};
+  app.name("sen test");
+
+  const auto spec = dumpAs(app);
+  bool foundHelp = false;
+  for (const auto& opt: spec.at("options"))
+  {
+    const auto name = opt.value("name", "");
+    if (name.find("help") != std::string::npos)
+    {
+      foundHelp = true;
+    }
+  }
+  EXPECT_TRUE(foundHelp);
+}
+
+/// @test
+/// addChoice records the choice list in the spec so completion emitters can surface them.
+TEST(SpecTest, addChoiceSurfacesChoicesInSpec)
+{
+  CLI::App app {"test"};
+  app.name("sen test");
+
+  std::string target;
+  addChoice(app, "--preset", target, {"shell", "explorer", "replay"}, "Preset");
+
+  const auto spec = dumpAs(app);
+  const auto* preset = findOption(spec, "--preset");
+  ASSERT_NE(preset, nullptr);
+  EXPECT_EQ(preset->at("choices"), nlohmann::json::array({"shell", "explorer", "replay"}));
+}
+
+/// @test
+/// The spec encodes an explicit path array at every level; downstream consumers walk the tree
+/// by this array rather than parsing the display name.
+TEST(SpecTest, pathArrayTracksSubcommandHierarchy)
+{
+  CLI::App app {"test"};
+  app.name("sen test");
+  auto* sub = app.add_subcommand("child", "c");
+  sub->add_subcommand("grand", "g");
+
+  const auto spec = dumpAs(app);
+  EXPECT_EQ(spec.at("path"), nlohmann::json::array({"sen", "test"}));
+
+  const auto& child = spec.at("subcommands").at(0);
+  EXPECT_EQ(child.at("path"), nlohmann::json::array({"sen", "test", "child"}));
+
+  const auto& grand = child.at("subcommands").at(0);
+  EXPECT_EQ(grand.at("path"), nlohmann::json::array({"sen", "test", "child", "grand"}));
+}
+
+/// @test
+/// A subcommand or option placed in an empty CLI11 group is marked as deprecated in the spec.
+/// Completion scripts filter deprecated entries, so this is the mechanism the sen CLI uses to
+/// hide backward-compat aliases from TAB completion while keeping them functional.
+TEST(SpecTest, emptyGroupMarksDeprecated)
+{
+  CLI::App app {"test"};
+  app.name("sen test");
+
+  auto* hiddenSub = app.add_subcommand("old-alias", "Hidden alias");
+  hiddenSub->group("");
+
+  std::string value;
+  auto* hiddenOpt = app.add_option("--old-flag", value, "Hidden flag");
+  hiddenOpt->group("");
+
+  auto* visibleSub = app.add_subcommand("visible", "Normal subcommand");
+  std::string other;
+  auto* visibleOpt = app.add_option("--visible-flag", other, "Normal flag");
+
+  const auto spec = dumpAs(app);
+
+  const auto& subs = spec.at("subcommands");
+  for (const auto& sub: subs)
+  {
+    if (sub.at("name") == "old-alias")
+    {
+      EXPECT_TRUE(sub.at("deprecated").get<bool>());
+    }
+    else if (sub.at("name") == "visible")
+    {
+      EXPECT_FALSE(sub.at("deprecated").get<bool>());
+    }
+  }
+
+  const auto* oldFlag = findOption(spec, "--old-flag");
+  ASSERT_NE(oldFlag, nullptr);
+  EXPECT_TRUE(oldFlag->at("deprecated").get<bool>());
+
+  const auto* visibleFlag = findOption(spec, "--visible-flag");
+  ASSERT_NE(visibleFlag, nullptr);
+  EXPECT_FALSE(visibleFlag->at("deprecated").get<bool>());
+
+  std::ignore = hiddenSub;
+  std::ignore = hiddenOpt;
+  std::ignore = visibleSub;
+  std::ignore = visibleOpt;
+}
+
+}  // namespace sen::cli
