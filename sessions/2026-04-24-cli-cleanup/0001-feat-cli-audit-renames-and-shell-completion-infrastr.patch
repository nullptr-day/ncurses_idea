@@ -0,0 +1,132 @@
+# sen completion for PowerShell
+# Generated by 'sen gen completions'. Do not edit by hand.
+
+## for section in sections
+$script:{{ section.var_name }} = @{
+## for entry in section.entries
+  '{{ entry.key }}' = '{{ entry.value }}'
+## endfor
+}
+
+## if section.has_items
+$script:{{ section.var_name }}Desc = @{
+## for entry in section.entries
+  '{{ entry.key }}' = @(
+## for item in entry.items
+    '{{ item.name }}|{{ item.description }}'
+## endfor
+  )
+## endfor
+}
+
+## endif
+## endfor
+function Get-SenCompleteByType {
+    param($Type, $WordToComplete)
+    $results = @()
+    if ($Type -match ':DIR') {
+        $results = Get-ChildItem -Directory -Name "$WordToComplete*" -ErrorAction SilentlyContinue
+    }
+    elseif ($Type -match ':FILE' -or $Type -match ':PATH') {
+        $results = Get-ChildItem -Name "$WordToComplete*" -ErrorAction SilentlyContinue
+    }
+    foreach ($r in $results) {
+        [System.Management.Automation.CompletionResult]::new($r, $r, 'ProviderItem', $r)
+    }
+}
+
+function Emit-SenCandidates {
+    param($Items, $WordToComplete, $ResultType, $TypedFlags = '')
+    $typedPadded = " $TypedFlags "
+    foreach ($item in $Items) {
+        $parts = $item -split '\|', 2
+        $name = $parts[0]
+        if ($typedPadded.Contains(" $name ")) { continue }
+        $desc = if ($parts.Count -gt 1) { $parts[1] } else { $name }
+        if ($name -and $name.StartsWith($WordToComplete)) {
+            [System.Management.Automation.CompletionResult]::new($name, $name, $ResultType, $desc)
+        }
+    }
+}
+
+Register-ArgumentCompleter -Native -CommandName sen -ScriptBlock {
+    param($wordToComplete, $commandAst, $cursorPosition)
+
+    $words = @($commandAst.CommandElements | ForEach-Object { $_.ToString() })
+    $endsWithSpace = $cursorPosition -gt $commandAst.Extent.EndOffset
+
+    $path = 'sen'
+    $i = 1
+    $limit = $words.Count
+    if (-not $endsWithSpace) { $limit = $words.Count - 1 }
+    while ($i -lt $limit) {
+        $w = $words[$i]
+        if ($w.StartsWith('-')) {
+            $vlist = $script:SenOptsVal[$path]
+            if ($vlist -and (" $vlist ").Contains(" $w ")) { $i++ }
+            $i++
+            continue
+        }
+        $subs = $script:SenSubs[$path]
+        if ($subs -and (" $subs ").Contains(" $w ")) {
+            $path = "$path $w"
+        }
+        $i++
+    }
+
+    # Collect already-typed flags at the resolved path so flag suggestions can filter them.
+    # Value-taking options (present in SenOptsVal) are never tracked because they may repeat.
+    $typedFlags = ''
+    $vlistHere = $script:SenOptsVal[$path]
+    $m = 1
+    while ($m -lt $limit) {
+        $tok = $words[$m]
+        if ($tok.StartsWith('-') -and -not (" $vlistHere ").Contains(" $tok ")) {
+            $typedFlags = "$typedFlags $tok"
+        }
+        $m++
+    }
+
+    $prev = ''
+    if ($words.Count -ge 2) {
+        $prev = $words[$words.Count - 2]
+        if ($endsWithSpace) { $prev = $words[$words.Count - 1] }
+    }
+
+    if ($prev.StartsWith('-')) {
+        $vlist = $script:SenOptsVal[$path]
+        if ($vlist -and (" $vlist ").Contains(" $prev ")) {
+            $key = "$path|$prev"
+            $choices = $script:SenOptionChoices[$key]
+            if ($choices) {
+                Emit-SenCandidates $script:SenOptionChoicesDesc[$key] $wordToComplete 'ParameterValue'
+                return
+            }
+            Get-SenCompleteByType $script:SenOptionType[$key] $wordToComplete
+            return
+        }
+    }
+
+    if ($wordToComplete.StartsWith('-')) {
+        Emit-SenCandidates $script:SenOptsDesc[$path] $wordToComplete 'ParameterName' $typedFlags
+        return
+    }
+
+    Emit-SenCandidates $script:SenSubsDesc[$path] $wordToComplete 'Command'
+
+    $pchoices = $script:SenPositionalChoices[$path]
+    if ($pchoices) {
+        foreach ($c in ($pchoices -split ' ')) {
+            if ($c -and $c.StartsWith($wordToComplete)) {
+                [System.Management.Automation.CompletionResult]::new($c, $c, 'ParameterValue', $c)
+            }
+        }
+    }
+    $ptype = $script:SenPositionalType[$path]
+    if ($ptype) {
+        Get-SenCompleteByType $ptype $wordToComplete
+    }
+    # Also offer flags alongside subcommands/positional; sen's flag surface is small enough
+    # that flags do not drown out other candidates.
+    Emit-SenCandidates $script:SenOptsDesc[$path] $wordToComplete 'ParameterName' $typedFlags
+}
