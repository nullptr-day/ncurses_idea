diff --git a/apps/cli_gen/src/completions/completion_tree.cpp b/apps/cli_gen/src/completions/completion_tree.cpp
new file mode 100644
index 0000000..1173388
--- /dev/null
+++ b/apps/cli_gen/src/completions/completion_tree.cpp
@@ -0,0 +1,368 @@
+// === completion_tree.cpp ============================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#include "completion_tree.h"
+
+// nlohmann
+#include <nlohmann/json.hpp>
+
+// std
+#include <string>
+#include <string_view>
+#include <unordered_map>
+#include <utility>
+#include <vector>
+
+namespace completions
+{
+
+namespace
+{
+
+bool isDeprecated(const nlohmann::json& node)
+{
+  return node.value("deprecated", false);
+}
+
+std::vector<std::string> collectStrings(const nlohmann::json& arr)
+{
+  std::vector<std::string> out;
+  for (const auto& v: arr)
+  {
+    out.push_back(v.get<std::string>());
+  }
+  return out;
+}
+
+std::string joinPath(const nlohmann::json& pathArray)
+{
+  return joinSpace(collectStrings(pathArray));
+}
+
+void collectSubcommands(const nlohmann::json& node, NodeFacts& facts)
+{
+  for (const auto& sub: node.value("subcommands", nlohmann::json::array()))
+  {
+    if (!isDeprecated(sub))
+    {
+      facts.subcommands.push_back({sub.value("name", ""), sub.value("description", "")});
+    }
+  }
+}
+
+void collectPositional(const nlohmann::json& option, NodeFacts& facts)
+{
+  if (!facts.positionalType.empty() || !facts.positionalChoices.empty())
+  {
+    return;  // first positional wins; see TODO in completion_tree.h
+  }
+  facts.positionalType = option.value("type_name", "");
+  if (option.contains("choices"))
+  {
+    facts.positionalChoices = collectStrings(option["choices"]);
+  }
+}
+
+void collectOption(const nlohmann::json& option,
+                   std::string_view path,
+                   NodeFacts& facts,
+                   std::vector<OptionFacts>& optionEntries)
+{
+  std::vector<std::string> tokens = collectStrings(option.value("long", nlohmann::json::array()));
+  for (const auto& s: collectStrings(option.value("short", nlohmann::json::array())))
+  {
+    tokens.push_back(s);
+  }
+
+  const auto description = option.value("description", "");
+  const bool takesValue = option.value("kind", "") == "option";
+  for (const auto& tok: tokens)
+  {
+    facts.allOptionTokens.push_back({tok, description});
+    if (takesValue)
+    {
+      facts.optionsTakingValue.push_back({tok, description});
+    }
+  }
+
+  if (!takesValue)
+  {
+    return;
+  }
+  OptionFacts prototype;
+  prototype.path = std::string(path);
+  prototype.typeName = option.value("type_name", "");
+  // Spec carries choices and choiceDescriptions as parallel arrays; walker zips them into
+  // NamedEntry pairs. Undescribed choices (registered via the string-only addChoice overload)
+  // have an empty description.
+  const auto values = collectStrings(option.value("choices", nlohmann::json::array()));
+  const auto descriptions =
+    collectStrings(option.value("choiceDescriptions", nlohmann::json::array()));
+  prototype.choices.reserve(values.size());
+  for (std::size_t i = 0; i < values.size(); ++i)
+  {
+    const auto desc = i < descriptions.size() ? descriptions[i] : std::string();
+    prototype.choices.push_back({values[i], desc});
+  }
+  for (const auto& tok: tokens)
+  {
+    prototype.token = tok;
+    optionEntries.push_back(prototype);
+  }
+}
+
+void walk(const nlohmann::json& node, CompletionTree& tree)
+{
+  NodeFacts facts;
+  facts.path = joinPath(node.value("path", nlohmann::json::array()));
+
+  collectSubcommands(node, facts);
+
+  for (const auto& opt: node.value("options", nlohmann::json::array()))
+  {
+    if (isDeprecated(opt))
+    {
+      continue;
+    }
+    if (opt.value("kind", "") == "positional")
+    {
+      collectPositional(opt, facts);
+    }
+    else
+    {
+      collectOption(opt, facts.path, facts, tree.options);
+    }
+  }
+
+  tree.nodes.push_back(std::move(facts));
+
+  for (const auto& sub: node.value("subcommands", nlohmann::json::array()))
+  {
+    if (!isDeprecated(sub))
+    {
+      walk(sub, tree);
+    }
+  }
+}
+
+}  // namespace
+
+CompletionTree buildCompletionTree(const nlohmann::json& mergedSpec)
+{
+  CompletionTree tree;
+  walk(mergedSpec, tree);
+  return tree;
+}
+
+std::string joinSpace(const std::vector<std::string>& items)
+{
+  std::string out;
+  for (const auto& it: items)
+  {
+    if (!out.empty())
+    {
+      out += ' ';
+    }
+    out += it;
+  }
+  return out;
+}
+
+namespace
+{
+
+std::string joinSpaceNames(const std::vector<NamedEntry>& entries)
+{
+  std::string out;
+  for (const auto& e: entries)
+  {
+    if (!out.empty())
+    {
+      out += ' ';
+    }
+    out += e.name;
+  }
+  return out;
+}
+
+}  // namespace
+
+KVList subcommandsByPath(const CompletionTree& tree)
+{
+  KVList out;
+  out.reserve(tree.nodes.size());
+  for (const auto& node: tree.nodes)
+  {
+    out.emplace_back(node.path, joinSpaceNames(node.subcommands));
+  }
+  return out;
+}
+
+KVList optionTokensByPath(const CompletionTree& tree)
+{
+  KVList out;
+  out.reserve(tree.nodes.size());
+  for (const auto& node: tree.nodes)
+  {
+    out.emplace_back(node.path, joinSpaceNames(node.allOptionTokens));
+  }
+  return out;
+}
+
+KVList optionsTakingValueByPath(const CompletionTree& tree)
+{
+  KVList out;
+  out.reserve(tree.nodes.size());
+  for (const auto& node: tree.nodes)
+  {
+    out.emplace_back(node.path, joinSpaceNames(node.optionsTakingValue));
+  }
+  return out;
+}
+
+KVList positionalTypesByPath(const CompletionTree& tree)
+{
+  KVList out;
+  for (const auto& node: tree.nodes)
+  {
+    if (!node.positionalType.empty())
+    {
+      out.emplace_back(node.path, node.positionalType);
+    }
+  }
+  return out;
+}
+
+KVList positionalChoicesByPath(const CompletionTree& tree)
+{
+  KVList out;
+  for (const auto& node: tree.nodes)
+  {
+    if (!node.positionalChoices.empty())
+    {
+      out.emplace_back(node.path, joinSpace(node.positionalChoices));
+    }
+  }
+  return out;
+}
+
+KVList optionTypesByKey(const CompletionTree& tree)
+{
+  KVList out;
+  out.reserve(tree.options.size());
+  for (const auto& od: tree.options)
+  {
+    out.emplace_back(od.path + '|' + od.token, od.typeName);
+  }
+  return out;
+}
+
+KVList optionChoicesByKey(const CompletionTree& tree)
+{
+  KVList out;
+  out.reserve(tree.options.size());
+  for (const auto& od: tree.options)
+  {
+    out.emplace_back(od.path + '|' + od.token, joinSpaceNames(od.choices));
+  }
+  return out;
+}
+
+ItemsByPath optionChoiceItemsByKey(const CompletionTree& tree)
+{
+  ItemsByPath out;
+  out.reserve(tree.options.size());
+  for (const auto& od: tree.options)
+  {
+    out.emplace_back(od.path + '|' + od.token, od.choices);
+  }
+  return out;
+}
+
+ItemsByPath subcommandItemsByPath(const CompletionTree& tree)
+{
+  ItemsByPath out;
+  out.reserve(tree.nodes.size());
+  for (const auto& node: tree.nodes)
+  {
+    out.emplace_back(node.path, node.subcommands);
+  }
+  return out;
+}
+
+ItemsByPath optionTokenItemsByPath(const CompletionTree& tree)
+{
+  ItemsByPath out;
+  out.reserve(tree.nodes.size());
+  for (const auto& node: tree.nodes)
+  {
+    out.emplace_back(node.path, node.allOptionTokens);
+  }
+  return out;
+}
+
+ItemsByPath optionsTakingValueItemsByPath(const CompletionTree& tree)
+{
+  ItemsByPath out;
+  out.reserve(tree.nodes.size());
+  for (const auto& node: tree.nodes)
+  {
+    out.emplace_back(node.path, node.optionsTakingValue);
+  }
+  return out;
+}
+
+nlohmann::json buildSectionsContext(const CompletionTree& tree,
+                                    const VarNameFn& varNameFn,
+                                    const EscapeFn& valueEscape,
+                                    const EscapeFn& descriptionEscape)
+{
+  auto applyValue = [&](std::string_view s) -> std::string
+  { return valueEscape ? valueEscape(s) : std::string(s); };
+  auto applyDesc = [&](std::string_view s) -> std::string
+  { return descriptionEscape ? descriptionEscape(s) : std::string(s); };
+
+  nlohmann::json sections = nlohmann::json::array();
+  for (const auto& section: dataSections)
+  {
+    // Keep `sectionItems` alive for the full section body so the map below can safely hold
+    // pointers into it.
+    const auto sectionItems =
+      section.itemsGetter != nullptr ? section.itemsGetter(tree) : ItemsByPath {};
+    std::unordered_map<std::string, const std::vector<NamedEntry>*> itemsByPath;
+    for (const auto& [path, entries]: sectionItems)
+    {
+      itemsByPath.emplace(path, &entries);
+    }
+
+    nlohmann::json entries = nlohmann::json::array();
+    for (const auto& [k, v]: section.getter(tree))
+    {
+      nlohmann::json entry = {{"key", applyValue(k)}, {"value", applyValue(v)}};
+      const auto it = itemsByPath.find(k);
+      if (it != itemsByPath.end())
+      {
+        nlohmann::json items = nlohmann::json::array();
+        for (const auto& e: *it->second)
+        {
+          items.push_back({{"name", applyValue(e.name)}, {"description", applyDesc(e.description)}});
+        }
+        entry["items"] = items;
+      }
+      entries.push_back(std::move(entry));
+    }
+    sections.push_back({{"var_name", varNameFn(section.logicalName)},
+                        {"has_items", section.itemsGetter != nullptr},
+                        {"entries", entries}});
+  }
+
+  nlohmann::json ctx;
+  ctx["sections"] = sections;
+  return ctx;
+}
+
+}  // namespace completions
diff --git a/apps/cli_gen/src/completions/completion_tree.h b/apps/cli_gen/src/completions/completion_tree.h
new file mode 100644
index 0000000..9e3a881
--- /dev/null
+++ b/apps/cli_gen/src/completions/completion_tree.h
@@ -0,0 +1,206 @@
+// === completion_tree.h ==============================================================================================
+//                                               Sen Infrastructure
+//                   Released under the Apache License v2.0 (SPDX-License-Identifier Apache-2.0).
+//                                    See the LICENSE.txt file for more information.
+//                   © Airbus SAS, Airbus Helicopters, and Airbus Defence and Space SAU/GmbH/SAS.
+// =====================================================================================================================
+
+#ifndef SEN_APPS_CLI_GEN_COMPLETIONS_COMPLETION_TREE_H
+#define SEN_APPS_CLI_GEN_COMPLETIONS_COMPLETION_TREE_H
+
+// The input JSON shape consumed by this module is documented in
+// apps/cli_common/include/sen/cli/spec.h (the producer). Look there for the field list and
+// value conventions ("kind", "type_name" suffixes, etc.).
+
+// nlohmann
+#include <nlohmann/json.hpp>
+
+// std
+#include <array>
+#include <functional>
+#include <iosfwd>
+#include <string>
+#include <string_view>
+#include <utility>
+#include <vector>
+
+namespace completions
+{
+
+/// A completion candidate carrying both the literal token to insert and its human-readable
+/// description. Shells that support inline descriptions (zsh, fish, PowerShell) render the
+/// description alongside the candidate; bash ignores it (bash has no native description UI).
+struct NamedEntry
+{
+  std::string name;
+  std::string description;
+};
+
+struct NodeFacts
+{
+  /// Space-joined key used to index each node; e.g. "sen", "sen run", "sen gen cpp".
+  std::string path;
+
+  /// Non-deprecated subcommand names valid at this path (with their descriptions).
+  std::vector<NamedEntry> subcommands;
+
+  /// Non-deprecated option/flag tokens (long + short, with leading dashes). Each long or
+  /// short form is a separate entry carrying the same description as its owning option.
+  std::vector<NamedEntry> allOptionTokens;
+
+  /// Subset of allOptionTokens that consume a value argument.
+  std::vector<NamedEntry> optionsTakingValue;
+
+  /// CLI11 type_name of the first positional argument at this path (empty if none). Subsequent
+  /// positionals at the same node are ignored: no current sen command takes more than one
+  /// heterogeneous positional. If that changes, promote this to std::vector<std::string> and
+  /// teach the shell walker to count how many positionals have been consumed on the command
+  /// line before picking the right type.
+  std::string positionalType;
+
+  /// Choice list of the first positional (populated only when the positional was registered
+  /// via sen::cli::addChoice); empty otherwise.
+  std::vector<std::string> positionalChoices;
+};
+
+struct OptionFacts
+{
+  /// Owner node path (same key as NodeFacts::path).
+  std::string path;
+
+  /// The option token this entry describes (one of the strings in NodeFacts::optionsTakingValue).
+  std::string token;
+
+  /// CLI11 type_name of the option's value (e.g., "TEXT", "TEXT:FILE", "TEXT:DIR", "TEXT:{a,b}").
+  std::string typeName;
+
+  /// Choices registered via sen::cli::addChoice. Each entry carries a value and an optional
+  /// description; undescribed choices (registered via the string-only overload) have an empty
+  /// description.
+  std::vector<NamedEntry> choices;
+};
+
+struct CompletionTree
+{
+  std::vector<NodeFacts> nodes;
+  std::vector<OptionFacts> options;
+};
+
+/// Walks the merged spec and returns a flattened CompletionTree suitable for shell emission.
+CompletionTree buildCompletionTree(const nlohmann::json& mergedSpec);
+
+/// List of (key, value) pairs. Emitters use this shape to represent the associative data a
+/// shell needs to declare: each pair becomes one entry in a bash assoc array, zsh hash, fish
+/// switch case, or PowerShell hashtable.
+using KVList = std::vector<std::pair<std::string, std::string>>;
+
+/// Per-node list of NamedEntry candidates, keyed by node path. Description-aware shells (zsh,
+/// fish, PowerShell) pull the `items` field from the rendered context; bash ignores it and
+/// uses the space-joined KVList form instead.
+using ItemsByPath = std::vector<std::pair<std::string, std::vector<NamedEntry>>>;
+
+std::string joinSpace(const std::vector<std::string>& items);
+
+/// Maps path -> space-joined subcommand names; one entry per node.
+KVList subcommandsByPath(const CompletionTree& tree);
+
+/// Maps path -> space-joined list of all option/flag tokens (long + short, with dashes).
+KVList optionTokensByPath(const CompletionTree& tree);
+
+/// Maps path -> space-joined list of tokens that consume a value argument.
+KVList optionsTakingValueByPath(const CompletionTree& tree);
+
+/// Maps path -> positional CLI11 type_name (only for nodes that have a positional).
+KVList positionalTypesByPath(const CompletionTree& tree);
+
+/// Maps path -> space-joined choice list for the positional (only for positionals with choices).
+KVList positionalChoicesByPath(const CompletionTree& tree);
+
+/// Maps "path|token" -> CLI11 type_name of the option's value.
+KVList optionTypesByKey(const CompletionTree& tree);
+
+/// Maps "path|token" -> space-joined choice list (empty for non-choice options).
+KVList optionChoicesByKey(const CompletionTree& tree);
+
+/// Per-node subcommand candidates with descriptions, keyed by node path.
+ItemsByPath subcommandItemsByPath(const CompletionTree& tree);
+
+/// Per-node option/flag tokens with descriptions, keyed by node path.
+ItemsByPath optionTokenItemsByPath(const CompletionTree& tree);
+
+/// Per-node value-consuming option tokens with descriptions, keyed by node path.
+ItemsByPath optionsTakingValueItemsByPath(const CompletionTree& tree);
+
+/// Per-option choice lists with descriptions, keyed by "path|token". Used by shells that
+/// render descriptions alongside a `--flag <TAB>` value-list completion.
+ItemsByPath optionChoiceItemsByKey(const CompletionTree& tree);
+
+/// Registry entry for a single data section that emitters declare in their output script.
+/// Each shell emitter iterates dataSections, derives its shell-specific variable name from
+/// logicalName, and invokes getter(tree) to get the KVList to encode. For sections whose
+/// candidates carry descriptions (subcommands, options), itemsGetter returns the name/
+/// description pairs that description-aware shells embed alongside each candidate; null
+/// means the section has no descriptions (e.g., positional file types, choice lists).
+/// Adding a new data section requires appending one entry here plus referencing it from each
+/// shell's walker.
+struct DataSection
+{
+  const char* logicalName;
+  KVList (*getter)(const CompletionTree&);
+  ItemsByPath (*itemsGetter)(const CompletionTree&);
+};
+
+inline constexpr std::array<DataSection, 7> dataSections = {{
+  {"subs", subcommandsByPath, subcommandItemsByPath},
+  {"opts", optionTokensByPath, optionTokenItemsByPath},
+  {"opts_val", optionsTakingValueByPath, optionsTakingValueItemsByPath},
+  {"positional_type", positionalTypesByPath, nullptr},
+  {"positional_choices", positionalChoicesByPath, nullptr},
+  {"option_type", optionTypesByKey, nullptr},
+  {"option_choices", optionChoicesByKey, optionChoiceItemsByKey},
+}};
+
+using VarNameFn = std::function<std::string(const char* logicalName)>;
+using EscapeFn = std::function<std::string(std::string_view)>;
+
+/// Builds the inja context shared by every shell template. Each section's `entries` array
+/// carries both a space-joined `value` (for bash) and an `items` array of `{name, description}`
+/// pairs (for shells that render per-candidate descriptions). Escape callbacks adjust keys,
+/// values, and descriptions for shell-specific quoting rules; when null, no escaping is applied.
+///
+///   { "sections": [
+///       {
+///         "var_name": "_sen_subs",
+///         "entries": [
+///           {
+///             "key":   "sen",
+///             "value": "run generate archive",
+///             "items": [ {"name": "run", "description": "Run a sen kernel"}, ... ]
+///           }
+///         ]
+///       }
+///   ] }
+nlohmann::json buildSectionsContext(const CompletionTree& tree,
+                                    const VarNameFn& varNameFn,
+                                    const EscapeFn& valueEscape = nullptr,
+                                    const EscapeFn& descriptionEscape = nullptr);
+
+// --------------------------------------------------------------------------------------------
+// Emission entry point
+// --------------------------------------------------------------------------------------------
+
+enum class Shell
+{
+  bash,
+  zsh,
+  fish,
+  powershell
+};
+
+/// Renders the completion script for the given shell from the merged CLI spec. The output is a
+/// self-contained, sourceable script; no runtime `sen __complete` callback is involved.
+void emit(Shell shell, const nlohmann::json& mergedSpec, std::ostream& out);
+
+}  // namespace completions
+
+#endif  // SEN_APPS_CLI_GEN_COMPLETIONS_COMPLETION_TREE_H
