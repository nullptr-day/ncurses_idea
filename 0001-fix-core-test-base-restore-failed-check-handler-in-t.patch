From b433597d6bc751ff3ab6780650905fc9be681ff0 Mon Sep 17 00:00:00 2001
From: Enrique Parodi Spalazzi <enrique.parodi@airbus.com>
Date: Tue, 21 Apr 2026 00:36:18 +0200
Subject: [PATCH] fix[core/test/base]: restore failed-check handler in test
 teardown

Two latent bugs where tests installed a custom failed-check handler but
never restored the original, leaving the test handler globally installed
for the rest of the suite. This caused SIGSEGV-instead-of-SIGABRT in
death tests that rely on the default handler's std::raise(SIGABRT)
(Compiler.failure, IOUtils.BaseTypeUnhandledPaths_Death,
ResizableBufferWriterTypedTest.ReverseUnderflowTriggersAssert).

- assert_test.cpp: SetUp shadowed the member with a local auto, so the
  original handler was never captured; TearDown re-installed the test
  handler instead of the saved one.
- static_vector_test.cpp: checkTermination had the same teardown bug.

Co-Authored-By: Claude Opus 4.7 <noreply@anthropic.com>
---
 libs/core/test/base/assert_test.cpp        | 5 +++--
 libs/core/test/base/static_vector_test.cpp | 2 +-
 2 files changed, 4 insertions(+), 3 deletions(-)

diff --git a/libs/core/test/base/assert_test.cpp b/libs/core/test/base/assert_test.cpp
index 2da1dfa..8a2dfb4 100644
--- a/libs/core/test/base/assert_test.cpp
+++ b/libs/core/test/base/assert_test.cpp
@@ -17,6 +17,7 @@
 
 // std
 #include <cstddef>
+#include <tuple>
 
 using sen::impl::CheckInfo;
 using sen::impl::CheckType;
@@ -50,12 +51,12 @@ class AssertTest: public ::testing::Test
 protected:
   void SetUp() override
   {
-    auto oldHandler = setFailedCheckHandler(testAssertHandler);
+    oldHandler = setFailedCheckHandler(testAssertHandler);
     ASSERT_NE(oldHandler, nullptr);
     prevCallCount = callCount;
   }
 
-  void TearDown() override { oldHandler = setFailedCheckHandler(testAssertHandler); }
+  void TearDown() override { std::ignore = setFailedCheckHandler(oldHandler); }
 
   FailedCheckHandler oldHandler;   // NOLINT(misc-non-private-member-variables-in-classes)
   std::size_t prevCallCount = 0U;  // NOLINT(misc-non-private-member-variables-in-classes)
diff --git a/libs/core/test/base/static_vector_test.cpp b/libs/core/test/base/static_vector_test.cpp
index 672c85c..839c597 100644
--- a/libs/core/test/base/static_vector_test.cpp
+++ b/libs/core/test/base/static_vector_test.cpp
@@ -52,7 +52,7 @@ void checkTermination(std::function<void()> func)
 
   EXPECT_EQ(callCount, prevCallCount + 1);
 
-  oldHandler = sen::impl::setFailedCheckHandler(testAssertHandler);
+  std::ignore = sen::impl::setFailedCheckHandler(oldHandler);
 }
 
 template <typename V, std::size_t size>
-- 
2.51.0

