diff --git a/resources/syntax_highlighting/stl/github_linguist/heuristics-entry.yml b/resources/syntax_highlighting/stl/github_linguist/heuristics-entry.yml
new file mode 100644
index 0000000..29207ce
--- /dev/null
+++ b/resources/syntax_highlighting/stl/github_linguist/heuristics-entry.yml
@@ -0,0 +1,30 @@
+# Snippet to add to lib/linguist/heuristics.yml in a fork of
+# https://github.com/github-linguist/linguist.
+#
+# The `.stl` extension is already registered in Linguist for the
+# stereolithography / 3D-printing file format. A heuristic is required so
+# Linguist can decide which language a given `.stl` file belongs to.
+#
+# Distinguishing signals:
+#   - Sen STL always has a `package <name>;` declaration near the top,
+#     and/or one of the STL declaration keywords (class, struct, enum,
+#     variant, interface, sequence, array, optional, quantity, alias).
+#   - Stereolithography ASCII starts with `solid <name>` on line 1.
+#   - Stereolithography binary has an 80-byte header that cannot match
+#     the STL keywords reliably, but the heuristic below sticks to
+#     textual signals, which is enough in practice.
+#
+# The existing 3D-printing entry in heuristics.yml (if any) will need
+# to coexist with the block below. In current Linguist there is a
+# disambiguation for `.stl` listing only STL (stereolithography).
+# Extend that block rather than adding a second one.
+
+disambiguations:
+  - extensions: ['.stl']
+    rules:
+      - language: Sen STL
+        pattern: '(?m)^\s*package\s+[A-Za-z_][A-Za-z0-9_.]*\s*;'
+      - language: Sen STL
+        pattern: '(?m)^\s*(class|struct|enum|variant|interface|sequence|array|optional|quantity|alias)\s+[A-Za-z_]'
+      - language: STL
+        pattern: '\A\s*solid\b'
diff --git a/resources/syntax_highlighting/stl/github_linguist/languages-entry.yml b/resources/syntax_highlighting/stl/github_linguist/languages-entry.yml
