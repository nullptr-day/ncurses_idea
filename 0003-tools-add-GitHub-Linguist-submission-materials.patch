@@ -0,0 +1,15 @@
+# Snippet to add to lib/linguist/languages.yml in a fork of
+# https://github.com/github-linguist/linguist.
+#
+# Insert this entry alphabetically (it will land between "Self" and "ShaderLab"
+# in current Linguist). language_id is auto-assigned by the Linguist
+# maintainers during PR review - leave the placeholder and ask in the PR.
+
+Sen STL:
+  type: programming
+  color: "#c97660"
+  extensions:
+    - ".stl"
+  tm_scope: source.stl
+  ace_mode: text
+  language_id: 000000   # TBD - Linguist maintainers assign a unique id
